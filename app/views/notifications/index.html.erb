<div class="container-fluid py-4" data-controller="notifications">
  <div class="row g-4">
    <%# ══ SIDEBAR ══ %>
    <div class="col-lg-3">
      <div class="card border-0 shadow-sm sticky-top" style="top: 1rem;">
        <div class="card-body p-3">
          <%# Header %>
          <div class="d-flex align-items-center gap-2 mb-3">
            <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 d-flex">
              <i class="bi bi-bell-fill fs-5"></i>
            </div>
            <div>
              <h6 class="fw-bold mb-0">Notificaciones</h6>
              <small class="text-muted">
                <% if @unread_count > 0 %>
                  <span class="text-danger fw-semibold"><%= @unread_count %> sin leer</span>
                <% else %>
                  Todo al día ✓
                <% end %>
              </small>
            </div>
          </div>
          <hr class="my-2">
          <%# Filtros por tipo %>
          <div class="list-group list-group-flush mb-3">
            <%= link_to notifications_path,
                  class: "list-group-item list-group-item-action border-0 rounded-3 d-flex justify-content-between align-items-center mb-1 py-2 #{'active fw-semibold' if params[:q].blank?}" do %>
              <span class="d-flex align-items-center gap-2">
                <i class="bi bi-grid-1x2"></i> Todas
              </span>
              <span class="badge rounded-pill <%= params[:q].blank? ? 'bg-white text-primary' : 'bg-light text-dark' %>">
                <%= policy_scope(Notification).count %>
              </span>
            <% end %>
            <% Notification::TYPES.each do |type, config| %>
              <% count = @types_counts[type] || 0 %>
              <% active = params.dig(:q, :notification_type_eq) == type %>
              <%= link_to notifications_path(q: { notification_type_eq: type }),
                    class: "list-group-item list-group-item-action border-0 rounded-3 d-flex justify-content-between align-items-center mb-1 py-2 #{'active fw-semibold' if active}" do %>
                <span class="d-flex align-items-center gap-2">
                  <i class="bi <%= config[:icon] %>"></i>
                  <%= config[:label] %>
                </span>
                <span class="badge rounded-pill <%= active ? 'bg-white text-primary' : 'bg-light text-dark' %>">
                  <%= count %>
                </span>
              <% end %>
            <% end %>
          </div>
          <%# Acción global %>
          <% if @unread_count > 0 %>
            <%= button_to mark_all_as_read_notifications_path,
                  method: :patch,
                  class: "btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2",
                  style: "font-size: 0.82rem;",
                  form: {
                    data: {
                      turbo_confirm: "¿Marcar todas las notificaciones como leídas?",
                      turbo_stream: true
                    }
                  } do %>
              <i class="bi bi-check2-all"></i> Marcar todas como leídas
            <% end %>
          <% else %>
            <div class="text-center py-2">
              <span class="text-success small d-flex align-items-center justify-content-center gap-1">
                <i class="bi bi-check-circle-fill"></i> Sin pendientes
              </span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <%# ══ PANEL PRINCIPAL ══ %>
    <div class="col-lg-9">
      <%# Buscador %>
      <div class="mb-3">
        <%= search_form_for @q, url: notifications_path, html: { class: "position-relative" } do |f| %>
          <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"
             style="pointer-events: none;"></i>
          <%= f.search_field :message_cont,
                class: "form-control ps-5 border-0 shadow-sm rounded-3 bg-white",
                placeholder: "Buscar en notificaciones...",
                style: "height: 2.75rem;" %>
        <% end %>
      </div>
      <%# Meta info %>
      <div class="d-flex justify-content-between align-items-center mb-3">
        <small class="text-muted">
          <% if @notifications.total_count > 0 %>
            Mostrando <strong><%= @notifications.count %></strong>
            de <strong><%= @notifications.total_count %></strong> notificaciones
          <% end %>
        </small>
        <% if params.dig(:q, :notification_type_eq).present? %>
          <% type = params.dig(:q, :notification_type_eq) %>
          <% config = Notification::TYPES[type] %>
          <% if config %>
            <span class="badge d-inline-flex align-items-center gap-1"
                  style="background-color: var(--bs-<%= config[:color] %>); font-size: 0.72rem;">
              <i class="bi <%= config[:icon] %>"></i>
              <%= config[:label] %>
              <%= link_to notifications_path, class: "text-white ms-1 text-decoration-none" do %>
                <i class="bi bi-x-circle-fill"></i>
              <% end %>
            </span>
          <% end %>
        <% end %>
      </div>
      <%# Lista de notificaciones %>
      <div id="notifications_list" class="vstack gap-2">
        <% if @notifications.any? %>
          <%= render @notifications %>
        <% else %>
          <div class="card border-0 shadow-sm">
            <div class="card-body py-5 text-center">
              <i class="bi bi-bell-slash display-4 d-block mb-3 opacity-25"></i>
              <h5 class="text-muted fw-semibold">Sin notificaciones</h5>
              <p class="text-muted small mb-3">
                <% if params[:q].present? %>
                  No hay resultados para tu búsqueda.
                  <%= link_to "Limpiar filtros", notifications_path, class: "link-primary" %>
                <% else %>
                  Cuando recibas notificaciones, aparecerán aquí.
                <% end %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
      <%# Paginación %>
      <% if @notifications.total_count > 15 %>
        <div class="mt-4 d-flex justify-content-center">
          <%= paginate @notifications %>
        </div>
      <% end %>
    </div>
  </div>
</div>
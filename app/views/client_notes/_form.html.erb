<%# app/views/client_notes/_form.html.erb %>
<div id="client_note_form">
  <%= simple_form_for [client, note],
        html: {
          data: {
            turbo_stream: true,
            controller: "client-note-form",
            action: "submit->client-note-form#clearOnSuccess"
          }
        } do |f| %>
    <% if note.errors.any? %>
      <div class="alert alert-danger py-2 small mb-2">
        <% note.errors.full_messages.each do |msg| %>
          <div><i class="bi bi-exclamation-circle me-1"></i><%= msg %></div>
        <% end %>
      </div>
    <% end %>
    <div class="mb-2">
      <%= f.input :body,
            label: false,
            input_html: {
              rows: 3,
              class: "form-control form-control-sm",
              placeholder: "Escribí una nota sobre este cliente...",
              data: { "client-note-form-target": "body" }
            } %>
    </div>
    <div class="row g-2 mb-2">
      <div class="col-8">
        <%= f.input :category,
              label: false,
              as: :select,
              collection: ClientNote.categories.keys.map { |k|
                [ClientNote::CATEGORY_LABELS[k], k]
              },
              include_blank: "— Categoría —",
              input_html: { class: "form-select form-select-sm" } %>
      </div>
      <div class="col-4 d-flex align-items-center">
        <%= f.input :pinned,
              label: "Fijar",
              as: :boolean,
              wrapper_html: { class: "mb-0 d-flex align-items-center gap-2" },
              input_html: { class: "form-check-input" } %>
      </div>
    </div>
    <div class="d-flex justify-content-end">
      <%= f.submit "Agregar nota", class: "btn btn-sm btn-primary d-flex align-items-center gap-1" %>
    </div>
  <% end %>
</div>
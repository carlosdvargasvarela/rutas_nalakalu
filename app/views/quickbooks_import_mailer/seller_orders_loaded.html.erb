  <!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <style>
      .mail-body { font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1e293b; max-width: 800px; margin: 0 auto; background-color: #f1f5f9; padding: 20px; }
      .main-container { background: white; border-radius: 12px; overflow: hidden; }
      .header { background-color: #4f46e5; color: white; padding: 30px; text-align: center; }
      .header h1 { margin: 0; font-size: 24px; font-weight: 800; }
      .header p { margin: 8px 0 0; opacity: 0.85; font-size: 14px; }
      .content { padding: 30px; }
      .summary-box { background: #eef2ff; border-radius: 8px; padding: 20px; margin-bottom: 28px; border: 1px solid #e0e7ff; }
      .order-card { border: 1px solid #e2e8f0; border-radius: 10px; margin-bottom: 20px; overflow: hidden; }
      .order-header { background: #f8fafc; padding: 14px 20px; border-bottom: 1px solid #e2e8f0; display: table; width: 100%; box-sizing: border-box; }
      .order-number { display: table-cell; font-size: 16px; font-weight: 800; color: #1e293b; }
      .order-badge { display: table-cell; text-align: right; vertical-align: middle; }
      .badge-new { background: #dcfce7; color: #166534; padding: 3px 10px; border-radius: 9999px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
      .badge-updated { background: #fef9c3; color: #854d0e; padding: 3px 10px; border-radius: 9999px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
      .order-body { padding: 16px 20px; }
      .meta-grid { display: table; width: 100%; margin-bottom: 14px; }
      .meta-col { display: table-cell; width: 50%; vertical-align: top; font-size: 13px; padding-right: 10px; }
      .label { display: block; font-size: 11px; color: #64748b; text-transform: uppercase; font-weight: 700; margin-bottom: 3px; }
      .items-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 10px; }
      .items-table th { text-align: left; padding: 8px 10px; background: #f1f5f9; color: #475569; font-size: 11px; text-transform: uppercase; font-weight: 700; }
      .items-table td { padding: 8px 10px; border-bottom: 1px solid #f1f5f9; }
      .items-table tr:last-child td { border-bottom: none; }
      .notes-box { background: #fafafa; border-left: 3px solid #c7d2fe; border-radius: 0 6px 6px 0; padding: 10px 14px; margin-top: 12px; font-size: 13px; color: #475569; }
      .footer { text-align: center; padding: 20px; color: #94a3b8; font-size: 12px; }
    </style>
  </head>
  <body class="mail-body">
    <div class="main-container">
      <div class="header">
        <h1>📦 Pedidos Cargados desde QuickBooks</h1>
        <p><%= l(Date.today, format: :long) %></p>
      </div>

      <div class="content">
        <p>Hola <strong><%= @seller.name %></strong>, se acaba de procesar la siguiente información desde QuickBooks:</p>

        <div class="summary-box">
          <table width="100%">
            <tr>
              <td align="center">
                <span style="font-size:26px; font-weight:800; color:#4f46e5"><%= @orders_data.size %></span><br>
                <span style="font-size:11px; color:#64748b; text-transform:uppercase; font-weight:600">Total pedidos</span>
              </td>
              <% if @created_count > 0 %>
                <td align="center" style="border-left: 1px solid #c7d2fe">
                  <span style="font-size:26px; font-weight:800; color:#16a34a"><%= @created_count %></span><br>
                  <span style="font-size:11px; color:#64748b; text-transform:uppercase; font-weight:600">Nuevos</span>
                </td>
              <% end %>
              <% if @updated_count > 0 %>
                <td align="center" style="border-left: 1px solid #c7d2fe">
                  <span style="font-size:26px; font-weight:800; color:#d97706"><%= @updated_count %></span><br>
                  <span style="font-size:11px; color:#64748b; text-transform:uppercase; font-weight:600">Actualizados</span>
                </td>
              <% end %>
            </tr>
          </table>
        </div>

        <% @orders_data.each do |order| %>
          <div class="order-card">
            <div class="order-header">
              <span class="order-number">Pedido #<%= order[:order_number] %></span>
              <span class="order-badge">
                <% if order[:action] == "created" %>
                  <span class="badge-new">✦ Nuevo</span>
                <% else %>
                  <span class="badge-updated">↻ Actualizado</span>
                <% end %>
              </span>
            </div>
            <div class="order-body">
              <div class="meta-grid">
                <div class="meta-col">
                  <span class="label">Cliente</span>
                  <strong><%= order[:client_name].presence || "—" %></strong>
                </div>
                <div class="meta-col">
                  <span class="label">Fecha de Entrega</span>
                  <% if order[:delivery_date].present? %>
                    <strong><%= Date.parse(order[:delivery_date]).strftime("%d/%m/%Y") rescue order[:delivery_date] %></strong>
                  <% else %>
                    <span style="color:#94a3b8">No especificada</span>
                  <% end %>
                </div>
              </div>

              <% if order[:items].present? %>
                <span class="label">Productos</span>
                <table class="items-table">
                  <thead>
                    <tr>
                      <th>Producto</th>
                      <th style="text-align:right; width:80px">Cantidad</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% order[:items].each do |item| %>
                      <tr>
                        <td><%= item[:product] %></td>
                        <td style="text-align:right; font-weight:700; color:#4f46e5">
                          <%= item[:quantity].to_f == item[:quantity].to_f.to_i ? item[:quantity].to_i : item[:quantity] %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              <% end %>

              <% if order[:notes].present? %>
                <div class="notes-box">
                  <strong style="font-size:11px; text-transform:uppercase; color:#6366f1">Notas:</strong><br>
                  <%= order[:notes] %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="footer">
        <p>Sistema de Rutas NaLakalu • Por favor no respondas a este correo.</p>
      </div>
    </div>
  </body>
</html>

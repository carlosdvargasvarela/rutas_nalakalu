<!-- app/views/dashboard/index.html.erb -->
<div class="container-fluid py-4">
  <!-- Header con Saludo y Acciones Rápidas -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="fw-bold mb-1 text-dark">
        <i class="bi bi-speedometer2 me-2 text-primary"></i>
        Panel de Control
      </h2>
      <p class="text-muted mb-0">
        Hola, <strong><%= current_user.name %></strong>. 
        Aquí tienes el resumen de logística para hoy.
      </p>
    </div>
    <div class="d-flex gap-2">
      <% if current_user.admin? || current_user.production_manager? %>
        <%= link_to new_delivery_import_path, class: "btn btn-outline-primary rounded-pill shadow-sm" do %>
          <i class="bi bi-file-earmark-excel me-1"></i> Importar
        <% end %>
      <% end %>
      <% if current_user.seller? || current_user.admin? %>
        <%= link_to orders_path, class: "btn btn-primary rounded-pill shadow-sm" do %>
          <i class="bi bi-plus-lg me-1"></i> Nuevo Pedido
        <% end %>
      <% end %>
      <%= link_to notifications_path, class: "btn btn-outline-info rounded-pill shadow-sm position-relative" do %>
        <i class="bi bi-bell"></i>
        <% if @unread_notifications_count > 0 %>
          <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
            <%= @unread_notifications_count %>
          </span>
        <% end %>
      <% end %>
    </div>
  </div>
  <!-- KPIs en Cards Minimalistas -->
  <div class="row g-3 mb-4">
    <%= render "dashboard/kpi_cards" %>
  </div>
  <div class="row g-4">
    <!-- Columna Izquierda: Tablas de Datos (UX Mejorada con Tabs) -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 pt-4 px-4">
          <ul class="nav nav-pills mb-3" id="dashboardTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active rounded-pill" id="unplanned-tab" data-bs-toggle="pill" data-bs-target="#unplanned" type="button">
                <i class="bi bi-list-ul me-1"></i> Sin Plan (Esta Semana)
                <span class="badge bg-light text-primary ms-1"><%= @unplanned_this_week.total_count %></span>
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link rounded-pill" id="errors-tab" data-bs-toggle="pill" data-bs-target="#errors" type="button">
                <i class="bi bi-exclamation-triangle me-1"></i> Con Errores 
                <span class="badge bg-danger ms-1"><%= @deliveries_with_errors.total_count %></span>
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link rounded-pill" id="reschedules-tab" data-bs-toggle="pill" data-bs-target="#reschedules" type="button">
                <i class="bi bi-arrow-repeat me-1"></i> Reprogramaciones
                <span class="badge bg-warning text-dark ms-1"><%= @reschedule_notifications.total_count %></span>
              </button>
            </li>
            <% if @pending_approvals.any? %>
              <li class="nav-item" role="presentation">
                <button class="nav-link rounded-pill" id="approvals-tab" data-bs-toggle="pill" data-bs-target="#approvals" type="button">
                  <i class="bi bi-shield-check me-1"></i> Por Aprobar 
                  <span class="badge bg-info text-dark ms-1"><%= @pending_approvals.total_count %></span>
                </button>
              </li>
            <% end %>
          </ul>
        </div>
        <div class="card-body p-0">
          <div class="tab-content" id="dashboardTabsContent">
            <!-- Tab: Sin Plan (Esta Semana) -->
            <div class="tab-pane fade show active" id="unplanned" role="tabpanel">
              <%= render "dashboard/table_unplanned", deliveries: @unplanned_this_week %>
            </div>
            <!-- Tab: Errores -->
            <div class="tab-pane fade" id="errors" role="tabpanel">
              <%= render "dashboard/table_errors", deliveries: @deliveries_with_errors %>
            </div>
            <!-- Tab: Reprogramaciones -->
            <div class="tab-pane fade" id="reschedules" role="tabpanel">
              <%= render "dashboard/table_reschedules", notifications: @reschedule_notifications %>
            </div>
            <!-- Tab: Por Aprobar -->
            <% if @pending_approvals.any? %>
              <div class="tab-pane fade" id="approvals" role="tabpanel">
                <%= render "dashboard/table_approvals", deliveries: @pending_approvals %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <!-- Columna Derecha: Tareas y Notificaciones -->
    <div class="col-lg-4">
      <div class="mb-4">
        <%= render "dashboard/pending_tasks", tasks: @pending_tasks %>
      </div>
      <div>
        <%= render "dashboard/recent_notifications", notifications: @recent_notifications %>
      </div>
    </div>
  </div>
  <!-- Soporte -->
  <div class="alert alert-info mt-5 rounded-3 d-flex align-items-center shadow-sm">
    <i class="bi bi-question-circle-fill fs-4 me-2"></i>
    <span>
      ¿Necesitas ayuda? 
      <a href="mailto:cvargas@nalakalu.com" class="fw-semibold ms-1">Contacta al equipo de soporte</a>
    </span>
  </div>
</div>
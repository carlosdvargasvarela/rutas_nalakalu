<!-- app/views/dashboard/_kpi_cards.html.erb -->
<div class="col-md-3">
  <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
    <div class="d-flex align-items-center">
      <div class="flex-shrink-0 bg-primary bg-opacity-10 p-3 rounded-3">
        <i class="bi bi-truck text-primary fs-4"></i>
      </div>
      <div class="flex-grow-1 ms-3">
        <h6 class="text-muted small mb-0">Entregas Pendientes</h6>
        <h4 class="fw-bold mb-0"><%= @pending_deliveries_count %></h4>
      </div>
    </div>
  </div>
</div>
<div class="col-md-3">
  <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
    <div class="d-flex align-items-center">
      <div class="flex-shrink-0 bg-success bg-opacity-10 p-3 rounded-3">
        <i class="bi bi-box-seam text-success fs-4"></i>
      </div>
      <div class="flex-grow-1 ms-3">
        <h6 class="text-muted small mb-0">Pedidos Activos</h6>
        <h4 class="fw-bold mb-0"><%= @active_orders_count %></h4>
      </div>
    </div>
  </div>
</div>
<div class="col-md-3">
  <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
    <div class="d-flex align-items-center">
      <div class="flex-shrink-0 bg-info bg-opacity-10 p-3 rounded-3">
        <i class="bi bi-calendar-event text-info fs-4"></i>
      </div>
      <div class="flex-grow-1 ms-3">
        <h6 class="text-muted small mb-0">Planes Semanales</h6>
        <h4 class="fw-bold mb-0"><%= @upcoming_plans_count %></h4>
      </div>
    </div>
  </div>
</div>
<div class="col-md-3">
  <div class="card border-0 shadow-sm rounded-4 p-3 h-100">
    <div class="d-flex align-items-center">
      <div class="flex-shrink-0 bg-warning bg-opacity-10 p-3 rounded-3">
        <i class="bi bi-bell text-warning fs-4"></i>
      </div>
      <div class="flex-grow-1 ms-3">
        <h6 class="text-muted small mb-0">Notificaciones</h6>
        <h4 class="fw-bold mb-0"><%= @unread_notifications_count %></h4>
      </div>
    </div>
  </div>
</div>
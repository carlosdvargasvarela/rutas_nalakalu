<!-- app/views/dashboard/_table_approvals.html.erb -->
<div class="table-responsive">
  <table class="table table-hover align-middle mb-0">
    <thead class="bg-light">
      <tr>
        <th class="ps-4">ID</th>
        <th>Fecha</th>
        <th>Pedido</th>
        <th>Cliente</th>
        <th>Vendedor</th>
        <th class="text-end pe-4">Acción</th>
      </tr>
    </thead>
    <tbody>
      <% if deliveries.any? %>
        <% deliveries.each do |delivery| %>
          <tr>
            <td class="ps-4">
              <%= link_to "##{delivery.id}", delivery_path(delivery), class: "fw-medium text-primary text-decoration-none" %>
            </td>
            <td><%= l delivery.delivery_date, format: :short %></td>
            <td>
              <%= link_to delivery.order.number, order_path(delivery.order), class: "text-decoration-none" %>
            </td>
            <td><%= delivery.order.client.name %></td>
            <td><%= delivery.order.seller.name %></td>
            <td class="text-end pe-4">
              <%= button_to approve_delivery_path(delivery), method: :patch,
                    class: "btn btn-outline-success btn-sm rounded-pill",
                    data: { turbo_confirm: "¿Aprobar la entrega ##{delivery.id}?" } do %>
                <i class="bi bi-check-circle"></i> Aprobar
              <% end %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="6" class="text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            No hay entregas pendientes de aprobación.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<!-- Paginación -->
<% if deliveries.any? %>
  <div class="card-footer bg-white border-0 d-flex justify-content-center py-3">
    <%= paginate deliveries, param_name: "page_approvals" %>
  </div>
<% end %>
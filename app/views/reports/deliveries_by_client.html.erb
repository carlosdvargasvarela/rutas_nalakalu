<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0">
      <i class="bi bi-file-earmark-bar-graph text-primary me-2"></i>Entregas por cliente
    </h1>
  </div>

  <%# Filtros %>
  <%= form_with url: report_deliveries_by_client_path, method: :get, local: true, class: "card shadow-sm mb-4" do |f| %>
    <div class="card-body">
      <div class="row g-3 align-items-end">
        <div class="col-sm-4">
          <%= f.label :from, "Desde", class: "form-label small fw-semibold" %>
          <%= f.date_field :from, value: @from, class: "form-control" %>
        </div>
        <div class="col-sm-4">
          <%= f.label :to, "Hasta", class: "form-label small fw-semibold" %>
          <%= f.date_field :to, value: @to, class: "form-control" %>
        </div>
        <div class="col-sm-4">
          <%= f.submit "Filtrar", class: "btn btn-primary w-100" %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Descarga %>
  <% if @deliveries.any? %>
    <div class="d-flex gap-2 mb-3">
      <%= link_to report_deliveries_by_client_path(from: @from, to: @to, format: :xlsx),
            class: "btn btn-success" do %>
        <i class="bi bi-file-earmark-excel me-1"></i>Descargar Excel
      <% end %>
      <%= link_to report_deliveries_by_client_path(from: @from, to: @to, format: :pdf),
            class: "btn btn-danger" do %>
        <i class="bi bi-file-earmark-pdf me-1"></i>Descargar PDF
      <% end %>
    </div>

    <%# Vista previa %>
    <div class="card shadow-sm">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-table me-1"></i>
        <%= @deliveries.size %> entrega<%= @deliveries.size == 1 ? "" : "s" %>
        del <%= l(@from, format: :long) %> al <%= l(@to, format: :long) %>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
              <tr>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Pedido</th>
                <th>Camión</th>
              </tr>
            </thead>
            <tbody>
              <% @deliveries.each do |d| %>
                <tr>
                  <td class="fw-semibold"><%= d.order.client.name %></td>
                  <td><%= l(d.delivery_date, format: :long) %></td>
                  <td>
                    <%= link_to d.order.number, delivery_path(d),
                          class: "text-decoration-none text-primary fw-semibold" %>
                  </td>
                  <td>
                    <% truck = d.delivery_plan_assignment&.delivery_plan&.truck %>
                    <% if truck %>
                      <span class="badge bg-dark"><i class="bi bi-truck me-1"></i><%= truck %></span>
                    <% else %>
                      <span class="text-muted fst-italic small">Sin asignar</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% else %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle me-2"></i>
      Sin entregas para el período <strong><%= l(@from, format: :long) %> – <%= l(@to, format: :long) %></strong>.
    </div>
  <% end %>
</div>

<%# app/views/devise/registrations/edit.html.erb %>
<% content_for :title, "Mi Perfil" %>
<div class="container-fluid py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-6">
      <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4 p-md-5">
          <div class="d-flex align-items-center mb-4">
            <div class="flex-shrink-0 btn-soft-secondary p-3 rounded-circle">
              <i class="bi bi-person-gear fs-3"></i>
            </div>
            <div class="flex-grow-1 ms-3">
              <h4 class="mb-0 fw-bold">Configuración de Perfil</h4>
              <p class="text-muted mb-0 small">Gestiona tu información y seguridad</p>
            </div>
          </div>
          <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
            <div class="row g-3">
              <div class="col-md-6">
                <%= f.input :name, label: "Nombre completo" %>
              </div>
              <div class="col-md-6">
                <%= f.input :email, label: "Correo electrónico", input_html: { readonly: true }, hint: "No editable" %>
              </div>
            </div>
            <hr class="my-4">
            <div class="bg-light p-3 rounded-3 mb-4">
              <h6 class="fw-bold mb-3 text-primary">
                <i class="bi bi-shield-lock me-2"></i>Seguridad
              </h6>
              <div class="row g-3">
                <div class="col-md-6">
                  <%= f.input :password, 
                      label: "Nueva contraseña", 
                      required: resource.force_password_change?,
                      hint: (resource.force_password_change? ? "Requerido por seguridad" : "Dejar en blanco si no desea cambiarla") %>
                </div>
                <div class="col-md-6">
                  <%= f.input :password_confirmation, 
                      label: "Confirmar contraseña",
                      required: resource.force_password_change? %>
                </div>
              </div>
            </div>
            <% unless resource.force_password_change? %>
              <div class="mb-4">
                <%= f.input :current_password, 
                    label: "Contraseña actual", 
                    hint: "Necesaria para confirmar cambios",
                    input_html: { class: "form-control-light" } %>
              </div>
            <% end %>
            <div class="d-flex justify-content-end gap-2">
              <%= link_to "Volver", root_path, class: "btn btn-light px-4" %>
              <%= f.button :submit, "Guardar Cambios", class: "btn btn-primary px-4" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .btn-soft-secondary { background-color: #f8f9fa; color: #6c757d; border: 1px solid #dee2e6; }
  .form-control-light { background-color: #fdfdfd; }
</style>
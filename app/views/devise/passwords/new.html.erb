<%# app/views/devise/passwords/new.html.erb %>
<% content_for :title, "Recuperar contraseña" %>
<div class="card shadow-lg border-0 rounded-4">
  <div class="card-body p-5">
    <div class="text-center mb-4">
      <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-info bg-opacity-10 mb-3" style="width: 64px; height: 64px;">
        <i class="bi bi-envelope-paper fs-2 text-info"></i>
      </div>
      <h4 class="fw-semibold mb-1">Recuperar contraseña</h4>
      <p class="text-muted small mb-0">Te enviaremos instrucciones a tu correo</p>
    </div>
    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <div class="mb-4">
        <%= f.input :email,
            required: true,
            autofocus: true,
            label: "Correo electrónico",
            input_html: { class: "form-control form-control-lg" },
            wrapper_html: { class: "mb-3" } %>
      </div>
      <div class="d-grid mb-3">
        <%= f.button :submit, "Enviar instrucciones", class: "btn btn-info btn-lg" %>
      </div>
      <div class="text-center">
        <%= link_to new_session_path(resource_name), class: "text-decoration-none small d-inline-flex align-items-center" do %>
          <i class="bi bi-arrow-left me-1"></i>
          Volver al inicio de sesión
        <% end %>
      </div>
    <% end %>
  </div>
</div>
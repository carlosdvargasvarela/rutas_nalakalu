<%# app/views/devise/sessions/new.html.erb %>
<% content_for :title, "Iniciar sesión" %>
<div class="card shadow-lg border-0 rounded-4">
  <div class="card-body p-5">
    <div class="text-center mb-4">
      <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 mb-3" style="width: 64px; height: 64px;">
        <i class="bi bi-box-arrow-in-right fs-2 text-primary"></i>
      </div>
      <h4 class="fw-semibold mb-1">Bienvenido de nuevo</h4>
      <p class="text-muted small mb-0">Ingresa tus credenciales para continuar</p>
    </div>
    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-3">
        <%= f.input :email,
            required: true,
            autofocus: true,
            label: "Correo electrónico",
            input_html: { class: "form-control form-control-lg" },
            wrapper_html: { class: "mb-3" } %>
      </div>
      <div class="mb-3">
        <%= f.input :password,
            required: true,
            label: "Contraseña",
            input_html: { class: "form-control form-control-lg" },
            wrapper_html: { class: "mb-3" } %>
      </div>
      <% if devise_mapping.rememberable? %>
        <div class="mb-4">
          <%= f.input :remember_me,
              as: :boolean,
              label: "Mantener sesión iniciada",
              wrapper_html: { class: "form-check" } %>
        </div>
      <% end %>
      <div class="d-grid mb-3">
        <%= f.button :submit, "Iniciar sesión", class: "btn btn-primary btn-lg" %>
      </div>
      <div class="text-center">
        <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name), class: "text-decoration-none small" %>
      </div>
    <% end %>
  </div>
</div>
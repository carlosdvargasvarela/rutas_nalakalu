<%# app/views/layouts/application.html.erb %>
<!DOCTYPE html>
<html>
  <head>
    <title>NaLakalu - Rutas de Entrega</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <meta name="mobile-web-app-capable" content="yes">
    <link rel="manifest" href="/manifest.json">
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>
  <body class="bg-light" data-controller="bootstrap">
    <!-- Navbar persistente -->
    <div id="navbar-container" data-turbo-permanent>
      <%= render "layouts/navbar" %>
    </div>
    <%# Banner de mantenimiento — solo visible para usuarios con acceso permitido %>
    <% if MaintenanceWindow.active? %>
      <% mw = MaintenanceWindow.current_window %>
      <div class="alert alert-warning rounded-0 border-0 border-bottom border-warning mb-0 py-2 shadow-sm" role="alert">
        <div class="container-fluid d-flex align-items-center justify-content-center gap-3 flex-wrap">
          <span>
            <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>
            <strong>Modo mantenimiento activo</strong>
            <% if mw&.ends_at %>
              &mdash;
              <span class="badge bg-warning text-dark">
                <i class="bi bi-clock-history me-1"></i><%= mw.time_remaining %> min restantes
              </span>
            <% end %>
          </span>
          <% if current_user&.admin? || current_user&.manager? %>
            <%= link_to admin_maintenance_window_path, class: "btn btn-sm btn-outline-dark py-0 px-2" do %>
              <i class="bi bi-gear-fill me-1"></i>Gestionar
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
    <main class="container-fluid mt-4">
      <%= render "layouts/flashes" %>
      <%= yield %>
    </main>
    <%# Modal global unificado — turbo-frame "modal" vive DENTRO del modal de Bootstrap %>
    <div class="modal fade" id="globalModal" tabindex="-1" aria-hidden="true"
     data-controller="modal"
     data-turbo-permanent>
      <div class="modal-dialog modal-dialog-centered" data-modal-target="dialog">
        <div class="modal-content">
          <%= turbo_frame_tag "modal" %>
        </div>
      </div>
    </div>
    <script>
      window.GOOGLE_MAPS_API_KEY = "<%= ENV['GOOGLE_MAPS_API_KEY'] %>";
      if ('serviceWorker' in navigator && window.location.pathname.startsWith('/driver')) {
        window.addEventListener('load', async () => {
          try {
            const reg = await navigator.serviceWorker.register('/service-worker.js', {
              scope: '/driver/',
              updateViaCache: 'none'
            })
            console.log('[SW] Registered for /driver/', reg)
            reg.addEventListener('updatefound', () => {
              const newWorker = reg.installing
              newWorker.addEventListener('statechange', () => {
                if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                  console.log('[SW] New version available, reloading...')
                  window.location.reload()
                }
              })
            })
          } catch (e) {
            console.warn('[SW] Registration failed', e)
          }
        })
      }
    </script>
  </body>
</html>
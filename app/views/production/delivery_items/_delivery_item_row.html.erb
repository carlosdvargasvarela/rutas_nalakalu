<%# app/views/production/delivery_items/_delivery_item_row.html.erb %>
<%
  item_color = case item.load_status
    when "loaded"  then "success"
    when "missing" then "danger"
    else "secondary"
  end
%>
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3"
     data-controller="delivery-item"
     data-delivery-item-item-id-value="<%= item.id %>"
  data-delivery-item-delivery-id-value="<%= item.delivery_id %>"
    data-delivery-item-status-value="<%= item.load_status %>">
  <%# Info del producto %>
  <div class="d-flex align-items-center gap-3 flex-grow-1">
    <%# Ícono de estado %>
    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
         style="width:32px; height:32px; background: var(--bs-<%= item_color %>); opacity: 0.15;">
    </div>
    <div style="margin-left: -40px; padding-left: 40px;">
      <%# Ícono superpuesto %>
    </div>
    <div>
      <div class="fw-semibold"><%= item.order_item&.product_name || "Producto sin nombre" %></div>
      <div class="small text-muted d-flex flex-wrap gap-2 mt-1">
        <span><i class="bi bi-layers me-1"></i>Cant: <strong><%= item.quantity %></strong></span>
        <% if item.service_case? %>
          <span class="badge bg-warning text-dark">
            <i class="bi bi-tools me-1"></i>Caso de servicio
          </span>
        <% end %>
        <% if item.notes.present? %>
          <span class="text-muted fst-italic">
            <i class="bi bi-chat-left-text me-1"></i><%= item.notes.truncate(40) %>
          </span>
        <% end %>
      </div>
    </div>
  </div>
  <%# Badge + Botones de acción táctiles %>
  <div class="d-flex align-items-center gap-2 flex-shrink-0">
    <span data-delivery-item-target="badge">
      <%= load_status_badge(item.load_status) %>
    </span>
    <div class="d-flex gap-2" data-delivery-item-target="buttons">
      <% if policy(item).mark_loaded? %>
        <%= link_to mark_loaded_production_delivery_item_path(item),
            class: "btn btn-success btn-sm px-3 fw-semibold",
            title: "Marcar cargado",
            data: {
              turbo_method: :patch,
              action: "click->delivery-item#markLoaded"
            } do %>
          <i class="bi bi-check-lg me-1"></i>
          <span class="d-none d-md-inline">Cargado</span>
        <% end %>
      <% end %>
      <% if policy(item).mark_missing? %>
        <%= link_to mark_missing_production_delivery_item_path(item),
            class: "btn btn-outline-danger btn-sm px-3",
            title: "Marcar faltante",
            data: {
              turbo_method: :patch,
              action: "click->delivery-item#markMissing"
            } do %>
          <i class="bi bi-x-lg me-1"></i>
          <span class="d-none d-md-inline">Faltante</span>
        <% end %>
      <% end %>
      <% if policy(item).mark_unloaded? %>
        <%= link_to mark_unloaded_production_delivery_item_path(item),
            class: "btn btn-outline-secondary btn-sm",
            title: "Desmarcar",
            data: {
              turbo_method: :patch,
              action: "click->delivery-item#markUnloaded"
            } do %>
          <i class="bi bi-arrow-counterclockwise"></i>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
<%# app/views/production/delivery_plans/_plan_header.html.erb %>
<%
  load_color = case delivery_plan.load_status
    when "all_loaded"   then "success"
    when "partial"      then "warning"
    when "some_missing" then "danger"
    else "secondary"
  end
  driver_initials = delivery_plan.driver&.name&.split&.map { |w| w[0] }&.first(2)&.join&.upcase || "?"
%>
<div class="card border-0 shadow-sm mb-3" style="border-left: 4px solid var(--bs-<%= load_color %>) !important;">
  <div class="card-body py-3">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
      <%# Izquierda: navegación + info %>
      <div class="d-flex align-items-center gap-3">
        <%= link_to production_delivery_plans_path(date: delivery_plan.first_delivery_date || Date.current),
            class: "btn btn-outline-secondary btn-sm flex-shrink-0" do %>
          <i class="bi bi-arrow-left"></i>
        <% end %>
        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white flex-shrink-0"
             style="width:44px; height:44px; background: var(--bs-primary); font-size:0.9rem;">
          <%= driver_initials %>
        </div>
        <div>
          <h5 class="mb-0 fw-bold lh-1">
            <%= delivery_plan.driver&.name || "Sin asignar" %>
          </h5>
          <div class="small text-muted mt-1 d-flex flex-wrap gap-2">
            <span><i class="bi bi-hash me-1"></i>Plan #<%= delivery_plan.id %></span>
            <span><i class="bi bi-truck me-1"></i><%= delivery_plan.truck_label || "N/A" %></span>
            <span><i class="bi bi-calendar3 me-1"></i>Semana <%= delivery_plan.week %> / <%= delivery_plan.year %></span>
          </div>
        </div>
      </div>
      <%# Derecha: badge + barra de progreso %>
      <div class="d-flex flex-column align-items-end gap-2" style="min-width: 220px;">
        <div class="d-flex align-items-center gap-2">
          <%= load_status_badge(delivery_plan.load_status) %>
          <span class="fw-bold text-<%= load_color %> fs-5"><%= delivery_plan.load_percentage %>%</span>
        </div>
        <div class="progress w-100 rounded-pill" style="height: 14px;">
          <div class="progress-bar bg-<%= load_color %> progress-bar-striped progress-bar-animated"
               role="progressbar"
               style="width: <%= delivery_plan.load_percentage %>%"
               aria-valuenow="<%= delivery_plan.load_percentage %>"
            aria-valuemin="0" aria-valuemax="100">
          </div>
        </div>
        <div class="small text-muted">
          <%= load_stats[:loaded_items] %> de <%= load_stats[:total_items] %> productos cargados
        </div>
      </div>
    </div>
  </div>
</div>
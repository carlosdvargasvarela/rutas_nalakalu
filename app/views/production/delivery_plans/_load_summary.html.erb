<%# app/views/production/delivery_plans/_load_summary.html.erb %>
<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-3">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-3">
      <h6 class="mb-0 fw-semibold">
        <i class="bi bi-bar-chart-line me-2 text-primary"></i>Resumen de Carga
      </h6>
      <% if policy(delivery_plan).mark_all_loaded? %>
        <%= button_to mark_all_loaded_production_delivery_plan_path(delivery_plan),
            method: :post,
            class: "btn btn-success btn-sm fw-semibold px-3",
            data: { turbo_confirm: "¿Marcar TODOS los productos del plan como cargados? Esta acción no se puede deshacer." } do %>
          <i class="bi bi-check-all me-1"></i>Marcar Todo Cargado
        <% end %>
      <% end %>
    </div>
    <div class="row g-3 text-center">
      <div class="col-6 col-md-3">
        <div class="rounded-3 py-3 px-2 h-100" style="background:#f0f9ff; border: 1px solid #bae6fd;">
          <i class="bi bi-box-seam fs-4 text-primary mb-1 d-block"></i>
          <div class="fs-4 fw-bold text-primary"><%= load_stats[:total_items] %></div>
          <div class="small text-muted">Total productos</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="rounded-3 py-3 px-2 h-100" style="background:#f0fdf4; border: 1px solid #bbf7d0;">
          <i class="bi bi-check-circle-fill fs-4 text-success mb-1 d-block"></i>
          <div class="fs-4 fw-bold text-success"><%= load_stats[:loaded_items] %></div>
          <div class="small text-muted">Cargados</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="rounded-3 py-3 px-2 h-100" style="background:#fffbeb; border: 1px solid #fde68a;">
          <i class="bi bi-hourglass-split fs-4 text-warning mb-1 d-block"></i>
          <div class="fs-4 fw-bold text-warning"><%= load_stats[:unloaded_items] %></div>
          <div class="small text-muted">Sin cargar</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="rounded-3 py-3 px-2 h-100" style="background:#fff1f2; border: 1px solid #fecdd3;">
          <i class="bi bi-exclamation-triangle-fill fs-4 text-danger mb-1 d-block"></i>
          <div class="fs-4 fw-bold text-danger"><%= load_stats[:missing_items] %></div>
          <div class="small text-muted">Faltantes</div>
        </div>
      </div>
    </div>
  </div>
</div>
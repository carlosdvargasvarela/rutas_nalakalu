<%# app/views/production/deliveries/_delivery_items_list.html.erb %>
<div class="table-responsive">
  <table class="table table-hover align-middle mb-0">
    <thead class="table-light">
      <tr>
        <th class="ps-4">Producto</th>
        <th class="text-center">Cant. Pedida</th>
        <th class="text-center">Cant. Entrega</th>
        <th>Estado</th>
        <th class="text-center">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% delivery.delivery_items.each do |item| %>
        <tr id="delivery_item_row_<%= item.id %>">
          <td class="ps-4">
            <div class="fw-bold"><%= item.order_item.product %></div>
            <small class="text-muted"><%= item.order_item.notes.presence || "Sin notas" %></small>
          </td>
          <td class="text-center"><%= item.order_item.quantity %></td>
          <td class="text-center">
            <span class="badge bg-primary rounded-pill px-3"><%= item.quantity_delivered %></span>
          </td>
          <td>
            <span class="badge bg-<%= delivery_item_status_color(item.status) %>">
              <%= item.status.humanize %>
            </span>
          </td>
          <td class="text-center">
            <div class="btn-group btn-group-sm">
              <% unless %w[delivered cancelled rescheduled].include?(item.status.to_s) %>
                <%= button_to mark_item_delivered_production_delivery_path(delivery, item_id: item.id),
                    method: :patch,
                    class: "btn btn-sm btn-outline-success",
                    title: "Marcar como entregado",
                    data: { turbo_confirm: "¿Marcar este producto como entregado?" } do %>
                  <i class="bi bi-check-lg"></i>
                <% end %>
              <% end %>
              <% unless %w[delivered cancelled rescheduled].include?(item.status.to_s) %>
                <button class="btn btn-sm btn-outline-warning"
                        title="Reagendar este producto"
                        data-bs-toggle="modal"
                        data-bs-target="#rescheduleItemModal<%= item.id %>">
                  <i class="bi bi-calendar-plus"></i>
                </button>
              <% end %>
              <% unless %w[delivered cancelled].include?(item.status.to_s) %>
                <%= button_to cancel_item_production_delivery_path(delivery, item_id: item.id),
                    method: :patch,
                    class: "btn btn-sm btn-outline-danger",
                    title: "Cancelar producto",
                    data: { turbo_confirm: "¿Cancelar este producto de la entrega?" } do %>
                  <i class="bi bi-x-lg"></i>
                <% end %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<%# Modales de reagendamiento por item %>
<% delivery.delivery_items.each do |item| %>
  <div class="modal fade" id="rescheduleItemModal<%= item.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content border-0 shadow">
        <div class="modal-header bg-warning">
          <h6 class="modal-title fw-bold">Reagendar: <%= item.order_item.product.truncate(30) %></h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <%= form_with url: reschedule_item_production_delivery_path(delivery), method: :patch do |f| %>
          <%= hidden_field_tag :item_id, item.id %>
          <div class="modal-body">
            <label class="form-label fw-bold small">Nueva Fecha</label>
            <%= date_field_tag :new_date, Date.current + 1, class: "form-control", required: true, min: Date.current + 1 %>
          </div>
          <div class="modal-footer border-0">
            <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            <%= f.submit "Reagendar", class: "btn btn-sm btn-warning px-3" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
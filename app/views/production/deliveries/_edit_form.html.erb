<%= form_with model: [:production, delivery],
      id: "delivery_edit_form_#{delivery.id}",
      data: { turbo: true } do |f| %>
  <% if delivery.errors.any? %>
    <div class="alert alert-danger d-flex align-items-start mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2 fs-5 mt-1"></i>
      <div>
        <strong>Por favor corrige los siguientes errores:</strong>
        <ul class="mb-0 mt-1">
          <% delivery.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
  <%# ── BLOQUE 1: DATOS GENERALES ── %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-light border-bottom d-flex align-items-center gap-2 py-3">
      <i class="bi bi-calendar-event text-primary fs-5"></i>
      <h6 class="mb-0 fw-bold text-primary">Datos Generales</h6>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <%= f.label :delivery_date, class: "form-label fw-semibold" do %>
            <i class="bi bi-calendar3 me-1 text-primary"></i> Fecha de Entrega
          <% end %>
          <%= f.date_field :delivery_date,
                class: "form-control #{"is-invalid" if delivery.errors[:delivery_date].any?}",
                required: true %>
          <% if delivery.errors[:delivery_date].any? %>
            <div class="invalid-feedback"><%= delivery.errors[:delivery_date].first %></div>
          <% end %>
        </div>
        <div class="col-md-4">
          <%= f.label :delivery_time_preference, class: "form-label fw-semibold" do %>
            <i class="bi bi-clock me-1 text-primary"></i> Preferencia de Hora
          <% end %>
          <%= f.text_field :delivery_time_preference,
                class: "form-control",
                placeholder: "Ej: Mañana, Tarde, 8am-12pm" %>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">
            <i class="bi bi-building me-1 text-primary"></i> Cliente
          </label>
          <input type="text"
                 class="form-control bg-light"
                 value="<%= client.name %>"
          readonly>
          <div class="form-text">
            <i class="bi bi-lock me-1"></i> No editable desde producción
          </div>
        </div>
      </div>
    </div>
  </div>
  <%# ── BLOQUE 2: CONTACTO ── %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-light border-bottom d-flex align-items-center gap-2 py-3">
      <i class="bi bi-person-lines-fill text-success fs-5"></i>
      <h6 class="mb-0 fw-bold text-success">Información de Contacto</h6>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.label :contact_name, class: "form-label fw-semibold" do %>
            <i class="bi bi-person me-1 text-success"></i> Nombre de Contacto
          <% end %>
          <%= f.text_field :contact_name,
                class: "form-control #{"is-invalid" if delivery.errors[:contact_name].any?}",
                placeholder: "Nombre de quien recibe" %>
          <% if delivery.errors[:contact_name].any? %>
            <div class="invalid-feedback"><%= delivery.errors[:contact_name].first %></div>
          <% end %>
        </div>
        <div class="col-md-6">
          <%= f.label :contact_phone, class: "form-label fw-semibold" do %>
            <i class="bi bi-telephone me-1 text-success"></i> Teléfono de Contacto
          <% end %>
          <%= f.telephone_field :contact_phone,
                class: "form-control",
                placeholder: "Ej: 8888-8888" %>
        </div>
        <div class="col-12">
          <%= f.label :delivery_notes, class: "form-label fw-semibold" do %>
            <i class="bi bi-sticky me-1 text-success"></i> Notas de Entrega
          <% end %>
          <%= f.text_area :delivery_notes,
                rows: 3,
                class: "form-control",
                placeholder: "Instrucciones especiales para el chofer..." %>
        </div>
      </div>
    </div>
  </div>
  <%# ── BLOQUE 3: DIRECCIÓN ── %>
  <%= render "deliveries/upsert_partials/address_fields",
        f: f,
        delivery: delivery,
        addresses: addresses %>
  <%# ── FOOTER ── %>
  <div class="d-flex justify-content-end gap-2 pt-2 border-top mt-4">
    <button type="button"
            class="btn btn-outline-secondary"
            data-bs-dismiss="modal">
      <i class="bi bi-x-circle me-1"></i> Cancelar
    </button>
    <%= f.submit "Guardar Cambios",
          class: "btn btn-primary px-4",
          data: { disable_with: "Guardando..." } %>
  </div>
<% end %>
<%# app/views/production/deliveries/_management_card.html.erb %>
<tr id="delivery_card_<%= delivery.id %>">
  <td>
    <span class="fw-bold d-block"><%= l(delivery.delivery_date, format: :short) %></span>
    <small class="text-muted"><%= delivery.delivery_time_preference.presence || "Sin horario" %></small>
  </td>
  <td>
    <span class="fw-bold"><%= delivery.order.number %></span>
  </td>
  <td>
    <span><%= delivery.order.client.name %></span>
    <% if delivery.condominio_number.present? || delivery.casa_number.present? %>
      <div class="mt-1">
        <% if delivery.condominio_number.present? %>
          <small class="text-muted"><i class="bi bi-buildings me-1"></i><%= delivery.condominio_number %></small>
        <% end %>
        <% if delivery.casa_number.present? %>
          <small class="text-muted ms-2"><i class="bi bi-house-door me-1"></i>Casa <%= delivery.casa_number %></small>
        <% end %>
      </div>
    <% end %>
  </td>
  <td>
    <span class="d-block"><%= delivery.order.seller.name %></span>
    <small class="text-muted"><%= delivery.order.seller.seller_code %></small>
  </td>
  <td>
    <% if delivery.delivery_items.any? %>
      <% delivery.delivery_items.each do |item| %>
        <div class="d-flex align-items-center mb-1">
          <span class="badge bg-secondary me-2 flex-shrink-0"><%= item.quantity_delivered %></span>
          <span class="small"><%= item.order_item.product %></span>
        </div>
      <% end %>
    <% else %>
      <span class="text-muted small">Sin productos</span>
    <% end %>
  </td>
  <td>
    <% if delivery.approved? %>
      <span class="badge bg-success mb-1 d-block">
        <i class="bi bi-shield-check me-1"></i>Aprobada
      </span>
    <% else %>
      <span class="badge bg-warning text-dark mb-1 d-block">
        <i class="bi bi-clock me-1"></i>Pendiente aprobación
      </span>
    <% end %>
    <span class="badge bg-<%= delivery_status_color(delivery.status) %> d-block">
      <%= delivery.display_status %>
    </span>
    <% error_detector = Deliveries::ErrorDetector.new(delivery) %>
    <% if error_detector.has_errors? %>
      <span class="badge bg-danger mt-1 d-block">
        <i class="bi bi-exclamation-octagon me-1"></i><%= pluralize(error_detector.errors.count, "error", "errores") %>
      </span>
    <% end %>
  </td>
  <td class="text-center">
    <div class="d-flex gap-1 justify-content-center flex-wrap">
      <% unless delivery.approved? %>
        <%= button_to approve_production_delivery_path(delivery),
            method: :patch,
            class: "btn btn-sm btn-success",
            title: "Aprobar para ruta",
            data: { turbo_confirm: "¿Confirmar que esta entrega está lista para planificación?" } do %>
          <i class="bi bi-check-lg"></i>
        <% end %>
      <% end %>
      <%= link_to production_delivery_path(delivery),
          class: "btn btn-sm btn-outline-primary",
          title: "Ver detalle" do %>
        <i class="bi bi-eye"></i>
      <% end %>
    </div>
  </td>
</tr>

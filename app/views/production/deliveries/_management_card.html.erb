<%# app/views/production/deliveries/_management_card.html.erb %>

<div class="list-group-item p-3 hover-bg-light border-start border-4 <%= delivery.approved? ? 'border-success' : 'border-warning' %>" id="delivery_card_<%= delivery.id %>">
  <div class="row align-items-center">
    
    <%# Col 1: Info Principal %>
    <div class="col-md-3">
      <div class="d-flex align-items-center">
        <div class="flex-shrink-0 me-3">
          <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
            <i class="bi bi-truck text-primary fs-4"></i>
          </div>
        </div>
        <div>
          <h6 class="mb-0 fw-bold">#<%= delivery.id %> - <%= delivery.order.client.name %></h6>
          <small class="text-muted"><i class="bi bi-person-badge me-1"></i><%= delivery.order.seller.name %></small>
        </div>
      </div>
    </div>

    <%# Col 2: Fecha y Horario %>
    <div class="col-md-2">
      <div class="d-flex flex-column">
        <span class="fw-bold text-dark">
          <i class="bi bi-calendar-event me-1 text-primary"></i>
          <%= l(delivery.delivery_date, format: :short) %>
        </span>
        <small class="text-muted">
          <i class="bi bi-clock me-1"></i>
          <%= delivery.delivery_time_preference.presence || "Sin horario" %>
        </small>
      </div>
    </div>

    <%# Col 3: Dirección y Contacto %>
    <div class="col-md-3">
      <div class="small text-truncate" title="<​%= delivery.delivery_address.address %>">
        <i class="bi bi-geo-alt text-danger me-1"></i><%= delivery.delivery_address.address %>
      </div>
      <div class="small text-muted">
        <i class="bi bi-telephone me-1"></i><%= delivery.contact_phone %> (<%= delivery.contact_name %>)
      </div>
    </div>

    <%# Col 4: Items y Errores %>
    <div class="col-md-2">
      <% error_detector = Deliveries::ErrorDetector.new(delivery) %>
      <% if error_detector.has_errors? %>
        <span class="badge bg-danger-soft text-danger w-100 mb-1" data-bs-toggle="tooltip" title="<​%= error_detector.errors.first[:message] %>">
          <i class="bi bi-exclamation-octagon me-1"></i> <%= pluralize(error_detector.errors.count, 'error', 'errores') %>
        </span>
      <% end %>
      <span class="badge bg-light text-dark border w-100">
        <i class="bi bi-box-seam me-1"></i> <%= delivery.delivery_items.count %> productos
      </span>
    </div>

    <%# Col 5: Acciones Rápidas %>
    <div class="col-md-2 text-end">
      <div class="btn-group shadow-sm">
        <% unless delivery.approved? %>
          <%= button_to approve_production_delivery_path(delivery), 
              method: :patch, 
              class: "btn btn-sm btn-success", 
              title: "Aprobar para Ruta",
              data: { turbo_confirm: "¿Confirmar que esta entrega está lista para ser planificada?" } do %>
            <i class="bi bi-check-lg"></i>
          <% end %>
        <% end %>
        
        <button class="btn btn-sm btn-white border" 
                data-bs-toggle="modal" 
                data-bs-target="#quickEditModal<%= delivery.id %>"
                title="Editar datos rápidos">
          <i class="bi bi-pencil-square"></i>
        </button>

        <%= link_to production_delivery_path(delivery), 
            class: "btn btn-sm btn-white border",
            title: "Ver detalle completo" do %>
          <i class="bi bi-eye"></i>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# Renderizamos el modal aquí mismo para que esté disponible %>
<%= render 'production/deliveries/quick_edit_modal', delivery: delivery %>

<style>
  .bg-danger-soft { background-color: rgba(220, 53, 69, 0.1); }
  .btn-white { background-color: #fff; }
</style>
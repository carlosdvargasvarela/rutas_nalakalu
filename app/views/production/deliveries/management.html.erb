<%# app/views/production/deliveries/management.html.erb %>
<div class="container-fluid px-4 py-4">
  <div class="mb-3">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1">
        <li class="breadcrumb-item"><%= link_to "Dashboard", root_path %></li>
        <li class="breadcrumb-item active">Producción</li>
      </ol>
    </nav>
    <h2 class="fw-bold mb-0">
      <i class="bi bi-gear-wide-connected text-primary me-2"></i>Gestión de Operaciones
    </h2>
  </div>

  <%# ── FILTROS ── %>
  <div class="card shadow-sm border-0 mb-3">
    <div class="card-body py-3">
      <form action="<%= management_production_deliveries_path %>" method="get" class="row gy-2 gx-2 align-items-end">
        <div class="col-md-2">
          <label class="form-label small mb-1 fw-semibold">Desde</label>
          <input type="date" name="date_from" value="<%= @date_from %>" class="form-control form-control-sm">
        </div>
        <div class="col-md-2">
          <label class="form-label small mb-1 fw-semibold">Hasta</label>
          <input type="date" name="date_to" value="<%= @date_to %>" class="form-control form-control-sm">
        </div>
        <div class="col-md-2">
          <label class="form-label small mb-1 fw-semibold"># Pedido</label>
          <div class="input-group input-group-sm">
            <span class="input-group-text"><i class="bi bi-hash"></i></span>
            <input type="text" name="order_number" value="<%= @order_number %>" class="form-control" placeholder="ej. NK-001">
          </div>
        </div>
        <div class="col-md-2">
          <label class="form-label small mb-1 fw-semibold">Vendedor</label>
          <div class="input-group input-group-sm">
            <span class="input-group-text"><i class="bi bi-person-badge"></i></span>
            <input type="text" name="seller" value="<%= @seller_query %>" class="form-control" placeholder="nombre o código">
          </div>
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary btn-sm w-100 mt-3">
            <i class="bi bi-search me-1"></i> Buscar
          </button>
        </div>
        <div class="col-md-2">
          <%= link_to management_production_deliveries_path, class: "btn btn-outline-secondary btn-sm w-100 mt-3" do %>
            <i class="bi bi-x-circle me-1"></i> Limpiar
          <% end %>
        </div>
      </form>
    </div>
  </div>

  <%# ── TABLA ── %>
  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <% if @deliveries.any? %>
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Fecha</th>
                <th># Pedido</th>
                <th>Cliente</th>
                <th>Vendedor</th>
                <th style="width: 35%;">Muebles</th>
                <th>Estado</th>
                <th class="text-center">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% @deliveries.each do |delivery| %>
                <%= render "production/deliveries/management_card", delivery: delivery %>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-inbox text-muted display-1"></i>
          <p class="mt-3 text-muted">No hay entregas para mostrar.</p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="d-flex justify-content-center mt-3">
    <%= paginate @deliveries %>
  </div>
</div>

<%# app/views/driver/delivery_plans/index.html.erb %>
<div class="dk-page">

  <%# ── Encabezado ──────────────────────────────────────── %>
  <div style="margin-bottom:16px;">
    <div class="dk-label">Panel del conductor</div>
    <h1 style="font-size:1.5rem;font-weight:800;margin:0 0 2px;color:var(--dk-text);">
      Mis Rutas
    </h1>
    <p style="font-size:.82rem;color:var(--dk-muted);margin:0;">
      <%= Date.current.strftime("%A %d de %B, %Y").capitalize %>
    </p>
  </div>

  <%# ── Stats ──────────────────────────────────────────── %>
  <% if @stats && @stats[:total_plans] > 0 %>
    <div class="dk-card" style="margin-bottom:14px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid var(--dk-border);">
        <div class="dk-mini-stat" style="border-right:1px solid var(--dk-border);">
          <div class="dk-mini-stat-val" style="color:var(--dk-primary);">
            <%= @stats[:total_plans] %>
          </div>
          <div class="dk-mini-stat-lbl">Planes</div>
        </div>
        <div class="dk-mini-stat">
          <div class="dk-mini-stat-val" style="color:var(--dk-success);">
            <%= @stats[:total_deliveries] %>
          </div>
          <div class="dk-mini-stat-lbl">Entregas</div>
        </div>
      </div>
      <% active = @stats[:by_status]["in_progress"].to_i %>
      <% if active > 0 %>
        <div style="padding:10px 16px;background:var(--dk-primary-lt);display:flex;align-items:center;gap:8px;">
          <i class="bi bi-broadcast" style="color:var(--dk-primary);font-size:1rem;"></i>
          <span style="font-size:.82rem;font-weight:700;color:var(--dk-primary);">
            <%= active %> ruta<%= active > 1 ? "s" : "" %> en progreso ahora
          </span>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ── Filtros (colapsable) ─────────────────────────────── %>
  <button type="button"
          class="dk-btn dk-btn-ghost dk-btn-sm"
          style="width:auto;padding:0 16px;margin-bottom:10px;"
          data-bs-toggle="collapse"
          data-bs-target="#dk-filters">
    <i class="bi bi-funnel"></i> Filtros
    <% if params[:q].present? %>
      <span style="background:var(--dk-primary);color:#fff;border-radius:10px;padding:1px 7px;font-size:.68rem;">ON</span>
    <% end %>
  </button>

  <div class="collapse <%= 'show' if params[:q].present? %>" id="dk-filters">
    <div class="dk-filter">
      <%= search_form_for @q, url: driver_delivery_plans_path, method: :get do |f| %>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
          <div>
            <div class="dk-label">Desde</div>
            <%= f.date_field :first_delivery_date_gteq, class: "form-control form-control-sm" %>
          </div>
          <div>
            <div class="dk-label">Hasta</div>
            <%= f.date_field :first_delivery_date_lteq, class: "form-control form-control-sm" %>
          </div>
        </div>
        <div style="margin-bottom:10px;">
          <div class="dk-label">Estado</div>
          <%= f.select :status_eq,
                options_for_select(
                  DeliveryPlan.statuses.keys.map { |s| [s.humanize, s] },
                  params.dig(:q, :status_eq)
                ),
                { include_blank: "Todos los estados" },
                { class: "form-select form-select-sm" } %>
        </div>
        <div style="display:flex;gap:8px;">
          <%= f.submit "Buscar", class: "btn btn-primary btn-sm flex-fill" %>
          <% if params[:q].present? %>
            <%= link_to driver_delivery_plans_path, class: "btn btn-outline-secondary btn-sm" do %>
              <i class="bi bi-x"></i> Limpiar
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Lista de planes ────────────────────────────────── %>
  <% if @delivery_plans.any? %>
    <% @delivery_plans.each do |plan| %>
      <%
        total      = plan.deliveries_count.to_i
        done       = plan.delivered_count.to_i
        pct        = total > 0 ? (done.to_f / total * 100).round : 0
        first_date = plan.try(:first_delivery_date)
        is_active  = plan.status == "in_progress"
      %>

      <div class="dk-card dk-plan-card" data-status="<%= plan.status %>">
        <div class="dk-card-body">

          <%# Fila top: semana + pill estado %>
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
            <div>
              <div style="font-size:1rem;font-weight:800;color:var(--dk-text);margin-bottom:2px;">
                Semana <%= plan.week %> / <%= plan.year %>
              </div>
              <div style="font-size:.78rem;color:var(--dk-muted);display:flex;align-items:center;gap:8px;">
                <% if first_date.present? %>
                  <span><i class="bi bi-calendar3 me-1"></i><%= l(first_date.to_date, format: :short) %></span>
                <% end %>
                <% if plan.truck.present? %>
                  <span><i class="bi bi-truck-front me-1"></i><%= plan.truck.tr("_"," ") %></span>
                <% end %>
              </div>
            </div>
            <% pill = case plan.status
                      when "in_progress"    then "dk-pill-primary"
                      when "routes_created" then "dk-pill-purple"
                      when "completed"      then "dk-pill-success"
                      when "aborted"        then "dk-pill-danger"
                      else "dk-pill-muted"
                      end %>
            <span class="dk-pill <%= pill %>">
              <% if plan.status == "in_progress" %>
                <span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;"></span>
              <% end %>
              <%= plan.display_status %>
            </span>
          </div>

          <%# Conductor %>
          <% if plan.driver.present? %>
            <div style="font-size:.82rem;color:var(--dk-muted);margin-bottom:12px;display:flex;align-items:center;gap:6px;">
              <i class="bi bi-person-circle"></i>
              <%= plan.driver.name %>
            </div>
          <% end %>

          <%# Progreso %>
          <div style="margin-bottom:14px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;">
              <span style="font-size:.75rem;font-weight:700;color:var(--dk-muted);">Progreso de entregas</span>
              <span style="font-size:.8rem;font-weight:800;color:<%= pct == 100 ? "var(--dk-success)" : "var(--dk-text)" %>;">
                <%= done %> / <%= total %>
              </span>
            </div>
            <div class="dk-progress">
              <div class="dk-progress-fill" style="width:<%= pct %>%;"></div>
            </div>
          </div>

          <%# Botón acción %>
          <%= link_to driver_delivery_plan_path(plan),
                class: "dk-btn #{is_active ? 'dk-btn-blue' : 'dk-btn-blue-outline'}" do %>
            <i class="bi bi-<%= is_active ? 'broadcast' : 'geo-alt-fill' %>" style="font-size:1.1rem;"></i>
            <%= is_active ? "RUTA ACTIVA" : "VER RUTA" %>
          <% end %>

        </div>
      </div>
    <% end %>

    <% if @delivery_plans.respond_to?(:current_page) && @delivery_plans.total_pages > 1 %>
      <div style="margin-top:16px;text-align:center;">
        <%= paginate @delivery_plans %>
      </div>
    <% end %>

  <% else %>
    <div class="dk-empty">
      <div class="dk-empty-icon"><i class="bi bi-calendar-x"></i></div>
      <div style="font-size:1.05rem;font-weight:700;color:var(--dk-text);margin-bottom:6px;">
        No hay rutas disponibles
      </div>
      <div style="font-size:.875rem;color:var(--dk-muted);">
        Ajusta los filtros o espera a que se asigne una ruta.
      </div>
    </div>
  <% end %>

</div>

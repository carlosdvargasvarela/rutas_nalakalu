<%# app/views/driver/delivery_plans/_crew.html.erb %>
<% driver = delivery_plan.driver %>
<% return unless driver.present? && driver.crew_members.any? %>

<div class="dk-card" style="margin-bottom:14px;">
  <div class="dk-card-body">
    <div class="dk-label" style="margin-bottom:10px;">
      <i class="bi bi-people-fill me-1"></i>Tripulación
    </div>
    <% driver.crew_members.each do |cm| %>
      <div class="dk-info-row">
        <i class="bi bi-person-fill"></i>
        <span style="flex:1;font-weight:600;"><%= cm.name %></span>
        <span style="font-size:.75rem;color:var(--dk-muted);">
          <i class="bi bi-card-text me-1"></i><%= cm.id_number %>
        </span>
      </div>
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0 overflow-hidden">
  <div class="card-body p-0">
    <!-- Mapa con Stimulus -->
    <div id="public-map" 
         data-controller="public-tracking-map"
         data-public-tracking-map-plan-id-value="<​%= @plan.id %>"
      data-public-tracking-map-dest-lat-value="<​%= @address.latitude.to_f %>"
        data-public-tracking-map-dest-lng-value="<​%= @address.longitude.to_f %>"
          data-public-tracking-map-truck-lat-value="<​%= @plan.current_lat.to_f %>"
            data-public-tracking-map-truck-lng-value="<​%= @plan.current_lng.to_f %>">
            </div>
          </div>
          <div class="card-body bg-white">
            <div class="d-flex align-items-center mb-3">
              <div class="flex-shrink-0 bg-primary text-white rounded-circle p-3 me-3">
                🚚
              </div>
              <div>
                <h5 class="mb-0">Estado: <%= @plan.status_i18n %></h5>
                <small class="text-muted" data-public-tracking-map-target="lastUpdate">
                  Actualizando en tiempo real...
                </small>
              </div>
            </div>
            <hr>
            <div class="row">
              <div class="col-6">
                <small class="text-muted d-block">Pedido</small>
                <strong>#<%= @delivery.order.number %></strong>
              </div>
              <div class="col-6">
                <small class="text-muted d-block">Destino</small>
                <strong><%= @address.address.truncate(30) %></strong>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-4 text-center">
          <p class="small text-muted">Gracias por confiar en NaLakalu</p>
        </div>
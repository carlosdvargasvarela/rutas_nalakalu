<div class="container py-4">
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <!-- Encabezado -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
          <h4 class="fw-bold mb-1">Seguimiento de tu entrega</h4>
          <p class="text-muted mb-0">Pedido #<%= @delivery.order.number %></p>
        </div>
      </div>
      <!-- Mapa en tiempo real -->
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body p-0">
          <div 
            data-controller="public-tracking-map"
            data-public-tracking-map-plan-id-value="<%= @plan.id %>"
            data-public-tracking-map-dest-lat-value="<%= @delivery.delivery_address.latitude %>"
              data-public-tracking-map-dest-lng-value="<%= @delivery.delivery_address.longitude %>"
                data-public-tracking-map-truck-lat-value="<%= @plan.current_lat || @delivery.delivery_address.latitude %>"
                  data-public-tracking-map-truck-lng-value="<%= @plan.current_lng || @delivery.delivery_address.longitude %>"
                    style="height: 400px; border-radius: 0.375rem;">
                  </div>
                  <div class="p-3 bg-light border-top">
                    <small class="text-muted" data-public-tracking-map-target="lastUpdate">
                      <%= @plan.last_seen_at ? "Última actualización: #{time_ago_in_words(@plan.last_seen_at)} atrás" : "Esperando ubicación..." %>
                    </small>
                  </div>
                </div>
              </div>
              <!-- Información de la entrega -->
              <div class="card shadow-sm border-0">
                <div class="card-body">
                  <h5 class="fw-bold mb-3">Detalles de la entrega</h5>
                  <div class="row">
                    <div class="col-md-6 mb-3">
                      <small class="text-muted d-block">Fecha estimada</small>
                      <strong><%= l(@delivery.delivery_date, format: :long) %></strong>
                    </div>
                    <div class="col-md-6 mb-3">
                      <small class="text-muted d-block">Estado</small>
                      <span class="badge bg-primary">En camino</span>
                    </div>
                  </div>
                  <hr>
                  <div class="mb-2">
                    <small class="text-muted d-block">Dirección de entrega</small>
                    <strong><%= @delivery.delivery_address.address %></strong>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
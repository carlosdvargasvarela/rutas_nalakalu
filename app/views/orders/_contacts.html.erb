<%# app/views/orders/_contacts.html.erb %>
<div id="order_contacts_<%= order.id %>">
  <% contacts = order.order_contacts.primary_first %>

  <% if contacts.any? %>
    <ul class="list-group list-group-flush mb-3">
      <% contacts.each do |contact| %>
        <li class="list-group-item px-0 py-2 d-flex justify-content-between align-items-center">
          <div>
            <i class="bi bi-person-lines-fill me-2 text-secondary"></i>
            <strong><%= contact.name %></strong>
            <% if contact.phone.present? %>
              <span class="text-muted ms-2">
                <i class="bi bi-telephone me-1"></i>
                <a href="tel:<%= contact.phone %>" class="text-decoration-none text-muted"><%= contact.phone %></a>
              </span>
            <% end %>
            <% if contact.is_primary? %>
              <span class="badge bg-primary ms-2">Principal</span>
            <% end %>
          </div>
          <% if policy(contact).update? || policy(contact).destroy? %>
            <div class="d-flex gap-1 ms-2">
              <% unless contact.is_primary? %>
                <%= button_to order_order_contact_path(order, contact),
                      method: :patch,
                      params: { order_contact: { is_primary: true } },
                      class: "btn btn-outline-primary btn-sm",
                      title: "Marcar como principal",
                      data: { turbo_confirm: "¿Marcar a #{contact.name} como contacto principal?" } do %>
                  <i class="bi bi-star"></i>
                <% end %>
              <% end %>
              <button type="button"
                      class="btn btn-outline-secondary btn-sm"
                      data-bs-toggle="collapse"
                      data-bs-target="#edit_contact_<%= contact.id %>"
                      title="Editar">
                <i class="bi bi-pencil"></i>
              </button>
              <%= button_to order_order_contact_path(order, contact),
                    method: :delete,
                    class: "btn btn-outline-danger btn-sm",
                    title: "Eliminar",
                    data: { turbo_confirm: "¿Eliminar el contacto #{contact.name}?" } do %>
                <i class="bi bi-trash"></i>
              <% end %>
            </div>
          <% end %>
        </li>
        <%# Formulario de edición colapsable %>
        <% if policy(contact).update? %>
          <li class="list-group-item px-0 py-0 border-0">
            <div class="collapse" id="edit_contact_<%= contact.id %>">
              <div class="bg-light rounded p-3 mb-2">
                <%= form_with url: order_order_contact_path(order, contact),
                              method: :patch,
                              data: { turbo_stream: true } do |f| %>
                  <div class="row g-2 align-items-end">
                    <div class="col-md-5">
                      <%= label_tag "edit_contact_name_#{contact.id}", "Nombre", class: "form-label small fw-semibold mb-1" %>
                      <%= text_field_tag "order_contact[name]", contact.name,
                            id: "edit_contact_name_#{contact.id}",
                            class: "form-control form-control-sm",
                            required: true %>
                    </div>
                    <div class="col-md-4">
                      <%= label_tag "edit_contact_phone_#{contact.id}", "Teléfono", class: "form-label small fw-semibold mb-1" %>
                      <%= text_field_tag "order_contact[phone]", contact.phone,
                            id: "edit_contact_phone_#{contact.id}",
                            class: "form-control form-control-sm",
                            placeholder: "8888-8888" %>
                    </div>
                    <div class="col-auto">
                      <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-check-lg me-1"></i>Guardar
                      </button>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      <% end %>
    </ul>
  <% else %>
    <p class="text-muted fst-italic small mb-3">
      <i class="bi bi-person-x me-1"></i> No hay contactos registrados para este pedido.
    </p>
  <% end %>

  <% if policy(OrderContact.new(order: order)).create? %>
    <div>
      <button type="button"
              class="btn btn-outline-success btn-sm"
              data-bs-toggle="collapse"
              data-bs-target="#new_contact_form_<%= order.id %>">
        <i class="bi bi-person-plus me-1"></i>
        Agregar contacto
      </button>
      <div class="collapse mt-2" id="new_contact_form_<%= order.id %>">
        <div class="bg-light rounded p-3">
          <%= form_with url: order_order_contacts_path(order),
                        method: :post,
                        data: { turbo_stream: true } do |f| %>
            <% if local_assigns[:errors]&.any? %>
              <div class="alert alert-danger py-2 small mb-2">
                <%= errors.full_messages.to_sentence %>
              </div>
            <% end %>
            <div class="row g-2 align-items-end">
              <div class="col-md-5">
                <%= label_tag :order_contact_name, "Nombre *", class: "form-label small fw-semibold mb-1" %>
                <%= text_field_tag "order_contact[name]", nil,
                      id: :order_contact_name,
                      class: "form-control form-control-sm",
                      placeholder: "Ej: María González",
                      required: true %>
              </div>
              <div class="col-md-4">
                <%= label_tag :order_contact_phone, "Teléfono", class: "form-label small fw-semibold mb-1" %>
                <%= text_field_tag "order_contact[phone]", nil,
                      id: :order_contact_phone,
                      class: "form-control form-control-sm",
                      placeholder: "8888-8888" %>
              </div>
              <div class="col-md-3">
                <div class="form-check mb-1">
                  <%= check_box_tag "order_contact[is_primary]", "1", contacts.empty?,
                        id: :order_contact_is_primary,
                        class: "form-check-input" %>
                  <%= label_tag :order_contact_is_primary, "Principal", class: "form-check-label small" %>
                </div>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-success btn-sm">
                  <i class="bi bi-person-plus me-1"></i>Agregar
                </button>
                <button type="button"
                        class="btn btn-outline-secondary btn-sm ms-1"
                        data-bs-toggle="collapse"
                        data-bs-target="#new_contact_form_<%= order.id %>">
                  Cancelar
                </button>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

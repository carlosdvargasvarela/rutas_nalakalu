<h1 class="mb-4">
  <i class="bi bi-receipt me-2"></i>
  Pedido <span class="text-primary">#<%= @order.number %></span>
</h1>
<%= render "orders/header", order: @order %>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h6 class="card-title text-secondary mb-3">
      <i class="bi bi-people me-1"></i>Contactos del pedido
    </h6>
    <%= render "orders/contacts", order: @order %>
  </div>
</div>

<h2 class="mt-4 mb-3">
  <i class="bi bi-box-seam me-2"></i>
  Productos del pedido
</h2>
<%= render "orders/items_table", order: @order %>
<%= render "orders/actions", order: @order %>
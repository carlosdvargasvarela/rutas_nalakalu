<%# app/views/audit_logs/resource_history.html.erb %>
<% content_for :title, "Historial de #{@item_type} ##{@item_id}" %>
<div class="container-fluid py-4 px-4">
  <%# ── BREADCRUMB ── %>
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb small">
      <li class="breadcrumb-item">
        <%= link_to audit_logs_path, class: 'text-decoration-none text-muted' do %>
          <i class="bi bi-clock-history me-1"></i> Historial de cambios
        <% end %>
      </li>
      <li class="breadcrumb-item active text-dark fw-semibold">
        <%= @item_type %> #<%= @item_id %>
      </li>
    </ol>
  </nav>
  <div class="row g-4">
    <%# ── COLUMNA PRINCIPAL ── %>
    <div class="col-12 col-lg-8">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <h5 class="fw-bold mb-0">Línea de tiempo</h5>
          <small class="text-muted">
            <%= @timeline_groups.size %> evento<%= @timeline_groups.size == 1 ? "" : "s" %>
          </small>
        </div>
        <div class="d-flex gap-2">
          <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
            <i class="bi bi-activity me-1"></i>Negocio
          </span>
          <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25">
            <i class="bi bi-code-square me-1"></i>Sistema
          </span>
        </div>
      </div>
      <%= render "shared/timeline",
          timeline_groups: @timeline_groups,
          users_by_id: @users_by_id %>
    </div>
    <%# ── COLUMNA LATERAL ── %>
    <div class="col-12 col-lg-4">
      <%# Info del recurso %>
      <div class="card border-0 shadow-sm rounded-3 sticky-top" style="top: 20px;">
        <div class="card-header bg-primary text-white px-4 py-3 rounded-top-3">
          <div class="d-flex align-items-center gap-2">
            <i class="bi bi-info-circle"></i>
            <span class="fw-semibold">Información del recurso</span>
          </div>
        </div>
        <div class="card-body px-4 py-3">
          <% if @resource.present? %>
            <dl class="row small mb-0">
              <dt class="col-5 text-muted fw-normal">Tipo</dt>
              <dd class="col-7">
                <span class="badge bg-secondary bg-opacity-10 text-secondary"><%= @item_type %></span>
              </dd>
              <dt class="col-5 text-muted fw-normal">ID</dt>
              <dd class="col-7"><code>#<%= @item_id %></code></dd>
              <% if @resource.is_a?(Delivery) %>
                <dt class="col-5 text-muted fw-normal">Estado</dt>
                <dd class="col-7">
                  <span class="badge bg-primary bg-opacity-10 text-primary">
                    <%= @resource.display_status %>
                  </span>
                </dd>
                <dt class="col-5 text-muted fw-normal">Fecha entrega</dt>
                <dd class="col-7"><%= @resource.delivery_date.strftime("%d/%m/%Y") %></dd>
                <dt class="col-5 text-muted fw-normal">Cliente</dt>
                <dd class="col-7"><%= @resource.client_name %></dd>
                <dt class="col-5 text-muted fw-normal">Pedido</dt>
                <dd class="col-7"><code><%= @resource.order_number %></code></dd>
              <% else %>
                <dt class="col-5 text-muted fw-normal">Estado</dt>
                <dd class="col-7">
                  <span class="badge bg-success bg-opacity-10 text-success">
                    <i class="bi bi-check-circle me-1"></i>Activo
                  </span>
                </dd>
              <% end %>
              <% if @resource.respond_to?(:created_at) %>
                <dt class="col-5 text-muted fw-normal">Creado</dt>
                <dd class="col-7"><%= format_datetime_cr(@resource.created_at) %></dd>
              <% end %>
              <% if @resource.respond_to?(:updated_at) %>
                <dt class="col-5 text-muted fw-normal">Actualizado</dt>
                <dd class="col-7"><%= format_datetime_cr(@resource.updated_at) %></dd>
              <% end %>
            </dl>
            <hr class="my-3">
            <div class="d-grid gap-2">
              <% path = polymorphic_path(@resource) rescue nil %>
              <% if path %>
                <%= link_to path, class: 'btn btn-sm btn-outline-primary' do %>
                  <i class="bi bi-eye me-1"></i> Ver registro
                <% end %>
              <% else %>
                <button class="btn btn-sm btn-outline-secondary" disabled>
                  <i class="bi bi-eye-slash me-1"></i> Sin vista directa
                </button>
              <% end %>
              <%= link_to audit_logs_path, class: 'btn btn-sm btn-outline-secondary' do %>
                <i class="bi bi-arrow-left me-1"></i> Volver al log
              <% end %>
            </div>
          <% else %>
            <div class="alert alert-warning small mb-3">
              <i class="bi bi-exclamation-triangle me-2"></i>
              <strong>Registro eliminado</strong>
              <p class="mb-0 mt-1">Este registro ya no existe, pero su historial se conserva.</p>
            </div>
            <div class="d-grid">
              <%= link_to audit_logs_path, class: 'btn btn-sm btn-outline-secondary' do %>
                <i class="bi bi-arrow-left me-1"></i> Volver al log
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
      <%# Estadísticas %>
      <div class="card border-0 shadow-sm rounded-3 mt-3">
        <div class="card-header bg-white border-bottom px-4 py-3 d-flex align-items-center gap-2">
          <i class="bi bi-bar-chart text-muted"></i>
          <span class="fw-semibold small">Estadísticas</span>
        </div>
        <div class="card-body px-4 py-3">
          <%# Eventos de negocio (DeliveryEvent) %>
          <% business_groups = @timeline_groups.select { |g| g[:primary].delivery_event? } %>
          <% if business_groups.any? %>
            <p class="text-muted small fw-semibold mb-2">Eventos de negocio</p>
            <% actions_count = business_groups.group_by { |g| g[:primary].record.action }
                                              .transform_values(&:size) %>
            <% total_ev = business_groups.size %>
            <% DeliveryEvent::ACTION_LABELS.each do |action, label| %>
              <% count = actions_count[action] || 0 %>
              <% next if count.zero? %>
              <div class="mb-2">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <span class="small text-<%= DeliveryEvent::ACTION_COLORS[action] || 'secondary' %>">
                    <i class="bi <%= DeliveryEvent::ACTION_ICONS[action] || 'bi-circle' %> me-1"></i>
                    <%= label %>
                  </span>
                  <strong class="small"><%= count %></strong>
                </div>
                <div class="progress rounded-pill" style="height:5px;">
                  <div class="progress-bar bg-<%= DeliveryEvent::ACTION_COLORS[action] || 'secondary' %> rounded-pill"
                       style="width:<%= total_ev.zero? ? 0 : (count * 100.0 / total_ev).round %>%">
                  </div>
                </div>
              </div>
            <% end %>
            <hr class="my-3">
          <% end %>
          <%# Cambios técnicos (PaperTrail) %>
          <p class="text-muted small fw-semibold mb-2">Cambios técnicos</p>
          <% total_pt = (@events_count || {}).values.sum %>
          <% [
            ["create",  "success", "bi-plus-circle",  "Creaciones"],
            ["update",  "primary", "bi-pencil",        "Actualizaciones"],
            ["destroy", "danger",  "bi-trash",         "Eliminaciones"]
          ].each do |event, color, icon, label| %>
            <% count = (@events_count || {})[event] || 0 %>
            <div class="mb-2">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small text-<%= color %>">
                  <i class="bi <%= icon %> me-1"></i> <%= label %>
                </span>
                <strong class="small"><%= count %></strong>
              </div>
              <div class="progress rounded-pill" style="height:5px;">
                <div class="progress-bar bg-<%= color %> rounded-pill"
                     style="width:<%= total_pt.zero? ? 0 : (count * 100.0 / total_pt).round %>%">
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      <%# Registros relacionados %>
      <% if @related_versions.present? %>
        <div class="card border-0 shadow-sm rounded-3 mt-3">
          <div class="card-header bg-white border-bottom px-4 py-3">
            <div class="d-flex align-items-center gap-2">
              <i class="bi bi-link-45deg text-muted"></i>
              <span class="fw-semibold small">Registros relacionados</span>
            </div>
            <small class="text-muted d-block mt-1">
              <%= related_context_description(@resource) %>
            </small>
          </div>
          <div class="card-body p-0" style="max-height:400px; overflow-y:auto;">
            <%= render partial: 'audit_logs/related_version_compact',
                       collection: @related_versions,
                       as: :version,
                       locals: { users_by_id: @users_by_id } %>
          </div>
          <div class="card-footer bg-white border-top text-center py-2">
            <small class="text-muted">
              Últimos <%= @related_versions.size %> cambios relacionados
            </small>
          </div>
        </div>
      <% end %>
    </div>
    <%# /sidebar %>
  </div>
</div>
<style>
  .nav-tabs .nav-link { color: #6c757d; border-radius: 8px 8px 0 0; }
  .nav-tabs .nav-link.active { color: #3b5bdb; font-weight: 600; }
</style>
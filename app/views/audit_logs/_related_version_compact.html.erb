<%# app/views/audit_logs/_related_version_compact.html.erb %>
<div class="related-version-item px-4 py-3 border-bottom">
  <div class="d-flex justify-content-between align-items-start mb-2">
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <%= event_badge(version.event) %>
      <span class="small">
        <i class="<%= resource_icon(version.item_type) %> text-muted me-1"></i>
        <strong><%= item_label(version) %></strong>
      </span>
    </div>
    <div class="text-end flex-shrink-0 ms-2">
      <div class="small text-muted"><%= version.created_at.strftime('%d/%m/%Y') %></div>
      <div class="text-muted" style="font-size:0.72rem;"><%= version.created_at.strftime('%H:%M') %></div>
    </div>
  </div>
  <div class="small text-muted mb-2">
    <i class="bi bi-person me-1"></i>
    <%= user_name_for(version, users_by_id) %>
  </div>
  <% if version.event == 'update' %>
    <% changes = summarize_changes(version, max_keys: 3) %>
    <% if changes.any? %>
      <div class="p-2 rounded-2 bg-light border-start border-2 border-secondary mb-2">
        <% changes.each do |attr, (before, after)| %>
          <div class="small mb-1">
            <span class="badge bg-secondary bg-opacity-10 text-secondary me-1"><%= attr %></span>
            <code class="text-danger" style="font-size:0.72rem;"><%= truncate(before.to_s, length: 18) %></code>
            <i class="bi bi-arrow-right mx-1 text-muted" style="font-size:0.7rem;"></i>
            <code class="text-success" style="font-size:0.72rem;"><%= truncate(after.to_s, length: 18) %></code>
          </div>
        <% end %>
        <% full_changes = summarize_changes(version, max_keys: 100) %>
        <% if full_changes.size > 3 %>
          <small class="text-muted fst-italic">+ <%= full_changes.size - 3 %> más</small>
        <% end %>
      </div>
    <% end %>
  <% elsif version.event == 'create' %>
    <div class="small text-success mb-2">
      <i class="bi bi-plus-circle me-1"></i> Registro creado
    </div>
  <% elsif version.event == 'destroy' %>
    <div class="small text-danger mb-2">
      <i class="bi bi-trash me-1"></i> Registro eliminado
    </div>
  <% end %>
  <%= link_to resource_history_audit_logs_path(item_type: version.item_type, item_id: version.item_id),
      class: 'btn btn-sm btn-outline-secondary' do %>
    <i class="bi bi-clock-history me-1"></i> Ver historial
  <% end %>
</div>
<style>
  .related-version-item:hover { background-color: #fafbfc; transition: background 0.15s ease; }
  .related-version-item:last-child { border-bottom: none !important; }
</style>
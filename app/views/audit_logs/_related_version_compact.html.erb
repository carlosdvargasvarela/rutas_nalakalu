<%# app/views/audit_logs/_related_version_compact.html.erb %>
<div class="related-version-item px-4 py-3 border-bottom">
  <div class="d-flex justify-content-between align-items-start mb-2">
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <%= event_badge(version.event) %>
      <span class="small">
        <i class="<%= resource_icon(version.item_type) %> text-muted me-1"></i>
        <strong><%= item_label(version) %></strong>
      </span>
    </div>
    <div class="text-end flex-shrink-0 ms-2">
      <div class="small text-muted"><%= version.created_at.strftime('%d/%m/%Y') %></div>
      <div class="text-muted" style="font-size:0.72rem;"><%= version.created_at.strftime('%H:%M') %></div>
    </div>
  </div>
  <div class="small text-muted mb-2">
    <i class="bi bi-person me-1"></i>
    <%= user_name_for(version, users_by_id) %>
  </div>

  <% if version.event == 'update' %>
    <% all_changes = summarize_changes(version, max_keys: 100) %>
    <% if all_changes.any? %>
      <div class="p-2 rounded-2 bg-light border-start border-2 border-secondary mb-2">
        <% all_changes.each do |attr, (before, after)| %>
          <div class="small mb-1">
            <span class="badge bg-<%= change_severity(attr) %>-subtle text-<%= change_severity(attr) %>-emphasis me-1"
                  style="font-size:0.65rem;">
              <%= attribute_label(attr, version.item_type) %>
            </span>
            <code class="text-danger" style="font-size:0.72rem; word-break:break-word;">
              <%= format_change_value(before, attr, version.item_type) %>
            </code>
            <i class="bi bi-arrow-right mx-1 text-muted" style="font-size:0.7rem;"></i>
            <code class="text-success" style="font-size:0.72rem; word-break:break-word;">
              <%= format_change_value(after, attr, version.item_type) %>
            </code>
          </div>
        <% end %>
      </div>
    <% end %>
  <% elsif version.event == 'create' %>
    <% fields = create_summary(version) %>
    <% if fields.any? %>
      <div class="p-2 rounded-2 bg-success bg-opacity-10 border-start border-2 border-success mb-2">
        <% fields.each do |attr, value| %>
          <div class="small mb-1">
            <span class="badge bg-success-subtle text-success-emphasis me-1" style="font-size:0.65rem;">
              <%= attribute_label(attr, version.item_type) %>
            </span>
            <code class="text-success" style="font-size:0.72rem; word-break:break-word;">
              <%= format_change_value(value, attr, version.item_type) %>
            </code>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="small text-success mb-2">
        <i class="bi bi-plus-circle me-1"></i> Registro creado
      </div>
    <% end %>
  <% elsif version.event == 'destroy' %>
    <% fields = destroy_summary(version) %>
    <% if fields.any? %>
      <div class="p-2 rounded-2 bg-danger bg-opacity-10 border-start border-2 border-danger mb-2">
        <% fields.each do |attr, value| %>
          <div class="small mb-1">
            <span class="badge bg-danger-subtle text-danger-emphasis me-1" style="font-size:0.65rem;">
              <%= attribute_label(attr, version.item_type) %>
            </span>
            <code class="text-danger" style="font-size:0.72rem; word-break:break-word;">
              <%= format_change_value(value, attr, version.item_type) %>
            </code>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="small text-danger mb-2">
        <i class="bi bi-trash me-1"></i> Registro eliminado
      </div>
    <% end %>
  <% end %>

  <%= link_to resource_history_audit_logs_path(item_type: version.item_type, item_id: version.item_id),
      class: 'btn btn-sm btn-outline-secondary' do %>
    <i class="bi bi-clock-history me-1"></i> Ver historial
  <% end %>
</div>
<style>
  .related-version-item:hover { background-color: #fafbfc; transition: background 0.15s ease; }
  .related-version-item:last-child { border-bottom: none !important; }
</style>

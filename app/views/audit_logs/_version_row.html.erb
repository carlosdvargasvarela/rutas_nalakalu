<%# app/views/audit_logs/_version_row.html.erb %>
<tr class="audit-row" data-version-id="<%= version.id %>">
  <%# Fecha %>
  <td class="ps-4 py-3">
    <div class="fw-semibold text-dark small"><%= version.created_at.strftime('%d/%m/%Y') %></div>
    <div class="text-muted" style="font-size:0.75rem;"><%= version.created_at.strftime('%H:%M:%S') %></div>
  </td>
  <%# Usuario %>
  <td class="py-3">
    <div class="d-flex align-items-center gap-2">
      <div class="audit-avatar">
        <i class="bi bi-person-fill"></i>
      </div>
      <div>
        <div class="small fw-semibold text-dark"><%= user_name_for(version, users_by_id) %></div>
        <div class="text-muted" style="font-size:0.72rem;">ID: <%= version.whodunnit || '—' %></div>
      </div>
    </div>
  </td>
  <%# Recurso %>
  <td class="py-3">
    <% record = safe_find_item(version) %>
    <div class="d-flex align-items-center gap-2">
      <i class="<%= resource_icon(version.item_type) %> text-muted fs-6"></i>
      <div>
        <% if record.present? %>
          <% path = polymorphic_path(record) rescue nil %>
          <% if path %>
            <%= link_to path, class: 'small fw-semibold text-decoration-none text-dark link-hover' do %>
              <%= item_label(version) %>
              <i class="bi bi-box-arrow-up-right ms-1 text-muted" style="font-size:0.7rem;"></i>
            <% end %>
          <% else %>
            <span class="small fw-semibold"><%= item_label(version) %></span>
          <% end %>
        <% else %>
          <span class="small text-muted">
            <%= item_label(version) %>
            <span class="badge bg-secondary bg-opacity-10 text-secondary ms-1">eliminado</span>
          </span>
        <% end %>
        <div class="text-muted" style="font-size:0.72rem;"><%= version.item_type %></div>
      </div>
    </div>
  </td>
  <%# Evento %>
  <td class="py-3 text-center">
    <%= event_badge(version.event) %>
  </td>
  <%# Cambios %>
  <td class="py-3">
    <% if version.event == 'update' %>
      <% all_changes = summarize_changes(version, max_keys: 100) %>
      <% if all_changes.blank? %>
        <span class="text-muted fst-italic small">Sin cambios detectados</span>
      <% else %>
        <div class="changes-summary">
          <% all_changes.each do |attr, (before, after)| %>
            <div class="change-item mb-2">
              <span class="badge bg-<%= change_severity(attr) %> bg-opacity-10 text-<%= change_severity(attr) %> mb-1">
                <%= attribute_label(attr, version.item_type) %>
              </span>
              <div class="d-flex align-items-center gap-2 small flex-wrap">
                <code class="change-code text-danger"><%= format_change_value(before, attr, version.item_type) %></code>
                <i class="bi bi-arrow-right text-muted"></i>
                <code class="change-code text-success"><%= format_change_value(after, attr, version.item_type) %></code>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    <% elsif version.event == 'create' %>
      <% fields = create_summary(version) %>
      <% if fields.any? %>
        <div class="changes-summary">
          <% fields.each do |attr, value| %>
            <div class="change-item mb-1">
              <span class="badge bg-success bg-opacity-10 text-success mb-1" style="font-size:0.65rem;">
                <%= attribute_label(attr, version.item_type) %>
              </span>
              <code class="change-code text-success" style="font-size:0.72rem;">
                <%= format_change_value(value, attr, version.item_type) %>
              </code>
            </div>
          <% end %>
        </div>
      <% else %>
        <span class="small text-success"><i class="bi bi-plus-circle me-1"></i>Registro creado</span>
      <% end %>
    <% elsif version.event == 'destroy' %>
      <% fields = destroy_summary(version) %>
      <% if fields.any? %>
        <div class="changes-summary">
          <% fields.each do |attr, value| %>
            <div class="change-item mb-1">
              <span class="badge bg-danger bg-opacity-10 text-danger mb-1" style="font-size:0.65rem;">
                <%= attribute_label(attr, version.item_type) %>
              </span>
              <code class="change-code text-danger" style="font-size:0.72rem;">
                <%= format_change_value(value, attr, version.item_type) %>
              </code>
            </div>
          <% end %>
        </div>
      <% else %>
        <span class="small text-danger"><i class="bi bi-trash me-1"></i>Registro eliminado</span>
      <% end %>
    <% end %>
  </td>
  <%# Acciones %>
  <td class="py-3 text-center pe-4">
    <%= link_to resource_history_audit_logs_path(item_type: version.item_type, item_id: version.item_id),
        class: 'btn btn-sm btn-outline-secondary',
        title: 'Ver historial completo',
        data: { bs_toggle: 'tooltip' } do %>
      <i class="bi bi-clock-history"></i>
    <% end %>
  </td>
</tr>
<style>
  .audit-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: #e8f0fe;
    color: #3b5bdb;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem;
    flex-shrink: 0;
  }
  .change-code {
    background: #f8f9fa;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.75rem;
    max-width: 340px;
    word-break: break-word;
    white-space: pre-wrap;
    display: inline-block;
  }
  .change-item {
    padding: 6px 8px;
    border-left: 2px solid #e9ecef;
    border-radius: 0 4px 4px 0;
  }
  .audit-row:hover { background-color: #fafbfc; }
  .link-hover:hover { color: #3b5bdb !important; }
</style>

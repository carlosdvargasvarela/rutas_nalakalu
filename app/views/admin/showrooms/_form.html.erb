<%= simple_form_for [:admin, showroom] do |f| %>
  <% if showroom.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% showroom.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.input :name, label: "Nombre del showroom",
          input_html: { class: "form-control", placeholder: "Ej: Showroom Rohrmoser" },
          label_html: { class: "form-label fw-bold" } %>
    </div>
    <div class="col-md-3">
      <%= f.input :code, label: "Código único",
          input_html: { class: "form-control text-uppercase font-monospace", placeholder: "Ej: ROHR" },
          hint: "Solo letras y guiones, se guarda en mayúsculas",
          label_html: { class: "form-label fw-bold" } %>
    </div>
    <div class="col-md-3">
      <div class="form-check mt-4 pt-2">
        <%= f.check_box :is_main, class: "form-check-input" %>
        <%= f.label :is_main, "Sala principal (restock)", class: "form-check-label fw-bold" %>
        <div class="form-text">Marca si esta es la sala central de restock</div>
      </div>
    </div>

    <%# DIRECCIÓN con mapa %>
    <div class="col-12">
      <label class="form-label fw-bold">
        <i class="bi bi-geo-alt-fill me-1 text-primary"></i>Ubicación del showroom
      </label>
      <div data-controller="address-autocomplete"
           data-address-autocomplete-api-key-value="<%= ENV.fetch('GOOGLE_MAPS_API_KEY', '') %>">

        <%# Búsqueda %>
        <div class="mb-3">
          <div class="input-group">
            <span class="input-group-text bg-light"><i class="bi bi-search text-muted"></i></span>
            <%= text_field_tag "showroom_address_search",
                  showroom.delivery_address&.address,
                  placeholder: "Plus Code, coordenadas o nombre del lugar...",
                  class: "form-control",
                  data: {
                    "address-autocomplete-target": "input",
                    action: "input->address-autocomplete#handleSmartInput blur->address-autocomplete#handleSmartInput"
                  } %>
          </div>
          <div class="form-text">
            <i class="bi bi-lightbulb me-1"></i>Pegá <code>9.93,-84.08</code>, un Plus Code o buscá el nombre del lugar
          </div>
        </div>

        <%# Mapa %>
        <div class="mb-3 position-relative">
          <div data-address-autocomplete-target="map"
               class="rounded border"
               style="height: 300px; width: 100%; background: #e9ecef;"></div>
          <div class="position-absolute bottom-0 start-0 m-2 px-2 py-1 bg-white rounded border small d-flex gap-3"
               style="z-index: 1000;">
            <span>
              <span class="text-muted">Lat:</span>
              <strong data-address-autocomplete-target="latDisplay" class="text-primary">--</strong>
            </span>
            <span>
              <span class="text-muted">Lng:</span>
              <strong data-address-autocomplete-target="lngDisplay" class="text-primary">--</strong>
            </span>
            <span>
              <span class="text-muted">Plus:</span>
              <strong data-address-autocomplete-target="plusDisplay" class="text-success font-monospace">--</strong>
            </span>
          </div>
        </div>

        <%# Dirección detectada %>
        <div class="mb-3 p-2 bg-light rounded border d-flex align-items-start gap-2">
          <i class="bi bi-geo-alt-fill text-primary mt-1 small"></i>
          <div class="small flex-grow-1">
            <div class="text-muted mb-1">Dirección detectada</div>
            <div data-address-autocomplete-target="addressDisplay">
              <% if showroom.delivery_address&.address.present? %>
                <%= showroom.delivery_address.address %>
              <% else %>
                <span class="fst-italic text-muted">Se completará al seleccionar una ubicación</span>
              <% end %>
            </div>
          </div>
        </div>

        <%# Referencia adicional %>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Referencia adicional</label>
          <input type="text"
                 name="showroom[delivery_address_attributes][description]"
                 class="form-control"
                 value="<%= showroom.delivery_address&.description %>"
                 placeholder="Ej: Edificio blanco, local 3, frente al parque"
                 data-address-autocomplete-target="description">
        </div>

        <%# Hidden fields %>
        <input type="hidden" name="showroom[delivery_address_attributes][address]"
               value="<%= showroom.delivery_address&.address %>"
               data-address-autocomplete-target="addressName">
        <input type="hidden" name="showroom[delivery_address_attributes][latitude]"
               value="<%= showroom.delivery_address&.latitude %>"
               data-address-autocomplete-target="lat">
        <input type="hidden" name="showroom[delivery_address_attributes][longitude]"
               value="<%= showroom.delivery_address&.longitude %>"
               data-address-autocomplete-target="lng">
        <input type="hidden" name="showroom[delivery_address_attributes][plus_code]"
               value="<%= showroom.delivery_address&.plus_code %>"
               data-address-autocomplete-target="plus">
        <% if showroom.delivery_address_id.present? %>
          <input type="hidden" name="showroom[delivery_address_attributes][id]"
                 value="<%= showroom.delivery_address_id %>">
        <% end %>
      </div>
    </div>

    <div class="col-12"><hr class="my-1"></div>
    <div class="col-12">
      <h6 class="text-muted mb-3"><i class="bi bi-funnel me-1"></i>Reglas de detección automática</h6>
      <p class="small text-muted">Separar valores con comas. La detección es case-insensitive.</p>
    </div>

    <div class="col-md-6">
      <label class="form-label fw-bold">Prefijos de número de pedido</label>
      <input type="text" name="showroom[order_number_prefixes_raw]"
             class="form-control font-monospace"
             value="<%= showroom.order_number_prefixes.join(', ') %>"
             placeholder="Ej: 2, 3, SHOW-">
      <div class="form-text">Pedidos que <em>empiecen</em> con estos valores → showroom</div>
    </div>

    <div class="col-md-6">
      <label class="form-label fw-bold">Palabras clave en número de pedido</label>
      <input type="text" name="showroom[order_number_keywords_raw]"
             class="form-control"
             value="<%= showroom.order_number_keywords.join(', ') %>"
             placeholder="Ej: restock, sala">
      <div class="form-text">Pedidos que <em>contengan</em> estas palabras → showroom</div>
    </div>

    <div class="col-md-6">
      <label class="form-label fw-bold">Palabras clave de movimientos inter-sala</label>
      <input type="text" name="showroom[inter_sala_keywords_raw]"
             class="form-control"
             value="<%= showroom.inter_sala_keywords.join(', ') %>"
             placeholder="Ej: entre salas, traslado sala">
      <div class="form-text">Si aparecen en pedido, dirección o producto → movimiento inter-sala</div>
    </div>

    <div class="col-md-6">
      <label class="form-label fw-bold">Palabras clave en productos</label>
      <input type="text" name="showroom[product_keywords_raw]"
             class="form-control"
             value="<%= showroom.product_keywords.join(', ') %>"
             placeholder="Ej: stock sala, muestra, exhibición">
      <div class="form-text">Si aparecen en la descripción de productos → showroom</div>
    </div>
  </div>

  <div class="d-flex justify-content-between mt-4">
    <%= link_to "Cancelar", admin_showrooms_path, class: "btn btn-outline-secondary" %>
    <%= f.submit showroom.new_record? ? "Crear showroom" : "Guardar cambios",
        class: "btn btn-primary px-4" %>
  </div>
<% end %>

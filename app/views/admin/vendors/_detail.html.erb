<%= turbo_frame_tag "vendor_detail", class: "h-100 d-block" do %>
  <div class="h-100 overflow-auto bg-white p-4">
    <div class="d-flex align-items-center mb-4">
      <i class="bi bi-truck fs-2 text-primary me-3"></i>
      <div>
        <h1 class="h4 mb-0"><%= vendor.name.presence || "Editar proveedor" %></h1>
        <p class="text-muted small mb-0">Edita los datos sin salir de esta vista</p>
      </div>
    </div>
    <%= render "form", vendor: vendor %>
  </div>
<% end %>

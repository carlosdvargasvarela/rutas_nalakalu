<div id="<%= dom_id(vendor, :card) %>"
     class="card shadow-sm mb-2"
     data-workspace-target="card"
     data-action="click->workspace#select">
  <%= link_to edit_admin_vendor_path(vendor),
        class: "text-decoration-none d-block text-body",
        data: {card_link: true, turbo_frame: "vendor_detail"} do %>
    <div class="card-body py-2 px-3">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <div class="fw-semibold"><%= vendor.name %></div>
          <% primary = vendor.vendor_contacts.find(&:is_primary?) || vendor.vendor_contacts.first %>
          <% if primary %>
            <div class="small text-muted"><%= [primary.name, primary.phone].compact.join(" · ") %></div>
          <% end %>
        </div>
        <span class="badge bg-light text-dark border small">
          <i class="bi bi-geo-alt me-1"></i><%= vendor.vendor_addresses.size %>
        </span>
      </div>
    </div>
  <% end %>
</div>

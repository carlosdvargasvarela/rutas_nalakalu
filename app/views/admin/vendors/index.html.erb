<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-0"><i class="bi bi-truck me-2 text-primary"></i>Proveedores</h1>
    <p class="text-muted small mb-0">Nombre, contactos y direcciones precargadas para mandados</p>
  </div>
  <% if policy(Vendor).new? %>
    <%= link_to new_admin_vendor_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-circle me-1"></i>Nuevo proveedor
    <% end %>
  <% end %>
</div>

<% if @vendors.empty? %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-truck fs-1 d-block mb-3 opacity-25"></i>
    <p>No hay proveedores registrados.</p>
    <% if policy(Vendor).new? %>
      <%= link_to "Crear el primero", new_admin_vendor_path, class: "btn btn-outline-primary" %>
    <% end %>
  </div>
<% else %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Nombre</th>
            <th>Contacto principal</th>
            <th>Direcciones</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @vendors.each do |vendor| %>
            <tr>
              <td class="fw-semibold"><%= vendor.name %></td>
              <td class="small text-muted">
                <% primary = vendor.vendor_contacts.find(&:is_primary?) || vendor.vendor_contacts.first %>
                <%= [primary&.name, primary&.phone].compact.join(" - ") if primary %>
              </td>
              <td class="small text-muted">
                <%= vendor.vendor_addresses.map(&:full_address).join("; ").truncate(80) %>
              </td>
              <td class="text-end">
                <% if policy(vendor).edit? %>
                  <%= link_to edit_admin_vendor_path(vendor), class: "btn btn-sm btn-outline-secondary me-1" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                <% end %>
                <% if policy(vendor).destroy? %>
                  <%= button_to admin_vendor_path(vendor), method: :delete,
                      class: "btn btn-sm btn-outline-danger",
                      form: { data: { turbo_confirm: "¿Eliminar el proveedor '#{vendor.name}'?" } } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

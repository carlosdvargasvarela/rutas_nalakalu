<div class="workspace-container container-fluid py-3"
     data-controller="workspace"
     data-workspace-detail-frame-value="vendor_detail"
     data-workspace-active-class="border-primary">
  <div class="row g-3 workspace-row">
    <%# ── COLUMNA IZQUIERDA: Lista ── %>
    <div class="col-12 col-lg-5 col-xl-4 workspace-col d-flex flex-column">
      <div class="card shadow-sm border-0 h-100 d-flex flex-column overflow-hidden">
        <div class="card-header bg-white border-bottom py-3 flex-shrink-0">
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-truck me-2 text-primary"></i>Proveedores</h5>
            <% if policy(Vendor).new? %>
              <%= link_to new_admin_vendor_path, class: "btn btn-sm btn-primary" do %>
                <i class="bi bi-plus-lg"></i>
                <span class="d-none d-sm-inline">Nuevo</span>
              <% end %>
            <% end %>
          </div>
        </div>
        <div class="flex-grow-1 overflow-auto p-2" style="background-color: #f4f6f9;">
          <% if @vendors.any? %>
            <% @vendors.each do |vendor| %>
              <%= render "vendor_card", vendor: vendor %>
            <% end %>
          <% else %>
            <div class="text-center py-5 bg-white rounded-3 m-2 border">
              <i class="bi bi-truck text-light-emphasis" style="font-size: 3rem;"></i>
              <p class="text-muted mt-3 mb-0">No hay proveedores registrados.</p>
              <% if policy(Vendor).new? %>
                <%= link_to "Crear el primero", new_admin_vendor_path, class: "btn btn-outline-primary btn-sm mt-2" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <%# ── COLUMNA DERECHA: Panel de detalle ── %>
    <div class="col-lg-7 col-xl-8 workspace-col d-none d-lg-flex flex-column">
      <div class="card shadow-sm border-0 h-100 overflow-hidden">
        <%= turbo_frame_tag "vendor_detail", class: "h-100 d-block", data: {turbo_permanent: true} do %>
          <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted p-5 bg-white">
            <div class="text-center">
              <i class="bi bi-layout-sidebar-reverse text-light-emphasis" style="font-size: 4rem;"></i>
              <h5 class="fw-semibold mt-3">Selecciona un proveedor</h5>
              <p class="small text-secondary mb-0">Haz clic en uno de la lista para ver y editar sus datos.</p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

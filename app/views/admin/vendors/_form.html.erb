<%= simple_form_for [:admin, vendor] do |f| %>
  <% if vendor.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% vendor.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="accordion" id="vendorAccordion">
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#vendorGeneral">
          <i class="bi bi-truck me-2 text-primary"></i><strong>Datos generales</strong>
        </button>
      </h2>
      <div id="vendorGeneral" class="accordion-collapse collapse show" data-bs-parent="#vendorAccordion">
        <div class="accordion-body">
          <%= f.input :name, label: "Nombre del proveedor",
              input_html: { class: "form-control", placeholder: "Ej: Ferretería EPA" },
              label_html: { class: "form-label fw-bold" } %>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#vendorContacts">
          <i class="bi bi-person-lines-fill me-2 text-success"></i><strong>Contactos</strong> <span class="text-muted small ms-2">(opcional)</span>
        </button>
      </h2>
      <div id="vendorContacts" class="accordion-collapse collapse" data-bs-parent="#vendorAccordion">
        <div class="accordion-body">
          <div class="row g-3">
            <% vendor.vendor_contacts.each_with_index do |contact, i| %>
              <div class="col-md-5">
                <input type="text" name="vendor[vendor_contacts_attributes][<%= i %>][name]"
                       class="form-control" value="<%= contact.name %>" placeholder="Nombre del contacto">
              </div>
              <div class="col-md-4">
                <input type="text" name="vendor[vendor_contacts_attributes][<%= i %>][phone]"
                       class="form-control" value="<%= contact.phone %>" placeholder="Teléfono">
              </div>
              <div class="col-md-3 d-flex align-items-center gap-2">
                <div class="form-check">
                  <input type="checkbox" name="vendor[vendor_contacts_attributes][<%= i %>][is_primary]"
                         value="1" class="form-check-input" id="contact_primary_<%= i %>"
                         <%= "checked" if contact.is_primary? %>>
                  <input type="hidden" name="vendor[vendor_contacts_attributes][<%= i %>][is_primary]" value="0">
                  <label class="form-check-label small" for="contact_primary_<%= i %>">Principal</label>
                </div>
                <% if contact.persisted? %>
                  <input type="hidden" name="vendor[vendor_contacts_attributes][<%= i %>][id]" value="<%= contact.id %>">
                  <div class="form-check">
                    <input type="checkbox" name="vendor[vendor_contacts_attributes][<%= i %>][_destroy]"
                           value="1" class="form-check-input" id="contact_destroy_<%= i %>">
                    <label class="form-check-label small text-danger" for="contact_destroy_<%= i %>">Eliminar</label>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#vendorAddresses">
          <i class="bi bi-geo-alt-fill me-2 text-danger"></i><strong>Direcciones</strong> <span class="text-muted small ms-2">(al menos una)</span>
        </button>
      </h2>
      <div id="vendorAddresses" class="accordion-collapse collapse" data-bs-parent="#vendorAccordion">
        <div class="accordion-body"
             data-controller="vendor-address-list"
             data-vendor-address-list-addresses-value="<%= vendor.vendor_addresses.reject(&:marked_for_destruction?).map { |a|
               {id: a.id, address: a.address, description: a.description, latitude: a.latitude, longitude: a.longitude, plusCode: a.plus_code}
             }.to_json %>"
             data-vendor-address-list-address-autocomplete-outlet="#vendor_address_autocomplete">

          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="small text-muted">Cada una necesita coordenadas (usa el buscador o el mapa)</span>
            <button type="button" class="btn btn-sm btn-primary" data-action="vendor-address-list#openAdd">
              <i class="bi bi-plus-lg me-1"></i>Agregar dirección
            </button>
          </div>

          <div class="alert alert-warning small" data-vendor-address-list-target="emptyHint">
            Todavía no hay direcciones agregadas.
          </div>

          <div data-vendor-address-list-target="list"></div>

          <%# Panel inline (no modal): un solo mapa reutilizado para agregar o editar
              cualquier dirección. No es un Bootstrap Modal a propósito — este componente
              puede vivir dentro de OTRO modal (alta de proveedor desde el mandado), y
              Bootstrap 5 no soporta bien modales anidados. %>
          <div class="card border-primary mt-3 d-none" data-vendor-address-list-target="editor">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
              <strong data-vendor-address-list-target="editorTitle">Agregar dirección</strong>
              <button type="button" class="btn-close" data-action="vendor-address-list#cancelEdit"></button>
            </div>
            <div class="card-body">
              <div id="vendor_address_autocomplete" data-controller="address-autocomplete"
                   data-address-autocomplete-api-key-value="<%= ENV.fetch('GOOGLE_MAPS_API_KEY', '') %>">
                <div class="mb-2">
                  <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" placeholder="Plus Code, coordenadas o nombre del lugar..."
                           class="form-control"
                           data-address-autocomplete-target="input"
                           data-action="input->address-autocomplete#handleSmartInput blur->address-autocomplete#handleSmartInput">
                  </div>
                </div>
                <div class="mb-2 position-relative">
                  <div data-address-autocomplete-target="map" class="rounded border" style="height: 300px; width: 100%; background: #e9ecef;"></div>
                  <div class="position-absolute bottom-0 start-0 m-2 px-2 py-1 bg-white rounded border small d-flex gap-3" style="z-index: 1000;">
                    <span><span class="text-muted">Lat:</span> <strong data-address-autocomplete-target="latDisplay" class="text-primary">--</strong></span>
                    <span><span class="text-muted">Lng:</span> <strong data-address-autocomplete-target="lngDisplay" class="text-primary">--</strong></span>
                    <span><span class="text-muted">Plus:</span> <strong data-address-autocomplete-target="plusDisplay" class="text-success font-monospace">--</strong></span>
                  </div>
                </div>
                <div class="mb-2 p-2 bg-light rounded border small">
                  <span class="text-muted">Dirección detectada:</span>
                  <span data-address-autocomplete-target="addressDisplay"></span>
                </div>
                <label class="form-label small fw-semibold">Referencia (opcional)</label>
                <input type="text" class="form-control mb-2"
                       data-address-autocomplete-target="description"
                       data-vendor-address-list-target="description"
                       placeholder="Ej: Bodega detrás del edificio principal">

                <input type="hidden" data-address-autocomplete-target="addressName" data-vendor-address-list-target="address">
                <input type="hidden" data-address-autocomplete-target="lat" data-vendor-address-list-target="latitude">
                <input type="hidden" data-address-autocomplete-target="lng" data-vendor-address-list-target="longitude">
                <input type="hidden" data-address-autocomplete-target="plus" data-vendor-address-list-target="plusCode">
              </div>
            </div>
            <div class="card-footer bg-white d-flex justify-content-end gap-2">
              <button type="button" class="btn btn-outline-secondary" data-action="vendor-address-list#cancelEdit">Cancelar</button>
              <button type="button" class="btn btn-primary" data-action="vendor-address-list#confirm">Guardar dirección</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between mt-4">
    <div class="d-flex gap-2">
      <% if local_assigns[:modal] %>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
      <% else %>
        <%= link_to "Cancelar", admin_vendors_path, class: "btn btn-outline-secondary" %>
      <% end %>
    </div>
    <%= f.submit vendor.new_record? ? "Crear proveedor" : "Guardar cambios", class: "btn btn-primary px-4" %>
  </div>
<% end %>

<%# button_to genera su propio <form>: debe vivir fuera del simple_form_for de
    arriba, un <form> anidado dentro de otro es HTML inválido y el navegador
    termina enviando el submit equivocado (el de "Guardar cambios"). %>
<% if !local_assigns[:modal] && vendor.persisted? && policy(vendor).destroy? %>
  <div class="mt-2">
    <%= button_to "Eliminar proveedor", admin_vendor_path(vendor), method: :delete,
        class: "btn btn-outline-danger",
        form: {data: {turbo_frame: "_top", turbo_confirm: "¿Eliminar el proveedor '#{vendor.name}'? Esto también borra sus contactos y direcciones."}} %>
  </div>
<% end %>

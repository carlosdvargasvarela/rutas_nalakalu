<div class="container mt-4 admin-container-md">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Dashboard", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "Admin", admin_users_path %></li>
      <li class="breadcrumb-item active">Vocabulario de entregas</li>
    </ol>
  </nav>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom py-3">
      <h5 class="mb-0 fw-semibold">
        <i class="bi bi-tags me-2 text-primary"></i>Vocabulario de entregas
      </h5>
    </div>
    <div class="card-body p-4">

      <% if notice.present? %>
        <div class="alert alert-success border-0 shadow-sm mb-4">
          <i class="bi bi-check-circle-fill me-2"></i><%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="alert alert-danger border-0 shadow-sm mb-4">
          <i class="bi bi-exclamation-triangle-fill me-2"></i><%= alert %>
        </div>
      <% end %>

      <p class="text-muted mb-4">
        Palabras y prefijos que usan los formularios de Recolección/Devolución/Reparación,
        y las listas de palabras clave que usan los detectores automáticos
        (<code>app/services/deliveries/*_detector.rb</code>) para clasificar texto libre.
        Separar valores con comas. La detección es case-insensitive.
      </p>

      <%= form_with url: admin_deliveries_vocabulary_path, method: :patch, local: true do %>

        <h6 class="text-muted mb-3"><i class="bi bi-chat-quote me-1"></i>Palabras de servicio</h6>
        <div class="row g-3 mb-4">
          <% @service_types.each do |key, attrs| %>
            <div class="col-md-6">
              <div class="border rounded-3 p-3">
                <label class="form-label small fw-bold text-uppercase text-muted"><%= key %></label>
                <input type="text" name="service_types[<%= key %>][label]"
                       class="form-control mb-2"
                       value="<%= attrs["label"] %>"
                       placeholder="Palabra (ej: Recolección)">
                <input type="text" name="service_types[<%= key %>][prefix]"
                       class="form-control font-monospace"
                       value="<%= attrs["prefix"] %>"
                       placeholder="Prefijo de producto (puede ir vacío)">
                <div class="form-text">Label visible al usuario / prefijo usado al duplicar productos</div>
              </div>
            </div>
          <% end %>
        </div>

        <hr class="my-4">

        <h6 class="text-muted mb-3"><i class="bi bi-funnel me-1"></i>Palabras clave de los detectores</h6>
        <div class="row g-3">
          <% @keyword_lists.each do |entry| %>
            <div class="col-md-6">
              <label class="form-label fw-bold"><%= entry[:title] %></label>
              <input type="text" name="keyword_lists[<%= entry[:detector] %>][<%= entry[:list_name] %>]"
                     class="form-control"
                     value="<%= entry[:values].join(', ') %>">
              <div class="form-text"><%= entry[:detector] %> / <%= entry[:list_name] %></div>
            </div>
          <% end %>
        </div>

        <div class="d-flex justify-content-end mt-4">
          <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-save me-2"></i>Guardar vocabulario
          </button>
        </div>
      <% end %>

    </div>
  </div>
</div>

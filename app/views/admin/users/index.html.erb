<%# app/views/admin/users/index.html.erb %>
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
  <div>
    <h2 class="mb-1 fw-semibold">
      Administración de usuarios
    </h2>
    <p class="text-muted mb-0">
      Gestiona accesos, roles y notificaciones del sistema
    </p>
  </div>
  <div class="d-flex align-items-center gap-3">
    <span class="text-muted small">
      <strong><%= @users.count %></strong>
      <%= pluralize(@users.count, "usuario") %>
    </span>
    <%= link_to new_admin_user_path, class: "btn btn-primary" do %>
      <i class="bi bi-person-plus-fill me-1"></i>
      Nuevo usuario
    <% end %>
  </div>
</div>
<div class="card shadow-sm border-0">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead class="bg-light">
        <tr>
          <th>Usuario</th>
          <th>Rol</th>
          <th>Último acceso</th>
          <th>Estado</th>
          <th>Notificaciones</th>
          <th class="text-end">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="border-top">
            <td>
              <div class="d-flex flex-column">
                <strong><%= user.name %></strong>
                <span class="text-muted small"><%= user.email %></span>
              </div>
            </td>
            <td>
              <% role_color = case user.role
                when "admin" then "danger"
                when "production_manager" then "warning"
                when "seller" then "info"
                when "logistics" then "primary"
                when "driver" then "secondary"
              end %>
              <span class="badge bg-<%= role_color %> bg-opacity-10 text-<%= role_color %> fw-semibold">
                <%= user.display_role %>
              </span>
            </td>
            <td>
              <% if user.last_sign_in_at.present? %>
                <span class="text-success small">
                  <i class="bi bi-check-circle me-1"></i>
                  <%= l(user.last_sign_in_at, format: :short) %>
                </span>
              <% else %>
                <span class="text-muted small">Nunca</span>
              <% end %>
            </td>
            <td>
              <% if user.access_locked? %>
                <span class="badge bg-danger bg-opacity-10 text-danger">
                  <i class="bi bi-lock-fill me-1"></i>
                  Bloqueado
                </span>
              <% else %>
                <span class="badge bg-success bg-opacity-10 text-success">
                  <i class="bi bi-unlock-fill me-1"></i>
                  Activo
                </span>
              <% end %>
            </td>
            <td>
              <% if user.send_notifications? %>
                <span class="badge bg-primary bg-opacity-10 text-primary">
                  <i class="bi bi-bell-fill me-1"></i> Activas
                </span>
              <% else %>
                <span class="badge bg-secondary bg-opacity-10 text-secondary">
                  <i class="bi bi-bell-slash me-1"></i> Inactivas
                </span>
              <% end %>
            </td>
            <td class="text-end">
              <div class="btn-group">
                <%= link_to edit_admin_user_path(user),
                    class: "btn btn-sm btn-outline-secondary" do %>
                  <i class="bi bi-pencil-square"></i>
                <% end %>
                <%= button_to toggle_notifications_admin_user_path(user),
                    method: :patch,
                    class: "btn btn-sm #{user.send_notifications? ? 'btn-outline-primary' : 'btn-outline-secondary'}",
                    data: { turbo_confirm: "¿Cambiar notificaciones para #{user.name}?" } do %>
                  <i class="bi <%= user.send_notifications? ? 'bi-bell-fill' : 'bi-bell-slash' %>"></i>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
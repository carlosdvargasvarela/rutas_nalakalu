<%= simple_form_for delivery,
      html: {
        data: {
          controller: "delivery-form address-validator",
          "delivery-form-addresses-url-value": addresses_for_client_deliveries_path,
          "delivery-form-orders-url-value": orders_for_client_deliveries_path,
          action: "submit->address-validator#validateBeforeSubmit",
          turbo: true
        }
      } do |f| %>
  <%# ── HEADER DE PROGRESO ── %>
  <div class="d-flex align-items-center gap-3 mb-4 pb-3 border-bottom">
    <div class="d-flex align-items-center gap-2">
      <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1"
            data-delivery-form-target="clientBadge">!</span>
      <span class="small text-muted">Cliente</span>
    </div>
    <i class="bi bi-chevron-right text-muted small"></i>
    <div class="d-flex align-items-center gap-2">
      <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1"
            data-delivery-form-target="orderBadge">!</span>
      <span class="small text-muted">Pedido</span>
    </div>
    <i class="bi bi-chevron-right text-muted small"></i>
    <div class="d-flex align-items-center gap-2">
      <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1"
            data-delivery-form-target="deliveryDataBadge">!</span>
      <span class="small text-muted">Datos</span>
    </div>
    <i class="bi bi-chevron-right text-muted small"></i>
    <div class="d-flex align-items-center gap-2">
      <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1"
            data-delivery-form-target="productsBadge">!</span>
      <span class="small text-muted">Productos</span>
    </div>
    <i class="bi bi-chevron-right text-muted small"></i>
    <div class="d-flex align-items-center gap-2">
      <span class="badge rounded-pill bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1"
            data-delivery-form-target="addressBadge">!</span>
      <span class="small text-muted">Dirección</span>
    </div>
  </div>
  <%# ── LAYOUT DOS COLUMNAS ── %>
  <div class="row g-4 align-items-start">
    <%# ── COLUMNA IZQUIERDA: Cliente / Pedido / Datos / Productos ── %>
    <div class="col-lg-7">
      <%# Sección: Cliente %>
      <div class="mb-4">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3 d-flex align-items-center gap-2">
          <i class="bi bi-person-fill text-primary"></i> Cliente
        </h6>
        <%= render "deliveries/upsert_partials/client_fields", f: f, clients: clients, delivery: delivery %>
      </div>
      <%# Sección: Pedido %>
      <div class="mb-4">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3 d-flex align-items-center gap-2">
          <i class="bi bi-receipt text-primary"></i> Pedido
        </h6>
        <%= render "deliveries/upsert_partials/order_fields", f: f, delivery: delivery %>
      </div>
      <%# Sección: Datos de entrega %>
      <div class="mb-4">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3 d-flex align-items-center gap-2">
          <i class="bi bi-calendar-check text-primary"></i> Datos de entrega
        </h6>
        <%= render "deliveries/upsert_partials/delivery_data_fields", f: f, delivery: delivery %>
      </div>
      <%# Sección: Productos %>
      <div class="mb-4">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3 d-flex align-items-center gap-2">
          <i class="bi bi-box-seam text-primary"></i> Productos
        </h6>
        <%= render "deliveries/upsert_partials/order_items_fields", f: f %>
      </div>
    </div>
    <%# ── COLUMNA DERECHA: Dirección + Mapa (sticky) ── %>
    <div class="col-lg-5">
      <div class="sticky-top" style="top: 1rem;">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3 d-flex align-items-center gap-2">
          <i class="bi bi-geo-alt-fill text-primary"></i> Dirección de entrega
        </h6>
        <%= render "deliveries/upsert_partials/address_fields",
              f: f, addresses: addresses, delivery: delivery %>
      </div>
    </div>
  </div>
  <%= f.hidden_field :_return_to_panel, value: params[:return_to_panel] || "1" %>
  <%# ── FOOTER DE ACCIONES ── %>
  <div class="d-flex justify-content-between align-items-center pt-4 mt-2 border-top">
    <% cancel_url = local_assigns[:cancel_url] || deliveries_path %>
    <%= link_to cancel_url, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-x-lg me-1"></i> Volver a lista de entregas
    <% end %>
    <%= f.submit delivery.new_record? ? "Crear entrega" : "Guardar cambios",
        class: "btn btn-primary px-5",
        data: { "address-validator-target": "submitButton" } %>
  </div>
<% end %>
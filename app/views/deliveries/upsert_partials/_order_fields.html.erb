<%# Selector de pedido existente %>
<div class="row g-2 align-items-end mb-2">
  <div class="col">
    <div data-controller="searchable-select"
         data-searchable-select-placeholder-value="Selecciona un pedido..."
         data-searchable-select-search-placeholder-value="Buscar pedido...">
      <%= f.select :order_id,
            options_from_collection_for_select(
              @orders || [], :id, :number, delivery.order_id
            ),
            { prompt: "Selecciona un pedido..." },
            class: "form-select",
            data: {
              "delivery-form-target": "orderSelect",
              action: "change->delivery-form#orderChanged change->delivery-form#validateOrder"
            } %>
    </div>
  </div>
  <% unless delivery.persisted? %>
    <div class="col-auto">
      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="click->delivery-form#toggleNewOrderFields"
        data-delivery-form-target="addOrderButton">
        <i class="bi bi-plus-circle me-1"></i> Nuevo
      </button>
    </div>
  <% end %>
</div>
<%# Panel: nuevo pedido %>
<% unless delivery.persisted? %>
  <div data-delivery-form-target="newOrderFields"
       class="border rounded p-3 bg-light"
       style="display: none;">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <span class="fw-semibold small text-primary">
        <i class="bi bi-receipt me-1"></i> Nuevo pedido
      </span>
      <button type="button"
              class="btn-close btn-sm"
              data-action="click->delivery-form#cancelNewOrderFields"></button>
    </div>
    <div class="row g-2">
      <div class="col-md-6">
        <%= label_tag "order[number]", "Número de pedido", class: "form-label small fw-semibold" %>
        <%= text_field_tag "order[number]", nil,
              class: "form-control form-control-sm",
              placeholder: "Ej: PED-2025-001" %>
      </div>
      <div class="col-md-6">
        <%= label_tag :seller_id, "Vendedor", class: "form-label small fw-semibold" %>
        <%= select_tag :seller_id,
              options_from_collection_for_select(
                Seller.all, :id,
                ->(s) { "#{s.name} (#{s.seller_code})" }
              ),
              prompt: "Selecciona vendedor",
              class: "form-select form-select-sm" %>
      </div>
    </div>
  </div>
<% end %>
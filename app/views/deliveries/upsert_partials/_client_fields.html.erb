<%# Seleccionar cliente existente %>
<div class="mb-3">
  <div data-controller="searchable-select"
       data-searchable-select-placeholder-value="Selecciona un cliente..."
       data-searchable-select-search-placeholder-value="Buscar cliente...">
    <%= select_tag :client_id,
          options_from_collection_for_select(
            clients,
            :id,
            :name,
            params[:client_id] || f.object.order&.client_id
          ),
          include_blank: "Selecciona un cliente...",
          class: "form-select",
          data: {
            "delivery-form-target": "clientSelect",
            action: "change->delivery-form#clientChanged change->delivery-form#validateClient"
          } %>
  </div>
</div>
<%# Toggle: nuevo cliente %>
<% unless delivery.persisted? %>
  <div class="mb-2">
    <button type="button"
            class="btn btn-link btn-sm text-decoration-none px-0"
            data-action="click->delivery-form#toggleNewClientFields"
      data-delivery-form-target="addClientButton">
      <i class="bi bi-plus-circle me-1"></i> Crear nuevo cliente
    </button>
  </div>
  <div data-delivery-form-target="newClientFields"
       class="border rounded p-3 bg-light"
       style="display: none;">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <span class="fw-semibold small text-primary">
        <i class="bi bi-person-plus me-1"></i> Nuevo cliente
      </span>
      <button type="button"
              class="btn-close btn-sm"
              data-action="click->delivery-form#cancelNewClientFields"></button>
    </div>
    <div class="row g-2">
      <div class="col-12">
        <%= label_tag "client[name]", "Nombre *", class: "form-label small fw-semibold" %>
        <%= text_field_tag "client[name]",
              params.dig(:client, :name),
              placeholder: "Ej: Juan Pérez",
              class: "form-control form-control-sm",
              data: {
                "delivery-form-target": "newClientName",
                action: "input->delivery-form#validateClient"
              } %>
      </div>
      <div class="col-md-6">
        <%= label_tag "client[phone]", "Teléfono *", class: "form-label small fw-semibold" %>
        <%= text_field_tag "client[phone]",
              params.dig(:client, :phone),
              placeholder: "8888-8888",
              class: "form-control form-control-sm",
              data: {
                "delivery-form-target": "newClientPhone",
                action: "input->delivery-form#validateClient"
              } %>
      </div>
      <div class="col-md-6">
        <%= label_tag "client[email]", "Email", class: "form-label small fw-semibold" %>
        <%= text_field_tag "client[email]",
              params.dig(:client, :email),
              placeholder: "cliente@ejemplo.com",
              class: "form-control form-control-sm",
              data: { "delivery-form-target": "newClientEmail" } %>
      </div>
    </div>
  </div>
<% end %>
<div data-controller="address-autocomplete address-validator"
     data-address-autocomplete-api-key-value="<%= ENV.fetch('GOOGLE_MAPS_API_KEY', '') %>">
  <%# ── Dirección guardada ── %>
  <div data-controller="searchable-select"
     data-searchable-select-placeholder-value="Seleccionar dirección existente..."
     data-searchable-select-search-placeholder-value="Buscar dirección...">
    <%= f.select :delivery_address_id,
        options_from_collection_for_select(
          addresses || [],
          :id,
          :address,
          f.object.delivery_address_id || f.object.delivery_address&.id
        ),
        { prompt: "Seleccionar dirección existente..." },
        class: "form-select",
        data: {
          "delivery-form-target": "addressSelect",
          "address-autocomplete-target": "addressSelect",
          action: "change->address-autocomplete#loadExistingAddress change->delivery-form#addressChanged"
        } %>
  </div>
  <%# ── Divider ── %>
  <div class="d-flex align-items-center gap-2 mb-3">
    <hr class="flex-grow-1 m-0">
    <span class="text-muted small">o nueva dirección</span>
    <hr class="flex-grow-1 m-0">
  </div>
  <%# ── Búsqueda nueva dirección ── %>
  <div class="mb-3">
    <label class="form-label small fw-semibold">Buscar en Google Maps</label>
    <div class="input-group">
      <span class="input-group-text bg-light">
        <i class="bi bi-search text-muted"></i>
      </span>
      <%= text_field_tag "delivery_address[search_input]", nil,
            placeholder: "Plus Code, coordenadas o lugar...",
            class: "form-control",
            data: {
              "address-autocomplete-target": "input",
              action: "input->address-autocomplete#handleSmartInput blur->address-autocomplete#handleSmartInput"
            } %>
    </div>
    <div class="form-text">
      <i class="bi bi-lightbulb me-1"></i>
      Pegá <code>9.93,-84.08</code> o un Plus Code como <code>W2H5+2Q</code>
    </div>
  </div>
  <%# ── Mapa ── %>
  <div class="mb-3 position-relative">
    <div data-address-autocomplete-target="map"
         class="rounded border"
         style="height: 280px; width: 100%; background: #e9ecef;"></div>
    <%# Overlay de coordenadas sobre el mapa %>
    <div class="position-absolute bottom-0 start-0 m-2 px-2 py-1 bg-white rounded border small d-flex gap-3"
         style="z-index: 1000;">
      <span>
        <span class="text-muted">Lat:</span>
        <strong data-address-autocomplete-target="latDisplay" class="text-primary">--</strong>
      </span>
      <span>
        <span class="text-muted">Lng:</span>
        <strong data-address-autocomplete-target="lngDisplay" class="text-primary">--</strong>
      </span>
      <span>
        <span class="text-muted">Plus:</span>
        <strong data-address-autocomplete-target="plusDisplay" class="text-success font-monospace">--</strong>
      </span>
    </div>
  </div>
  <%# ── Detalles geográficos ── %>
  <div data-address-autocomplete-target="geoDetails"
       class="alert alert-light border small py-2 mb-3"
       style="display: none;">
    <i class="bi bi-map me-1"></i>
    <span class="text-muted">Seleccioná una ubicación para ver los detalles</span>
  </div>
  <%# ── Dirección detectada ── %>
  <div class="mb-3 p-2 bg-light rounded border d-flex align-items-start gap-2">
    <i class="bi bi-geo-alt-fill text-primary mt-1 small"></i>
    <div class="small flex-grow-1">
      <div class="text-muted mb-1">Dirección detectada</div>
      <div data-address-autocomplete-target="addressDisplay">
        <span class="fst-italic text-muted">Se completará al seleccionar una ubicación</span>
      </div>
    </div>
  </div>
  <%# ── Referencia para el chofer ── %>
  <div class="mb-3">
    <label class="form-label small fw-semibold">
      Referencia para el chofer <span class="text-danger">*</span>
    </label>
    <%= text_area_tag "delivery_address[description]",
          params.dig(:delivery_address, :description) || f.object.delivery_address&.description,
          placeholder: "Ej: Casa blanca, portón negro, 200m norte de la iglesia...",
          rows: 3,
          class: "form-control",
          required: true,
          data: {
            "address-autocomplete-target": "description",
            "address-validator-target": "addressInput"
          } %>
    <div class="form-text text-warning-emphasis">
      <i class="bi bi-exclamation-triangle me-1"></i>
      Sin esta referencia el chofer no puede encontrar el lugar aunque el GPS sea exacto.
    </div>
  </div>
  <%# ── Semáforo de validación ── %>
  <div class="d-flex gap-2">
    <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle"
          data-address-autocomplete-target="coordsStatus">
      <i class="bi bi-geo me-1"></i> Coordenadas: Pendiente
    </span>
    <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle"
          data-address-autocomplete-target="descStatus">
      <i class="bi bi-card-text me-1"></i> Descripción: Pendiente
    </span>
  </div>
  <%# ── Hidden fields ── %>
  <%= hidden_field_tag "delivery_address[latitude]",
        params.dig(:delivery_address, :latitude) || f.object.delivery_address&.latitude,
        data: { "address-autocomplete-target": "lat" } %>
  <%= hidden_field_tag "delivery_address[longitude]",
        params.dig(:delivery_address, :longitude) || f.object.delivery_address&.longitude,
        data: { "address-autocomplete-target": "lng" } %>
  <%= hidden_field_tag "delivery_address[plus_code]",
        params.dig(:delivery_address, :plus_code) || f.object.delivery_address&.plus_code,
        data: { "address-autocomplete-target": "plus" } %>
  <%= hidden_field_tag "delivery_address[address]",
        params.dig(:delivery_address, :address) || f.object.delivery_address&.address,
        data: { "address-autocomplete-target": "addressName" } %>
  <%= hidden_field_tag "delivery_address[client_id]",
        (@client&.id || delivery.order&.client&.id),
        data: { "delivery-form-target": "newAddressClientId" } %>
</div>
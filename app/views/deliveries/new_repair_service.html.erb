<% if flash[:alert] %>
  <div class="alert alert-danger">
    <i class="bi bi-exclamation-triangle me-2"></i>
    <%= flash[:alert] %>
  </div>
<% end %>
<div class="d-flex align-items-center mb-4">
  <i class="bi bi-wrench-adjustable me-2 fs-3 text-info"></i>
  <h1 class="mb-0">Nuevo Servicio de Reparación</h1>
</div>
<div class="card shadow-sm">
  <div class="card-body">
    <%= render "deliveries/repair_service_partials/form_repair_service", delivery: @delivery, clients: @clients, addresses: @addresses %>
  </div>
</div>

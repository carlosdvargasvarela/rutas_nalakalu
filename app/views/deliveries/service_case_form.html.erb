<%# app/views/deliveries/service_case_form.html.erb %>
<style>
  .pac-container { z-index: 9999 !important; }
</style>
<%= turbo_frame_tag "modal" do %>
  <div class="modal-header bg-warning">
    <h5 class="modal-title text-dark">
      <i class="bi bi-tools me-2"></i>Caso de Servicio
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
  </div>
  <%= simple_form_for @service_delivery,
        url: create_service_case_from_workspace_delivery_path(@delivery),
        method: :post do |f| %>
    <div class="modal-body">
      <div class="alert alert-warning small mb-4">
        <i class="bi bi-info-circle-fill me-2"></i>
        Define la dirección y fecha para gestionar este <strong>caso de servicio</strong>.
      </div>
      <%# Productos seleccionados %>
      <% if @items.any? %>
        <div class="mb-4">
          <label class="form-label fw-bold small text-uppercase text-muted">Productos de servicio</label>
          <div class="list-group list-group-flush shadow-sm rounded-3 border overflow-hidden">
            <% @items.each do |item| %>
              <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                <div class="d-flex align-items-center gap-2">
                  <%= check_box_tag "item_ids[]", item.id, true, class: "form-check-input flex-shrink-0" %>
                  <span class="small text-body"><%= item.order_item&.product || "Producto" %></span>
                </div>
                <span class="badge bg-secondary rounded-pill">x<%= item.quantity_delivered %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
      <%# Fecha %>
      <div class="mb-4">
        <%= f.input :delivery_date,
              as: :date,
              html5: true,
              label: "Fecha de gestión",
              input_html: {
                value: Date.current,
                class: "form-control border-warning"
              } %>
      </div>
      <%# Tipo de entrega %>
      <%= f.input :delivery_type,
            label: "Tipo de gestión",
            collection: [
              ["Recogida y entrega posterior", "pickup_with_return"],
              ["Solo recogida", "only_pickup"],
              ["Devolución", "return_delivery"]
            ],
            prompt: "Selecciona tipo",
            input_html: { class: "form-select" } %>
      <%# Dirección %>
      <div class="card border-warning shadow-sm mb-4 mt-3"
           data-controller="address-autocomplete"
           data-address-autocomplete-api-key-value="<%= ENV.fetch('GOOGLE_MAPS_API_KEY', '') %>">
        <div class="card-header bg-warning-subtle text-warning-emphasis py-2 d-flex align-items-center gap-2">
          <i class="bi bi-geo-alt-fill"></i>
          <span class="fw-semibold small">Dirección de gestión</span>
        </div>
        <div class="card-body">
          <%= render "deliveries/upsert_partials/address_fields",
                f: f,
                addresses: @addresses,
                delivery: @service_delivery %>
        </div>
      </div>
      <%# Contacto %>
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.input :contact_name,
                label: "Nombre de contacto",
                input_html: { class: "form-control-sm" } %>
        </div>
        <div class="col-md-6">
          <%= f.input :contact_phone,
                label: "Teléfono",
                input_html: { class: "form-control-sm" } %>
        </div>
      </div>
    </div>
    <div class="modal-footer bg-light d-flex justify-content-between align-items-center">
      <span class="text-muted small">
        <i class="bi bi-info-circle me-1"></i>
        Se creará una entrega derivada de tipo servicio
      </span>
      <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        <%= f.submit "Crear gestión", class: "btn btn-warning px-4 shadow-sm" %>
      </div>
    </div>
  <% end %>
<% end %>
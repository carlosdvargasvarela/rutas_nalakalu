<%# app/views/deliveries/sala_pickup_form.html.erb %>
<style>
  .pac-container { z-index: 9999 !important; }
</style>
<%= turbo_frame_tag "modal" do %>
  <div class="modal-header bg-danger text-white">
    <h5 class="modal-title"><i class="bi bi-shop me-2"></i>Nuevo Retiro en Sala</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
  </div>
  <%= simple_form_for @pickup_delivery, url: create_sala_pickup_delivery_path(@delivery), method: :post do |f| %>
    <%# ⚠️ SIN overflow aquí — el overflow lo maneja el modal de Bootstrap %>
    <div class="modal-body">
      <div class="alert alert-warning small mb-4">
        <i class="bi bi-info-circle-fill me-2"></i>
        Define la ubicación de la <strong>Sala</strong> donde se debe recoger el producto <strong>antes</strong> de la entrega al cliente.
      </div>
      <%# 1. Productos por Sala %>
      <div class="mb-4">
        <label class="form-label fw-bold small text-uppercase text-muted">Productos a recoger</label>
        <div class="list-group list-group-flush shadow-sm rounded-3 border overflow-hidden">
          <% @items_by_sala.each do |sala, items| %>
            <div class="list-group-item bg-dark text-white fw-semibold py-2 small d-flex justify-content-between align-items-center">
              <span><i class="bi bi-shop me-2"></i>SALA: <%= sala %></span>
              <span class="badge bg-danger">RECOGER AQUÍ</span>
            </div>
            <% items.each do |item| %>
              <div class="list-group-item d-flex justify-content-between align-items-center py-2">
                <div class="d-flex align-items-center gap-2">
                  <%= check_box_tag "item_ids[]", item.id, true, class: "form-check-input flex-shrink-0" %>
                  <span class="small text-body"><%= item.product %></span>
                </div>
                <span class="badge bg-secondary rounded-pill">x<%= item.quantity_delivered %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
      <%# 2. Fecha de retiro en sala %>
      <div class="mb-4">
        <%= f.input :delivery_date,
              as: :date,
              html5: true,
              label: "Fecha de retiro en sala",
              hint: "Debe ser anterior al #{@delivery.delivery_date.strftime("%d/%m/%Y")} (fecha de entrega al cliente)",
              input_html: {
                max: (@delivery.delivery_date - 1.day),
                min: Date.current,
                value: (@delivery.delivery_date - 1.day),
                class: "form-control border-primary"
              } %>
      </div>
      <%# 3. Dirección de la Sala %>
      <% default_code = @items_by_sala.keys.first %>
      <div data-controller="sala-pickup"
           data-sala-pickup-showrooms-value="<%= @showrooms_data.to_json %>">

        <%# Selector de sala %>
        <div class="mb-3">
          <label class="form-label fw-bold small text-uppercase text-muted">Sala de recogida</label>
          <select class="form-select form-select-sm"
                  name="showroom_code"
                  data-sala-pickup-target="select"
                  data-action="change->sala-pickup#updateAddress">
            <% @showrooms_data.each do |s| %>
              <option value="<%= s[:code] %>" <%= "selected" if s[:code] == default_code %>>
                <%= s[:name] %>
              </option>
            <% end %>
          </select>
        </div>

        <%# Dirección de la sala seleccionada (actualizada por Stimulus) %>
        <div class="card border-success shadow-sm mb-4 d-none" data-sala-pickup-target="addressCard">
          <div class="card-header bg-success-subtle text-success-emphasis py-2 d-flex align-items-center gap-2">
            <i class="bi bi-geo-alt-fill"></i>
            <span class="fw-semibold small">Dirección de la sala</span>
          </div>
          <div class="card-body py-3 d-flex align-items-start gap-2">
            <i class="bi bi-shop-window text-success mt-1 flex-shrink-0"></i>
            <div>
              <div class="fw-semibold small" data-sala-pickup-target="nameDisplay"></div>
              <div class="small text-muted" data-sala-pickup-target="addressDisplay"></div>
              <div class="small text-muted fst-italic mt-1 d-none" data-sala-pickup-target="descriptionDisplay"></div>
            </div>
          </div>
        </div>

        <%# Sin dirección configurada %>
        <div class="alert alert-warning small mb-4 py-2 d-none" data-sala-pickup-target="noAddress">
          <i class="bi bi-exclamation-triangle me-1"></i>
          Esta sala no tiene dirección configurada. Configurala en el panel de administración.
        </div>

        <%# Hidden fields — actualizados por el Stimulus controller %>
        <%= hidden_field_tag "delivery_address[latitude]",    nil, data: { "sala-pickup-target": "lat" } %>
        <%= hidden_field_tag "delivery_address[longitude]",   nil, data: { "sala-pickup-target": "lng" } %>
        <%= hidden_field_tag "delivery_address[plus_code]",   nil, data: { "sala-pickup-target": "plusCode" } %>
        <%= hidden_field_tag "delivery_address[address]",     nil, data: { "sala-pickup-target": "address" } %>
        <%= hidden_field_tag "delivery_address[description]", nil, data: { "sala-pickup-target": "description" } %>
        <%= hidden_field_tag "delivery_address[client_id]",   @delivery.order.client_id %>
      </div>
      <%# 4. Contacto en Sala %>
      <div class="row g-3">
        <div class="col-md-6">
          <%= f.input :contact_name,
                label: "Nombre contacto en Sala",
                input_html: { class: "form-control-sm", placeholder: "Ej: Encargado de Sala" } %>
        </div>
        <div class="col-md-6">
          <%= f.input :contact_phone,
                label: "Teléfono Sala",
                input_html: { class: "form-control-sm", placeholder: "Ej: 2222-3333" } %>
        </div>
      </div>
    </div>
    <div class="modal-footer bg-light d-flex justify-content-between align-items-center">
      <span class="text-muted small">
        <i class="bi bi-info-circle me-1"></i>
        Se creará una entrega de tipo <strong>Solo Retiro en Sala</strong>
      </span>
      <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        <%= f.submit "Generar Orden de Retiro en Sala", class: "btn btn-danger px-4 shadow-sm" %>
      </div>
    </div>
  <% end %>
<% end %>
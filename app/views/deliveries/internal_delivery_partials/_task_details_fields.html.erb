<div class="card shadow-sm mb-4">
  <div class="card-header bg-light">
    <i class="bi bi-pencil-square me-2 text-success"></i><strong>Detalle del mandado</strong>
  </div>
  <div class="card-body">

    <%# Productos físicos (si aplica) %>
    <div class="mb-4">
      <div class="form-label fw-bold fs-6">
        <i class="bi bi-box-seam me-1 text-success"></i>
        Productos
        <span class="badge bg-light text-secondary border ms-1" style="font-weight:400;">Opcional</span>
      </div>
      <p class="small text-muted mb-3">
        <i class="bi bi-info-circle me-1"></i>
        Si el mandado implica llevar o recoger productos específicos, descríbelos aquí.
        Dejar en blanco si no aplica.
      </p>
      <%= f.simple_fields_for :delivery_items do |di| %>
        <%= di.simple_fields_for :order_item do |oi| %>
          <%= oi.input :product,
              as: :text,
              label: "Lista de productos",
              input_html: {
                class: "form-control",
                rows: 3,
                placeholder: "Ej: 10 cajas de tornillos 2\", 5 rollos de cinta de embalaje..."
              },
              hint: "Un producto por línea o una descripción general",
              label_html: { class: "form-label fw-bold" } %>
          <%= oi.hidden_field :quantity, value: 1 %>
          <%= di.hidden_field :quantity_delivered, value: 1 %>
        <% end %>
      <% end %>
    </div>

    <%# ¿Qué hay que hacer? (opcional) %>
    <div class="border-top pt-3">
      <%= f.label :delivery_notes, class: "form-label fw-bold fs-6" do %>
        <i class="bi bi-clipboard-check me-1 text-success"></i>
        ¿Qué hay que hacer?
        <span class="badge bg-light text-secondary border ms-1" style="font-weight:400;">Opcional</span>
      <% end %>
      <%= f.text_area :delivery_notes,
          class: "form-control",
          rows: 5,
          placeholder: "Ej: Recoger 50 tornillos de 2 pulgadas en Ferretería El Tornillo y llevarlos a la bodega principal. Pedir factura a nombre de NaLakalu.",
          data: {
            action: "input->internal-delivery-form#validateTaskDetails"
          } %>
      <div class="form-text">
        <i class="bi bi-info-circle me-1"></i>
        Sea lo más específico posible para evitar confusiones al chofer
      </div>
    </div>

    <%# Ejemplos de mandados comunes %>
    <div class="card bg-light border-0 mt-3">
      <div class="card-body py-2">
        <h6 class="text-muted mb-2 small">
          <i class="bi bi-lightbulb me-1"></i> Ejemplos de mandados comunes:
        </h6>
        <ul class="small mb-0 text-muted">
          <li>Trasladar 10 cajas de herrajes desde bodega A a bodega B</li>
          <li>Comprar materiales en ferretería según lista adjunta</li>
          <li>Recoger documentos firmados en oficinas del cliente X</li>
          <li>Entregar muestras de productos a vendedor en zona Y</li>
        </ul>
      </div>
    </div>

  </div>
</div>

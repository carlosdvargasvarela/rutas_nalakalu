<% if flash[:alert] %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    <%= flash[:alert] %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>

<div class="d-flex align-items-center mb-4">
  <i class="bi bi-shop-window fs-2 text-primary me-3"></i>
  <div>
    <h1 class="h3 mb-0">Nuevo Movimiento de Showroom</h1>
    <p class="text-muted mb-0 small">Transferencia de stock entre salas o restock de sala</p>
  </div>
</div>

<% if @showrooms.empty? %>
  <div class="alert alert-warning">
    <i class="bi bi-exclamation-triangle me-2"></i>
    No hay showrooms configurados.
    <%= link_to "Configurar showrooms", new_admin_showroom_path, class: "alert-link" %>
    antes de crear movimientos.
  </div>
<% else %>
  <div class="card shadow-sm border-0">
    <div class="card-body">
      <%= render "deliveries/showroom_movement_partials/form", delivery: @delivery, showrooms: @showrooms %>
    </div>
  </div>
<% end %>

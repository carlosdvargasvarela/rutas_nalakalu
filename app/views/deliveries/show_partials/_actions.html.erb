<%# app/views/deliveries/show_partials/_actions.html.erb %>
<div class="d-flex gap-2 align-items-center">
  <%# ── Aprobar ── %>
  <% if policy(delivery).approve? && !delivery.approved? %>
    <%= button_to approve_delivery_path(delivery),
          method: :patch,
          class: "btn btn-sm btn-success d-flex align-items-center gap-1 fw-semibold",
          data: { turbo_confirm: "¿Aprobar esta entrega para producción?" } do %>
      <i class="bi bi-shield-check-fill"></i>
      <span class="d-none d-md-inline">Aprobar</span>
    <% end %>
  <% end %>
  <%# ── Confirmar todos los productos ── %>
  <% if policy(delivery).edit? && delivery.delivery_items.pending.any? %>
    <%= button_to confirm_all_items_delivery_path(delivery),
          method: :patch,
          class: "btn btn-sm btn-primary d-flex align-items-center gap-1 fw-semibold",
          data: { turbo_confirm: "¿Confirmar todos los productos como listos?" } do %>
      <i class="bi bi-box-seam-fill"></i>
      <span class="d-none d-md-inline">Confirmar Todo</span>
    <% end %>
  <% end %>
  <%# ── Dropdown acciones secundarias ── %>
  <div class="dropdown">
    <button class="btn btn-sm btn-outline-secondary"
            type="button"
            data-bs-toggle="dropdown"
            aria-expanded="false"
            title="Más acciones">
      <i class="bi bi-three-dots-vertical"></i>
    </button>
    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-3 py-2" style="min-width: 210px;">
      <%# Reasignar vendedor %>
      <% if policy(delivery).reassign_seller? %>
        <li>
          <button class="dropdown-item d-flex align-items-center gap-2 py-2"
                  data-bs-toggle="modal"
                  data-bs-target="#reassignSellerModal">
            <span class="dropdown-item-icon bg-secondary-subtle text-secondary">
              <i class="bi bi-person-gear"></i>
            </span>
            Reasignar Vendedor
          </button>
        </li>
      <% end %>
      <%# Caso de servicio %>
      <li>
        <%= link_to new_service_case_for_existing_delivery_path(delivery),
              class: "dropdown-item d-flex align-items-center gap-2 py-2",
              data: { turbo_frame: "_top" } do %>
          <span class="dropdown-item-icon bg-warning-subtle text-warning-emphasis">
            <i class="bi bi-headset"></i>
          </span>
          Crear Caso de Servicio
        <% end %>
      </li>
      <li><hr class="dropdown-divider my-1"></li>
      <%# Archivar — acción destructiva al final %>
      <li>
        <%= button_to archive_delivery_path(delivery),
              method: :patch,
              class: "dropdown-item d-flex align-items-center gap-2 py-2 text-danger",
              form_class: "d-block",
              data: { turbo_confirm: "¿Archivar esta entrega? Se quitará de la vista principal." } do %>
          <span class="dropdown-item-icon bg-danger-subtle text-danger">
            <i class="bi bi-archive"></i>
          </span>
          Archivar Entrega
        <% end %>
      </li>
    </ul>
  </div>
</div>
<%# app/views/deliveries/show_partials/_actions.html.erb %>
<%# Locals esperados (todos opcionales, default false/nil): %>
<%# can_edit, can_approve, can_reassign_seller, can_new_service_case, can_reopen, is_admin %>
<% can_edit             = local_assigns.fetch(:can_edit, false) %>
<% can_approve          = local_assigns.fetch(:can_approve, false) %>
<% can_reassign_seller  = local_assigns.fetch(:can_reassign_seller, false) %>
<% can_new_service_case = local_assigns.fetch(:can_new_service_case, false) %>
<% can_reopen           = local_assigns.fetch(:can_reopen, false) %>
<% is_admin             = local_assigns.fetch(:is_admin, false) %>
<div class="d-flex align-items-center gap-2 flex-wrap">
  <% if delivery.warehousing? %>
    <%# ── MODO BODEGAJE ── %>
    <% if can_edit %>
      <%= button_to warehousing_form_delivery_path(delivery),
            method: :get,
            form: { data: { turbo_frame: "modal" } },
            class: "btn btn-sm d-inline-flex align-items-center gap-2 px-3",
            style: "background-color:#f3e8ff; color:#6f42c1; border:1px solid #ce93d8;" do %>
        <i class="bi bi-calendar-range"></i>
        <span>Cambiar fecha de bodegaje</span>
      <% end %>
      <%= button_to end_warehousing_delivery_path(delivery),
            method: :patch,
            class: "btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-2 px-3",
            data: { turbo_confirm: "¿Finalizar el bodegaje y devolver a estado pendiente?" } do %>
        <i class="bi bi-box-arrow-up"></i>
        <span>Salir de Bodegaje</span>
      <% end %>
    <% end %>
  <% else %>
    <%# ── FLUJO NORMAL ── %>
    <%# Reabrir Entrega (solo para admin/gerente cuando está cerrada) %>
    <% if can_reopen && delivery.reopenable? %>
      <%= button_to reopen_delivery_path(delivery),
            method: :patch,
            form: { data: { turbo_stream: true } },
            class: "btn btn-sm btn-outline-warning d-inline-flex align-items-center gap-2 px-3",
            data: { turbo_confirm: "¿Reabrir esta entrega? Volverá a 'Pendiente de confirmar' y todos los productos se resetearán a pendiente." } do %>
        <i class="bi bi-arrow-counterclockwise"></i>
        <span>Reabrir Entrega</span>
      <% end %>
    <% end %>
    <%# Aprobar Ruta %>
    <% if can_approve && !delivery.approved? %>
      <%= button_to approve_delivery_path(delivery),
            method: :patch,
            class: "btn btn-sm btn-warning d-inline-flex align-items-center gap-2 px-3 shadow-sm",
            data: { turbo_confirm: "¿Aprobar para producción?" } do %>
        <i class="bi bi-check2-all"></i>
        <span>Aprobar Ruta</span>
      <% end %>
    <% end %>
    <%# Dropdown de Acciones Secundarias %>
    <% show_dropdown = can_edit || can_reassign_seller || can_new_service_case || is_admin %>
    <% if show_dropdown %>
      <div class="dropdown">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                data-bs-toggle="dropdown" aria-expanded="false">
          Acciones
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow border-0 m-0">
          <% if can_edit %>
            <% if delivery.delivery_items.pending.any? %>
              <li>
                <%= button_to confirm_all_items_delivery_path(delivery),
                      method: :patch,
                      class: "dropdown-item d-flex align-items-center gap-2 py-2 border-0 bg-transparent text-start",
                      data: { turbo_confirm: "¿Confirmar todos los productos?" } do %>
                  <i class="bi bi-box-seam text-primary"></i> Confirmar Productos
                <% end %>
              </li>
            <% end %>
            <% if !delivery.delivered? && !delivery.cancelled? && !delivery.archived? && !delivery.rescheduled? %>
              <li>
                <%= button_to mark_as_delivered_delivery_path(delivery),
                      method: :patch,
                      class: "dropdown-item d-flex align-items-center gap-2 py-2 border-0 bg-transparent text-start",
                      data: { turbo_confirm: "¿Marcar esta entrega y todos sus productos como entregados?" } do %>
                  <i class="bi bi-check-circle-fill text-success"></i> Marcar como Entregada
                <% end %>
              </li>
            <% end %>
            <% if delivery.delivery_items.pending.any? || (!delivery.delivered? && !delivery.cancelled? && !delivery.archived? && !delivery.rescheduled?) %>
              <li><hr class="dropdown-divider"></li>
            <% end %>
            <li>
              <%= link_to edit_delivery_path(delivery),
                    class: "dropdown-item d-flex align-items-center gap-2 py-2",
                    data: { turbo_frame: "_top" } do %>
                <i class="bi bi-pencil text-muted"></i> Editar Datos
              <% end %>
            </li>
            <% if delivery.delivery_items.bulk_reschedulable.any? %>
              <li>
                <%= link_to split_form_delivery_path(delivery),
                      class: "dropdown-item d-flex align-items-center gap-2 py-2",
                      data: { turbo_frame: "_top" } do %>
                  <i class="bi bi-diagram-2 text-warning"></i> Dividir Entrega
                <% end %>
              </li>
            <% end %>
            <% if delivery.confirmed_by_vendor? && !delivery.bulk_locked? %>
              <li>
                <%= button_to unconfirm_delivery_path(delivery),
                      method: :patch,
                      form: { data: { turbo_stream: true } },
                      class: "dropdown-item d-flex align-items-center gap-2 py-2 border-0 bg-transparent text-start text-warning",
                      data: { turbo_confirm: "¿Desconfirmar la entrega? Los productos volverán a estado pendiente." } do %>
                  <i class="bi bi-arrow-counterclockwise"></i> Desconfirmar
                <% end %>
              </li>
            <% end %>
            <li>
              <%= button_to warehousing_form_delivery_path(delivery),
                    method: :get,
                    form: { data: { turbo_frame: "modal" }, class: "w-100" },
                    class: "dropdown-item d-flex align-items-center gap-2 py-2 border-0 bg-transparent text-start" do %>
                <i class="bi bi-building text-muted"></i> Pasar a Bodegaje
              <% end %>
            </li>
          <% end %>
          <% if can_reassign_seller %>
            <li>
              <button class="dropdown-item d-flex align-items-center gap-2 py-2"
                      data-bs-toggle="modal"
                      data-bs-target="#reassignSellerModal">
                <i class="bi bi-person-gear text-muted"></i> Reasignar Vendedor
              </button>
            </li>
          <% end %>
          <% if can_new_service_case %>
            <li><hr class="dropdown-divider"></li>
            <li>
              <%= link_to new_service_case_for_existing_delivery_path(delivery),
                    class: "dropdown-item d-flex align-items-center gap-2 py-2",
                    data: { turbo_frame: "_top" } do %>
                <i class="bi bi-headset text-warning"></i> Crear Caso Servicio
              <% end %>
            </li>
            <li>
              <%= button_to repair_service_form_delivery_path(delivery),
                    method: :get,
                    form: { data: { turbo_frame: "modal" }, class: "w-100" },
                    class: "dropdown-item d-flex align-items-center gap-2 py-2 border-0 bg-transparent text-start" do %>
                <i class="bi bi-wrench-adjustable text-info"></i> Serv. Reparación
              <% end %>
            </li>
          <% end %>
          <% if is_admin %>
            <li><hr class="dropdown-divider"></li>
            <li>
              <%= button_to archive_delivery_path(delivery),
                    method: :patch,
                    class: "dropdown-item text-danger d-flex align-items-center gap-2 py-2",
                    data: { turbo_confirm: "¿Archivar esta entrega?" } do %>
                <i class="bi bi-archive"></i> Archivar Entrega
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% end %>
</div>
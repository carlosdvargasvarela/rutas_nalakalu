<%# app/views/deliveries/show_partials/_summary_cards.html.erb %>
<%# ⚠️ Este partial SÍ usa policy() — SOLO se renderiza desde controller (vía _detail_data) %>
<div class="row g-3">
  <%# ══ CARD: Información de Entrega ══ %>
  <div class="col-md-6">
    <div class="border rounded-3 overflow-hidden h-100 bg-white shadow-sm">
      <div class="px-3 py-2 border-bottom bg-light d-flex align-items-center gap-2">
        <i class="bi bi-truck text-primary card-header-icon"></i>
        <span class="card-section-label">
          Información de Entrega
        </span>
      </div>
      <div class="p-3">
        <p class="fw-bold fs-6 mb-2"><%= delivery.client_name %></p>
        <div class="mb-3">
          <%= render "deliveries/order_contacts_display", delivery: delivery, style: :full %>
        </div>
        <% if delivery.condominio_number.present? || delivery.casa_number.present? %>
          <div class="d-flex flex-wrap gap-2 mb-3">
            <% if delivery.condominio_number.present? %>
              <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill badge-sm">
                <i class="bi bi-buildings me-1"></i><%= delivery.condominio_number %>
              </span>
            <% end %>
            <% if delivery.casa_number.present? %>
              <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill badge-sm">
                <i class="bi bi-house-door me-1"></i>Casa <%= delivery.casa_number %>
              </span>
            <% end %>
          </div>
        <% end %>
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="bg-primary-subtle text-primary rounded-2 d-flex align-items-center justify-content-center flex-shrink-0 icon-square-sm">
            <i class="bi bi-calendar-event"></i>
          </span>
          <div>
            <div class="card-field-label">Fecha programada</div>
            <div class="fw-semibold small"><%= l delivery.delivery_date, format: :long %></div>
          </div>
        </div>
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="bg-info-subtle text-info rounded-2 d-flex align-items-center justify-content-center flex-shrink-0 icon-square-sm">
            <i class="bi bi-clock"></i>
          </span>
          <div>
            <div class="card-field-label">Preferencia horaria</div>
            <div class="fw-semibold small"><%= delivery.delivery_time_preference.presence || 'Sin especificar' %></div>
          </div>
        </div>
        <% if delivery.approved? %>
          <div class="d-flex align-items-center gap-2">
            <span class="bg-success-subtle text-success rounded-2 d-flex align-items-center justify-content-center flex-shrink-0 icon-square-sm">
              <i class="bi bi-shield-check"></i>
            </span>
            <div>
              <div class="card-field-label">Producción</div>
              <div class="fw-semibold small text-success">Aprobada para entrega</div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <%# ══ CARD: Detalles del Pedido ══ %>
  <div class="col-md-6">
    <div class="border rounded-3 overflow-hidden h-100 bg-white shadow-sm d-flex flex-column">
      <div class="px-3 py-2 border-bottom bg-light d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
          <i class="bi bi-receipt text-dark card-header-icon"></i>
          <span class="card-section-label">
            Detalles del Pedido
          </span>
        </div>
        <% if policy(delivery).reassign_seller? %>
          <button class="btn btn-xs btn-outline-secondary border-0"
                  data-bs-toggle="modal"
                  data-bs-target="#reassignSellerModal"
                  title="Reasignar vendedor">
            <i class="bi bi-arrow-left-right"></i>
          </button>
        <% end %>
      </div>
      <div class="p-3 flex-grow-1 d-flex flex-column">
        <div class="d-flex align-items-center gap-2 mb-3">
          <span class="badge bg-dark px-3 py-2 order-number-badge">#<%= delivery.order.number %></span>
          <%= status_badge(delivery.order, with_icon: false, classes: "status-badge-soft rounded-pill") %>
        </div>
        <div class="d-flex align-items-center gap-2 mb-3">
          <span class="bg-light text-secondary rounded-2 d-flex align-items-center justify-content-center flex-shrink-0 icon-square-sm-bordered">
            <i class="bi bi-person-badge"></i>
          </span>
          <div>
            <div class="card-field-label">Vendedor</div>
            <div class="fw-semibold small"><%= delivery.order.seller.name %></div>
            <div class="text-muted seller-code-text">Cód: <%= delivery.order.seller.seller_code %></div>
          </div>
        </div>
        <div class="mt-auto">
          <%= link_to order_path(delivery.order),
                class: "btn btn-sm btn-outline-secondary w-100",
                target: "_blank",
                rel: "noopener noreferrer" do %>
            <i class="bi bi-box-arrow-up-right me-1"></i>Ver entregas de este pedido
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <%# ══ CARD: Ubicación ══ %>
  <div class="col-12">
    <div class="border rounded-3 bg-white shadow-sm card-accent-danger">
      <div class="p-3 d-flex align-items-start gap-3">
        <span class="bg-danger-subtle text-danger rounded-2 d-flex align-items-center justify-content-center flex-shrink-0 icon-square-md">
          <i class="bi bi-geo-alt-fill fs-5"></i>
        </span>
        <div>
          <div class="card-field-label mb-1">
            Ubicación de Destino
          </div>
          <div class="fw-bold delivery-address-text"><%= delivery.delivery_address.address %></div>
          <% if delivery.delivery_address.description.present? %>
            <div class="text-muted small fst-italic mt-1"><%= delivery.delivery_address.description %></div>
          <% end %>
          <% if delivery.address_error? %>
            <span class="badge bg-danger-subtle text-danger border border-danger-subtle mt-2 d-inline-flex align-items-center gap-1 badge-xs">
              <i class="bi bi-exclamation-triangle-fill"></i> Coordenadas no verificadas
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <%# ══ CARD: Plan de Entrega ══ %>
  <% if delivery.delivery_plan_assignment.present? %>
    <% dpa = delivery.delivery_plan_assignment %>
    <% plan = dpa.delivery_plan %>
    <div class="col-12">
      <div class="border rounded-3 bg-white shadow-sm card-accent-info">
        <div class="p-3">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="card-field-label">
              Plan de Entrega
            </div>
            <% if plan.truck.present? %>
              <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle rounded-pill badge-xs">
                <i class="bi bi-truck me-1"></i><%= plan.truck %>
              </span>
            <% end %>
          </div>
          <div class="row g-2 text-center">
            <div class="col-4 border-end">
              <div class="card-field-label">Plan</div>
              <%= link_to plan.full_name, delivery_plan_path(plan),
                    class: "fw-bold small d-block text-truncate",
                    target: "_blank",
                    rel: "noopener noreferrer" %>
            </div>
            <div class="col-4 border-end">
              <div class="card-field-label">Conductor</div>
              <div class="fw-bold small"><%= plan.driver&.name.presence || '—' %></div>
            </div>
            <div class="col-4">
              <div class="card-field-label">Parada</div>
              <div class="fw-bold small">#<%= dpa.stop_order || '—' %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
  <%# ══ CARD: Notas del Cliente ══ %>
  <% client = delivery.order.client %>
  <div class="col-12">
    <div class="border rounded-3 bg-white shadow-sm">
      <div class="px-3 py-2 border-bottom bg-light d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2">
          <i class="bi bi-sticky-fill text-warning card-header-icon"></i>
          <span class="card-section-label">
            Notas del Cliente - Estas NO son notas de la entrega, sino del cliente en general. Para notas específicas de esta entrega, ver sección de editar entrega. Estas notas sólo las ve el equipo de logística, no los conductores.
          </span>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span id="client_notes_badge_<%= client.id %>">
            <%= render "client_notes/badge", client: client %>
          </span>
          <button class="btn btn-xs btn-outline-warning border-0 d-flex align-items-center gap-1"
                data-bs-toggle="modal"
                data-bs-target="#clientNotesModal_<%= client.id %>"
                title="Ver todas las notas">
            <i class="bi bi-arrow-up-right-square"></i>
          </button>
        </div>
      </div>
      <div class="p-3">
        <%# Notas pinned directamente visibles %>
        <div id="client_pinned_notes_<%= client.id %>">
          <% if client.pinned_notes.any? %>
            <%= render "client_notes/pinned_banner", client: client %>
          <% else %>
            <div class="text-center text-muted py-2 no-pinned-notes">
              <i class="bi bi-sticky opacity-25 d-block fs-4 mb-1"></i>
              Sin alertas fijadas para este cliente.
            </div>
          <% end %>
        </div>
        <%# Botón para abrir modal con todas las notas %>
        <button class="btn btn-sm btn-outline-secondary w-100 mt-2 d-flex align-items-center justify-content-center gap-1 btn-notes-toggle"
              data-bs-toggle="modal"
              data-bs-target="#clientNotesModal_<%= client.id %>">
          <i class="bi bi-chat-left-text"></i>
          Ver todas las notas / Agregar nota
        </button>
      </div>
    </div>
  </div>
  <%# Modal (se renderiza una sola vez por cliente) %>
  <%= render "client_notes/modal", client: client %>
  <%# Modal reasignación (solo si tiene permisos) %>
  <%= render "deliveries/show_partials/reassign_seller_modal", delivery: delivery %>
</div>
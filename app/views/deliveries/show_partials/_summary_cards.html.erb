<%# app/views/deliveries/show_partials/_summary_cards.html.erb %>
<div class="d-flex flex-column gap-3">
  <%# Información General %>
  <div class="p-3 border rounded bg-light-subtle">
    <h6 class="small text-uppercase text-secondary fw-bold mb-2">
      <i class="bi bi-info-circle me-1"></i> General
    </h6>
    <div class="d-flex flex-column gap-1 small">
      <div>
        <span class="text-muted">Fecha:</span>
        <strong><%= l delivery.delivery_date, format: :long %></strong>
      </div>
      <div>
        <span class="text-muted">Estado:</span>
        <span class="badge bg-<%= delivery_status_color(delivery.status) %>">
          <%= delivery.display_status %>
        </span>
        <% if delivery.approved? %>
          <span class="badge bg-success ms-1">
            <i class="bi bi-shield-check"></i> Aprobada
          </span>
        <% end %>
      </div>
      <div>
        <span class="text-muted">Preferencia horaria:</span>
        <%= delivery.delivery_time_preference.presence || 'No especificado' %>
      </div>
    </div>
  </div>
  <%# Pedido %>
  <div class="p-3 border rounded bg-light-subtle">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <h6 class="small text-uppercase text-secondary fw-bold mb-0">
        <i class="bi bi-receipt me-1"></i> Pedido
      </h6>
      <div class="d-flex gap-1">
        <% if policy(delivery).take_order? && current_user.seller? && delivery.order.seller_id != current_user.seller&.id %>
          <%= button_to take_order_delivery_path(delivery), method: :patch,
                class: "btn btn-xs btn-outline-primary",
                data: { turbo_confirm: "¿Tomar este pedido?" } do %>
            <i class="bi bi-hand-index-thumb"></i>
          <% end %>
        <% end %>
        <% if policy(delivery).reassign_seller? %>
          <button class="btn btn-xs btn-outline-secondary"
                  data-bs-toggle="modal"
                  data-bs-target="#reassignSellerModal">
            <i class="bi bi-arrow-left-right"></i>
          </button>
        <% end %>
      </div>
    </div>
    <div class="d-flex flex-column gap-1 small">
      <div>
        <span class="text-muted">Número:</span>
        <%= link_to delivery.order.number, order_path(delivery.order), class: "fw-semibold" %>
      </div>
      <div>
        <span class="text-muted">Cliente:</span>
        <strong><%= delivery.order.client.name %></strong>
      </div>
      <div>
        <span class="text-muted">Vendedor:</span>
        <%= delivery.order.seller.name %>
        <span class="text-muted">(<%=  delivery.order.seller.seller_code %>)</span>
        <% if current_user.seller? && delivery.order.seller_id == current_user.seller&.id %>
          <span class="badge bg-success ms-1">Tu pedido</span>
        <% end %>
      </div>
    </div>
  </div>
  <%# Dirección %>
  <div class="p-3 border rounded bg-light-subtle">
    <h6 class="small text-uppercase text-secondary fw-bold mb-2">
      <i class="bi bi-geo-alt me-1"></i> Entrega
    </h6>
    <div class="d-flex flex-column gap-1 small">
      <div><span class="text-muted">Dirección:</span> <%= delivery.delivery_address.address %></div>
      <% if delivery.delivery_address.description.present? %>
        <div><span class="text-muted">Referencia:</span> <%= delivery.delivery_address.description %></div>
      <% end %>
      <div><span class="text-muted">Contacto:</span> <%= delivery.contact_name %></div>
      <div><span class="text-muted">Teléfono:</span> <%= delivery.contact_phone.presence || 'No especificado' %></div>
      <% if delivery.delivery_notes.present? %>
        <div class="mt-1 p-2 bg-white border rounded">
          <i class="bi bi-sticky me-1 text-warning"></i><%= delivery.delivery_notes %>
        </div>
      <% end %>
    </div>
  </div>
  <%# Plan de Entrega (solo si existe) %>
  <% if delivery.delivery_plan_assignment.present? %>
    <% dpa = delivery.delivery_plan_assignment %>
    <% plan = dpa.delivery_plan %>
    <div class="p-3 border rounded bg-light-subtle">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="small text-uppercase text-secondary fw-bold mb-0">
          <i class="bi bi-diagram-3 me-1"></i> Plan de Entrega
        </h6>
        <% if plan.truck.present? %>
          <span class="badge bg-secondary">
            <i class="bi bi-truck me-1"></i><%= plan.truck %>
          </span>
        <% end %>
      </div>
      <div class="d-flex flex-column gap-1 small">
        <div>
          <span class="text-muted">Plan:</span>
          <%= link_to plan.full_name, delivery_plan_path(plan), class: "fw-semibold" %>
        </div>
        <div>
          <span class="text-muted">Conductor:</span>
          <%= plan.driver&.name.presence || content_tag(:span, "Sin asignar", class: "text-muted") %>
        </div>
        <div><span class="text-muted">Parada:</span> #<%= dpa.stop_order || "-" %></div>
      </div>
    </div>
  <% end %>
  <%# Modal de reasignación %>
  <%= render "deliveries/show_partials/reassign_seller_modal", delivery: delivery %>
</div>
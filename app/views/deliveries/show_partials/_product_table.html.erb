<%# app/views/deliveries/show_partials/_product_table.html.erb %>
<div id="delivery_items_list">
  <% if delivery.delivery_items.any? %>
    <% if policy(delivery).edit? %>
      <div class="d-flex flex-wrap gap-2 mb-3 p-2 bg-light rounded-3 border">
        <%= form_with url: bulk_confirm_production_delivery_items_path,
              method: :patch,
              data: { turbo_stream: true } do |f| %>
          <%= hidden_field_tag :delivery_id, delivery.id %>
          <%= f.submit "✓ Confirmar todos",
                class: "btn btn-sm btn-outline-info",
                data: { turbo_confirm: "¿Confirmar todos los items pendientes?" } %>
        <% end %>
        <%= form_with url: bulk_deliver_production_delivery_items_path,
              method: :patch,
              data: { turbo_stream: true } do |f| %>
          <%= hidden_field_tag :delivery_id, delivery.id %>
          <%= f.submit "✓ Marcar entregados",
                class: "btn btn-sm btn-outline-success",
                data: { turbo_confirm: "¿Marcar todos como entregados?" } %>
        <% end %>
        <%= form_with url: bulk_cancel_production_delivery_items_path,
              method: :patch,
              data: { turbo_stream: true } do |f| %>
          <%= hidden_field_tag :delivery_id, delivery.id %>
          <%= f.submit "✗ Cancelar todos",
                class: "btn btn-sm btn-outline-danger",
                data: { turbo_confirm: "¿Cancelar todos los items?" } %>
        <% end %>
      </div>
    <% end %>
    <div class="d-flex flex-column gap-2">
      <% delivery.delivery_items.includes(order_item: [:order, :order_item_notes]).each do |item| %>
        <%= render "deliveries/show_partials/product_item", item: item, delivery: delivery %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-inbox" style="font-size: 2.5rem; opacity: 0.3;"></i>
      <p class="mt-2 mb-0 small">No hay productos en esta entrega.</p>
    </div>
  <% end %>
</div>
<style>
  .btn-xs {
    padding: 0.15rem 0.5rem;
    font-size: 0.72rem;
    border-radius: 0.25rem;
    line-height: 1.5;
  }
</style>
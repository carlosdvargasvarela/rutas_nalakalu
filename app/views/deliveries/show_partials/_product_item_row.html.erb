<%# app/views/deliveries/show_partials/_product_item_row.html.erb %>
<% can_confirm = local_assigns.fetch(:can_confirm, false) %>
<tr id="<%= dom_id(item) %>"
  class="<%= 'item-with-notes' if item.notes.present? %>">
  <%# Checkbox %>
  <td class="text-center align-top pt-3">
    <% if can_confirm && item.bulk_reschedulable? %>
      <input type="checkbox"
             value="<%= item.id %>"
        class="form-check-input item-checkbox"
        data-delivery-items-selection-target="checkbox"
        data-action="change->delivery-items-selection#updateUI">
    <% end %>
  </td>
  <%# Producto + Notas %>
  <td class="py-2">
    <div class="d-flex flex-column gap-1">
      <%# Nombre + badges %>
      <div class="fw-bold text-dark d-flex align-items-center flex-wrap gap-1"
           style="font-size: 0.85rem;">
        <%= item.product %>
        <% if item.service_case? %>
          <span class="badge bg-info-subtle text-info border border-info-subtle"
                style="font-size: 0.6rem;">
            <i class="bi bi-tools"></i> Servicio
          </span>
        <% end %>
        <%= render "deliveries/shared_partials/item_status_badge", item: item %>
      </div>
      <%# Nota logística (alta prioridad) %>
      <% if item.notes.present? %>
        <div class="px-2 py-1 rounded-2 border-start border-3 border-warning bg-warning bg-opacity-10">
          <span class="text-warning-emphasis fw-medium" style="font-size: 0.72rem; line-height: 1.3;">
            <i class="bi bi-chat-right-dots-fill me-1"></i><%= item.notes %>
          </span>
        </div>
      <% end %>
      <%# Nota producción (contexto) %>
      <% if item.order_item&.notes.present? %>
        <div class="px-2 py-1 rounded-2 border-start border-3 border-secondary bg-light">
          <span class="text-muted" style="font-size: 0.72rem; line-height: 1.3;">
            <i class="bi bi-hammer me-1"></i><%= item.order_item.notes %>
          </span>
        </div>
      <% end %>
      <%# Alerta producción pendiente %>
      <% if item.order_item&.notes_open? %>
        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 align-self-start"
              style="font-size: 0.65rem;">
          <i class="bi bi-exclamation-triangle-fill me-1"></i>Pendiente de producción
        </span>
      <% end %>
    </div>
  </td>
  <%# Cantidad %>
  <td class="text-center align-top pt-3">
    <span class="fw-bold text-primary" style="font-size: 1rem;">
      <%= item.quantity_delivered %>
    </span>
  </td>
  <%# Acciones %>
  <td class="text-end align-top pt-2">
    <% if can_confirm %>
      <div class="dropdown">
        <button class="btn btn-sm btn-light border"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false">
          <i class="bi bi-three-dots"></i>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow border-0"
            style="font-size: 0.85rem; min-width: 160px;">
          <% unless item.confirmed? || item.delivered? || item.rescheduled? || item.cancelled? %>
            <li>
              <%= button_to confirm_delivery_item_path(item),
                    method: :patch,
                    class: "dropdown-item py-2 text-success",
                    data: { turbo_stream: true } do %>
                <i class="bi bi-check2-all me-2"></i>Confirmar
              <% end %>
            </li>
          <% end %>
          <% unless item.delivered? || item.rescheduled? || item.cancelled? %>
            <li>
              <%= button_to mark_delivered_delivery_item_path(item),
                    method: :patch,
                    class: "dropdown-item py-2 text-primary",
                    data: { turbo_stream: true } do %>
                <i class="bi bi-truck me-2"></i>Entregar
              <% end %>
            </li>
            <li>
              <%= link_to reschedule_form_delivery_item_path(item),
                    class: "dropdown-item py-2 text-warning",
                    data: { turbo_frame: "modal" } do %>
                <i class="bi bi-calendar-event me-2"></i>Reagendar
              <% end %>
            </li>
            <li><hr class="dropdown-divider my-1"></li>
            <li>
              <%= button_to cancel_delivery_item_path(item),
                    method: :patch,
                    class: "dropdown-item py-2 text-danger",
                    data: {
                      turbo_stream: true,
                      turbo_confirm: "¿Cancelar este producto?"
                    } do %>
                <i class="bi bi-x-circle me-2"></i>Cancelar
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </td>
</tr>
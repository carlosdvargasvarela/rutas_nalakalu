<%# app/views/deliveries/show_partials/_detail.html.erb %>
<%= turbo_frame_tag "delivery_detail" do %>
  <div class="d-flex flex-column h-100 bg-white">
    <%# ═══════════════════════════════════════
        HEADER — Cliente + Estado + Acciones
    ═══════════════════════════════════════ %>
    <div class="detail-header px-4 py-3 border-bottom flex-shrink-0">
      <div class="d-flex justify-content-between align-items-start gap-3">
        <%# Info principal %>
        <div class="min-w-0 flex-grow-1">
          <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
            <%= status_badge(delivery, with_icon: true, classes: "status-badge-soft rounded-pill") %>
            <% if delivery.approved? %>
              <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle rounded-pill status-badge-soft">
                <i class="bi bi-shield-check me-1"></i>Aprobada
              </span>
            <% end %>
          </div>
          <h5 class="fw-bold text-dark mb-0 text-truncate">
            <%= delivery.order&.client&.name || delivery.client_name %>
          </h5>
          <div class="detail-meta mt-1 d-flex flex-wrap gap-3">
            <span>
              <i class="bi bi-hash text-primary"></i>
              <strong><%= delivery.order&.number || "S/N" %></strong>
            </span>
            <span>
              <i class="bi bi-calendar-event text-primary"></i>
              <%= delivery.delivery_date ? l(delivery.delivery_date, format: :long) : 'Fecha no definida' %>
            </span>
            <% if delivery.delivery_time_preference.present? %>
              <span>
                <i class="bi bi-clock text-secondary"></i>
                <%= delivery.delivery_time_preference %>
              </span>
            <% end %>
          </div>
        </div>
        <%# Acciones %>
        <div class="d-flex gap-2 flex-shrink-0 align-items-start">
          <%= render "deliveries/show_partials/actions", delivery: delivery %>
          <%= link_to edit_delivery_path(delivery),
                class: "btn btn-sm btn-outline-secondary",
                title: "Editar entrega",
                data: { turbo_frame: "_top" } do %>
            <i class="bi bi-pencil"></i>
          <% end %>
        </div>
      </div>
      <%# Alertas críticas bajo el header %>
      <% if delivery.address_error? || (policy(delivery).approve? && !delivery.approved?) || delivery.rescheduled? %>
        <div class="mt-3 d-flex flex-column gap-2">
          <%= render "deliveries/show_partials/alerts", delivery: delivery %>
        </div>
      <% end %>
    </div>
    <%# ═══════════════════════════════════════
        TABS
    ═══════════════════════════════════════ %>
    <ul class="detail-tabs nav nav-underline px-4 border-bottom flex-shrink-0" role="tablist">
      <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#info-pane" type="button">
          <i class="bi bi-info-circle me-1"></i>Información
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link position-relative" data-bs-toggle="tab" data-bs-target="#products-pane" type="button">
          <i class="bi bi-box-seam me-1"></i>Productos
          <% pending_count = delivery.delivery_items.pending.count %>
          <% if pending_count > 0 %>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                  style="font-size: 0.55rem;">
              <%= pending_count %>
            </span>
          <% end %>
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#map-pane" type="button">
          <i class="bi bi-map me-1"></i>Mapa
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#history-pane" type="button">
          <i class="bi bi-clock-history me-1"></i>Historial
        </button>
      </li>
    </ul>
    <%# ═══════════════════════════════════════
        CONTENIDO DE TABS
    ═══════════════════════════════════════ %>
    <div class="tab-content flex-grow-1 overflow-auto custom-scrollbar p-4">
      <%# INFO %>
      <div class="tab-pane fade show active" id="info-pane" role="tabpanel">
        <%= render "deliveries/show_partials/summary_cards", delivery: delivery %>
        <% if delivery.delivery_notes.present? %>
          <div class="detail-notes mt-3 p-3 rounded-3 border-start border-warning border-4 bg-warning-subtle">
            <div class="section-label text-warning-emphasis">
              <i class="bi bi-sticky me-1"></i>Notas de Entrega
            </div>
            <p class="mb-0 small text-warning-emphasis"><%= delivery.delivery_notes %></p>
          </div>
        <% end %>
      </div>
      <%# PRODUCTOS %>
      <div class="tab-pane fade" id="products-pane" role="tabpanel">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h6 class="fw-bold mb-0">
            <i class="bi bi-box-seam me-1 text-primary"></i>Productos
          </h6>
          <span class="badge bg-light text-dark border">
            <%= delivery.delivery_items.count %> items
          </span>
        </div>
        <div id="delivery_items_list">
          <%= render "deliveries/show_partials/product_table",
                delivery: delivery,
                future_deliveries: @future_deliveries %>
        </div>
      </div>
      <%# MAPA %>
      <div class="tab-pane fade" id="map-pane" role="tabpanel">
        <div class="mb-3 p-3 rounded-3 bg-light border d-flex align-items-center gap-2">
          <i class="bi bi-geo-alt-fill text-danger fs-5"></i>
          <span class="small fw-medium"><%= delivery.address %></span>
        </div>
        <%= render "deliveries/show_partials/map", delivery: delivery %>
      </div>
      <%# HISTORIAL %>
      <div class="tab-pane fade" id="history-pane" role="tabpanel">
        <%= render "deliveries/show_partials/history",
              delivery: delivery,
              delivery_history: @delivery_history %>
      </div>
    </div>
    <%# ═══════════════════════════════════════
        FOOTER
    ═══════════════════════════════════════ %>
    <div class="detail-footer px-4 py-2 border-top flex-shrink-0">
      <div class="d-flex justify-content-between align-items-center">
        <span class="text-muted" style="font-size: 0.72rem;">
          <i class="bi bi-clock-history me-1"></i>
          Actualizado <%= time_ago_in_words(delivery.updated_at) %>
        </span>
        <div class="d-flex gap-2">
          <%= link_to delivery_path(delivery, format: :pdf),
                class: "btn btn-xs btn-light border fw-medium",
                target: "_blank",
                title: "Exportar PDF" do %>
            <i class="bi bi-file-earmark-pdf text-danger me-1"></i>PDF
          <% end %>
          <%= link_to delivery_path(delivery, format: :xlsx),
                class: "btn btn-xs btn-light border fw-medium",
                title: "Exportar Excel" do %>
            <i class="bi bi-file-earmark-excel text-success me-1"></i>Excel
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
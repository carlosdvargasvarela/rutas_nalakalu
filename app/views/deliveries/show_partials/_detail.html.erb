<%# app/views/deliveries/show_partials/_detail.html.erb %>
<%= turbo_frame_tag "delivery_detail" do %>
  <div class="d-flex flex-column h-100 bg-white" style="min-height: 600px;">
    <%# ───────── HEADER ───────── %>
    <div class="p-3 border-bottom bg-light sticky-top">
      <div class="d-flex justify-content-between align-items-start mb-2">
        <div>
          <h5 class="mb-0 fw-bold text-primary">
            <%= delivery.client_name %>
            <span class="text-muted fw-normal small">#<%= delivery.id %></span>
          </h5>
          <div class="small text-secondary mt-1">
            <i class="bi bi-calendar-event me-1"></i>
            <%= delivery.delivery_date ? l(delivery.delivery_date, format: :long) : 'Fecha no definida' %>
          </div>
        </div>
        <div class="d-flex gap-1">
          <%= render "deliveries/show_partials/actions", delivery: delivery %>
          <%= link_to edit_delivery_path(delivery),
                class: "btn btn-sm btn-outline-secondary",
                data: { turbo_frame: "_top" } do %>
            <i class="bi bi-pencil"></i>
          <% end %>
        </div>
      </div>
      <% if delivery.address_error? || delivery.rescheduled? %>
        <div class="mt-2">
          <%= render "deliveries/show_partials/alerts", delivery: delivery %>
        </div>
      <% end %>
    </div>
    <%# ───────── TABS ───────── %>
    <ul class="nav nav-underline px-3 border-bottom bg-white" role="tablist">
      <li class="nav-item">
        <button class="nav-link active py-2 small fw-medium"
                data-bs-toggle="tab"
                data-bs-target="#info-pane"
                type="button">
          Información
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link py-2 small fw-medium position-relative"
                data-bs-toggle="tab"
                data-bs-target="#products-pane"
                type="button">
          Productos
          <% pending_count = delivery.delivery_items.pending.count %>
          <% if pending_count > 0 %>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                  style="font-size: 0.6rem;">
              <%= pending_count %>
            </span>
          <% end %>
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link py-2 small fw-medium"
                data-bs-toggle="tab"
                data-bs-target="#map-pane"
                type="button">
          Mapa
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link py-2 small fw-medium"
                data-bs-toggle="tab"
                data-bs-target="#history-pane"
                type="button">
          Historial
        </button>
      </li>
    </ul>
    <%# ───────── CONTENIDO ───────── %>
    <div class="tab-content flex-grow-1 overflow-auto p-3 bg-white">
      <%# INFO %>
      <div class="tab-pane fade show active" id="info-pane">
        <div class="row g-3">
          <div class="col-12">
            <%= render "deliveries/show_partials/summary_cards", delivery: delivery %>
          </div>
          <div class="col-12">
            <div class="card border-0 bg-light">
              <div class="card-body p-3">
                <h6 class="fw-bold mb-3 small text-uppercase text-secondary">
                  Instrucciones de Entrega
                </h6>
                <p class="mb-0 small">
                  <%= delivery.delivery_notes.presence || "Sin notas adicionales." %>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <%# PRODUCTOS %>
      <div class="tab-pane fade" id="products-pane">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h6 class="fw-bold mb-0">Productos</h6>
          <span class="badge bg-light text-dark border">
            <%= delivery.delivery_items.count %> items
          </span>
        </div>
        <div id="delivery_items_list">
          <%= render "deliveries/show_partials/product_table",
                delivery: delivery,
                future_deliveries: @future_deliveries %>
        </div>
      </div>
      <%# MAPA %>
      <div class="tab-pane fade" id="map-pane">
        <div class="mb-3">
          <label class="small text-muted d-block mb-1">Dirección</label>
          <div class="p-2 border rounded bg-light small fw-medium">
            <i class="bi bi-geo-alt-fill text-danger me-1"></i>
            <%= delivery.address %>
          </div>
        </div>
        <%= render "deliveries/show_partials/map", delivery: delivery %>
      </div>
      <%# HISTORIAL %>
      <div class="tab-pane fade" id="history-pane">
        <%= render "deliveries/show_partials/history",
              delivery: delivery,
              delivery_history: @delivery_history %>
      </div>
    </div>
    <%# ───────── FOOTER ───────── %>
    <div class="p-3 border-top bg-light">
      <div class="d-flex justify-content-between align-items-center">
        <span class="small text-muted">
          Actualizado: <%= time_ago_in_words(delivery.updated_at) %>
        </span>
        <div class="btn-group">
          <%= link_to 'PDF',
                delivery_path(delivery, format: :pdf),
                class: "btn btn-sm btn-light border",
                target: "_blank" %>
          <%= link_to 'Excel',
                delivery_path(delivery, format: :xlsx),
                class: "btn btn-sm btn-light border" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
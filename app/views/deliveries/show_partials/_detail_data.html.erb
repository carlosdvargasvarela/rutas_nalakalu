<%# app/views/deliveries/show_partials/_detail_data.html.erb %>
<div class="detail-panel-body bg-white">
  <%# ═══ HEADER UNIFICADO (Información + Acciones) ═══ %>
  <div class="detail-header px-3 px-md-4 py-3 border-bottom shadow-sm">
    <div class="d-flex justify-content-between align-items-start mb-3">
      <div class="min-w-0">
        <div class="d-flex align-items-center gap-2 mb-1">
          <%= status_badge(delivery, with_icon: true, classes: "status-badge-soft rounded-pill") %>
        </div>
        <h5 class="fw-bold text-dark mb-0"><%= delivery.client_name %></h5>
        <div class="detail-meta text-muted" style="font-size: 0.8rem;">
          <span class="me-2"><i class="bi bi-hash text-primary"></i> <strong><%= delivery.order_number %></strong></span>
          <span><i class="bi bi-calendar-event me-1"></i><%= l(delivery.delivery_date, format: :long) if delivery.delivery_date %></span>
        </div>
      </div>
      <div class="d-flex gap-1">
        <%= link_to edit_delivery_path(delivery), class: "btn btn-sm btn-outline-secondary", data: { turbo_frame: "_top" } do %>
          <i class="bi bi-pencil"></i>
        <% end %>
      </div>
    </div>
    <%# Fila de Acciones Principales (Inyectamos _actions aquí) %>
    <div class="d-flex justify-content-between align-items-center">
      <div id="delivery_actions_container">
        <%= render "deliveries/show_partials/actions", delivery: delivery %>
      </div>
      <% if delivery.delivery_time_preference.present? %>
        <span class="badge bg-light text-secondary border small fw-normal">
          <i class="bi bi-clock me-1"></i><%= delivery.delivery_time_preference %>
        </span>
      <% end %>
    </div>
    <%# Alertas Críticas %>
    <% if delivery.rescheduled? || delivery.address_error? %>
      <div class="mt-3">
        <% if delivery.rescheduled? %>
          <div class="alert alert-info py-2 mb-1 small border-0 bg-info-subtle">
            <i class="bi bi-info-circle-fill me-2"></i>Reagendada: <%= delivery.reschedule_reason %>
          </div>
        <% end %>
        <% if delivery.address_error? %>
          <div class="alert alert-danger py-2 mb-0 small border-0 bg-danger-subtle">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>Error de geolocalización detectado.
          </div>
        <% end %>
      </div>
    <% end %>
    <% if delivery.requires_sala_pickup? %>
      <div class="alert alert-danger d-flex justify-content-between align-items-center py-2 mb-3 shadow-sm border-start border-4 border-danger">
        <div class="small">
          <i class="bi bi-shop-window me-2"></i>
          <strong>Atención:</strong> Existen productos de stock de sala que requieren recogida.
        </div>
        <%= link_to sala_pickup_form_delivery_path(delivery),
      class: "btn btn-sm btn-danger",
      data: { turbo_frame: "modal" } do %>
          <i class="bi bi-plus-circle me-1"></i> Generar Recogida
        <% end %>
      </div>
    <% end %>
  </div>
  <%# ═══ TABS NAV ═══ %>
  <ul class="nav nav-underline px-3 px-md-4 border-bottom bg-light" role="tablist" style="font-size: 0.85rem;">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#info-pane" type="button">Info</button></li>
    <li class="nav-item">
      <button class="nav-link position-relative" data-bs-toggle="tab" data-bs-target="#products-pane" type="button">
        Productos
        <% if delivery.delivery_items.pending.any? %>
          <span class="ms-1 badge rounded-pill bg-danger" style="font-size: 0.6rem;"><%= delivery.delivery_items.pending.count %></span>
        <% end %>
      </button>
    </li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#map-pane" type="button">Mapa</button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#history-pane" type="button">Historial</button></li>
  </ul>
  <%# ═══ CONTENIDO DINÁMICO ═══ %>
  <div class="tab-content detail-tab-content p-3 p-md-4">
    <div class="tab-pane fade show active" id="info-pane">
      <%= render "deliveries/show_partials/summary_cards", delivery: delivery %>
      <% if delivery.delivery_notes.present? %>
        <div class="mt-3 p-3 rounded bg-warning-subtle text-warning-emphasis small border-start border-warning border-4">
          <strong>Notas:</strong> <%= delivery.delivery_notes %>
        </div>
      <% end %>
    </div>
    <div class="tab-pane fade" id="products-pane">
      <%= render "deliveries/show_partials/product_table", delivery: delivery, future_deliveries: future_deliveries %>
    </div>
    <div class="tab-pane fade" id="map-pane">
      <%= render "deliveries/show_partials/map", delivery: delivery %>
    </div>
    <div class="tab-pane fade" id="history-pane">
      <%= render "deliveries/show_partials/history", delivery: delivery, delivery_history: delivery_history %>
    </div>
  </div>
</div>
<%# app/views/deliveries/show_partials/_detail_data.html.erb %>
<%= turbo_stream_from "delivery_#{delivery.id}_detail" %>
<div class="detail-panel-body bg-white h-100 d-flex flex-column">
  <%# Header con alertas — pasamos can_edit desde el contexto HTTP %>
  <%= render "deliveries/show_partials/detail_header",
        delivery: delivery,
        can_edit: policy(delivery).edit? %>
  <%# ═══ TABS NAV ═══ %>
  <nav class="bg-light border-bottom sticky-top shadow-sm" style="z-index: 10;">
    <ul class="nav nav-pills nav-fill px-4 py-2" id="deliveryTab" role="tablist" style="max-width: 600px;">
      <li class="nav-item">
        <button class="nav-link active small py-1" data-bs-toggle="tab" data-bs-target="#info-pane" type="button">
          Resumen
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link small py-1 position-relative" data-bs-toggle="tab" data-bs-target="#products-pane" type="button">
          Productos
          <% if delivery.delivery_items.pending.any? %>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                  style="font-size: 0.6rem;">
              <%= delivery.delivery_items.pending.count %>
            </span>
          <% end %>
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link small py-1" data-bs-toggle="tab" data-bs-target="#map-pane" type="button">
          Mapa
        </button>
      </li>
      <li class="nav-item">
        <button class="nav-link small py-1" data-bs-toggle="tab" data-bs-target="#history-pane" type="button">
          Historial
        </button>
      </li>
    </ul>
  </nav>
  <%# ═══ CONTENIDO ═══ %>
  <main class="tab-content flex-grow-1 overflow-auto bg-white p-4">
    <div class="tab-pane fade show active" id="info-pane">
      <%= render "deliveries/show_partials/summary_cards", delivery: delivery %>
      <% if delivery.delivery_notes.present? %>
        <div class="mt-4">
          <label class="text-muted small fw-bold text-uppercase mb-2 d-block">
            Instrucciones de Entrega
          </label>
          <div class="p-3 rounded bg-light border-start border-primary border-4 small">
            <%= delivery.delivery_notes %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="tab-pane fade" id="products-pane">
      <%= render "deliveries/show_partials/product_table",
            delivery: delivery,
            future_deliveries: future_deliveries %>
    </div>
    <div class="tab-pane fade" id="map-pane">
      <%= render "deliveries/show_partials/map", delivery: delivery %>
    </div>
    <div class="tab-pane fade" id="history-pane">
      <%= render "deliveries/show_partials/history",
            delivery: delivery,
            delivery_history: delivery_history %>
    </div>
  </main>
</div>
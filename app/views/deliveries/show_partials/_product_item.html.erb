<%# app/views/deliveries/show_partials/_product_item.html.erb %>
<div id="<​%= dom_id(item) %>"
  class="border rounded-3 bg-white shadow-sm overflow-hidden">
  <div class="d-flex align-items-stretch">
    <%# Franja lateral de color por estado %>
    <div class="flex-shrink-0"
         style="width: 4px; background-color: <%= delivery_status_border_color(item.status) %>;"></div>
    <div class="card-body p-2 flex-grow-1">
      <div class="d-flex align-items-start gap-2">
        <%# Checkbox bulk (solo si el item es accionable) %>
        <% unless item.delivered? || item.cancelled? || item.rescheduled? %>
          <div class="pt-1 flex-shrink-0">
            <input type="checkbox"
                   class="form-check-input"
                   value="<​%= item.id %>"
            data-bulk-items-target="checkbox"
            data-action="change->bulk-items#toggle">
          </div>
        <% else %>
          <div class="pt-1 flex-shrink-0" style="width: 16px;"></div>
        <% end %>
        <div class="flex-grow-1">
          <%# Nombre + badges %>
          <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
            <span class="badge bg-secondary">x<%= item.quantity %></span>
            <span class="small fw-bold"><%= item.order_item.product %></span>
            <% if item.service_case? %>
              <span class="badge bg-warning text-dark" style="font-size: 0.65rem;">
                <i class="bi bi-tools"></i> Servicio
              </span>
            <% end %>
            <span class="badge rounded-pill ms-auto flex-shrink-0 <%= delivery_status_badge_class(item.status) %>"
                  style="font-size: 0.65rem;">
              <%= item.display_status %>
            </span>
          </div>
          <%# Notas del order_item %>
          <% if item.order_item.notes.present? %>
            <div class="small text-muted ps-1 border-start border-warning border-2 mb-1">
              <%= item.order_item.notes %>
            </div>
          <% end %>
          <% if item.order_item.notes_open? %>
            <div class="small text-warning fw-medium mb-1">
              <i class="bi bi-exclamation-triangle-fill me-1"></i>
              Producción reporta pendientes — revisar antes de confirmar
            </div>
          <% end %>
          <%# Notas de producción %>
          <% unless current_user.seller? %>
            <% if item.order_item.order_item_notes.any? %>
              <div class="mt-1">
                <%= render "order_item_notes/list", item: item.order_item %>
              </div>
            <% end %>
          <% end %>
          <%# Acciones individuales %>
          <% unless item.delivered? || item.cancelled? || item.rescheduled? %>
            <div class="mt-2 d-flex flex-wrap gap-1 justify-content-end">
              <%# Confirmar → lleva a estado "confirmed" → color info %>
              <% if item.pending? && policy(delivery).edit? %>
                <%= button_to confirm_delivery_item_path(item),
                      method: :patch,
                      class: "btn btn-xs btn-outline-info",
                      data: { turbo_confirm: "¿Confirmar este producto?" } do %>
                  <i class="bi bi-check-circle me-1"></i>Confirmar
                <% end %>
              <% end %>
              <%# Entregado → lleva a estado "delivered" → color success %>
              <% if policy(delivery).edit? %>
                <%= button_to mark_delivered_delivery_item_path(item),
                      method: :patch,
                      class: "btn btn-xs btn-outline-success",
                      data: { turbo_confirm: "¿Marcar como entregado?" } do %>
                  <i class="bi bi-check2-circle me-1"></i>Entregado
                <% end %>
                <%# Reagendar → lleva a estado "rescheduled" → color warning %>
                <button type="button"
                        class="btn btn-xs btn-outline-warning"
                        data-bs-toggle="modal"
                        data-bs-target="#rescheduleItemModal<%= item.id %>">
                  <i class="bi bi-calendar2-plus me-1"></i>Reagendar
                </button>
                <%# Cancelar → lleva a estado "cancelled" → color danger %>
                <%= button_to cancel_delivery_item_path(item),
                      method: :patch,
                      class: "btn btn-xs btn-outline-danger",
                      data: { turbo_confirm: "¿Cancelar este item?" } do %>
                  <i class="bi bi-x-circle"></i>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <%# Estado terminal — solo texto informativo %>
            <div class="mt-1 text-end">
              <% if item.delivered? %>
                <span class="small text-success">
                  <i class="bi bi-check2-circle me-1"></i>Entregado
                </span>
              <% elsif item.rescheduled? %>
                <span class="small text-warning">
                  <i class="bi bi-calendar-x me-1"></i>Reagendado
                </span>
              <% elsif item.cancelled? %>
                <span class="small text-danger">
                  <i class="bi bi-x-circle me-1"></i>Cancelado
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<%# Modal reagendado individual %>
<% if policy(delivery).edit? && !item.delivered? && !item.cancelled? %>
  <%= render "delivery_items/reschedule_modal", item: item, future_deliveries: @future_deliveries %>
<% end %>
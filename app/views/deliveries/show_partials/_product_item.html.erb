<%# app/views/deliveries/show_partials/_product_item.html.erb %>
<div id="<%= dom_id(item) %>" class="border rounded-3 bg-white shadow-sm overflow-hidden">
  <div class="d-flex align-items-stretch">
    <div class="flex-shrink-0"
         style="width: 4px; background-color: <%= delivery_status_border_color(item.status) %>;"></div>
    <div class="p-3 flex-grow-1">
      <%# Fila 1: Nombre + badge estado %>
      <div class="d-flex justify-content-between align-items-start mb-2">
        <span class="fw-semibold text-dark" style="font-size: 0.9rem;">
          <%= item.order_item&.product_name || item.order_item&.product || "Producto sin nombre" %>
          <% if item.service_case? %>
            <span class="badge bg-warning text-dark ms-1" style="font-size: 0.65rem;">
              <i class="bi bi-tools"></i> Servicio
            </span>
          <% end %>
        </span>
        <span class="badge rounded-pill ms-2 flex-shrink-0 <%= delivery_status_badge_class(item.status) %>"
              style="font-size: 0.65rem;">
          <%= item.display_status %>
        </span>
      </div>
      <%# Fila 2: Cantidad + notas %>
      <div class="d-flex gap-3 mb-2 small text-secondary flex-wrap">
        <span>
          <i class="bi bi-box me-1"></i>
          Cant: <strong class="text-dark"><%= item.quantity %></strong>
        </span>
        <% if item.order_item&.notes.present? %>
          <span class="text-muted border-start border-warning border-2 ps-2">
            <%= item.order_item.notes.truncate(60) %>
          </span>
        <% end %>
        <% if item.order_item&.notes_open? %>
          <span class="text-warning fw-medium">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>Pendientes de producción
          </span>
        <% end %>
      </div>
      <%# Notas de producción %>
      <% unless current_user.seller? %>
        <% if item.order_item&.order_item_notes&.any? %>
          <div class="mb-2">
            <%= render "order_item_notes/list", item: item.order_item %>
          </div>
        <% end %>
      <% end %>
      <%# Fila 3: Acciones o estado terminal %>
      <% if item.delivered? || item.cancelled? || item.rescheduled? %>
        <div class="pt-2 border-top text-end">
          <% if item.delivered? %>
            <span class="small text-success">
              <i class="bi bi-check2-circle me-1"></i>Entregado
            </span>
          <% elsif item.rescheduled? %>
            <span class="small text-warning">
              <i class="bi bi-calendar-x me-1"></i>Reagendado
            </span>
          <% elsif item.cancelled? %>
            <span class="small text-danger">
              <i class="bi bi-x-circle me-1"></i>Cancelado
            </span>
          <% end %>
        </div>
      <% elsif policy(delivery).edit? %>
        <div class="d-flex flex-wrap gap-1 pt-2 border-top">
          <% if item.pending? %>
            <%= button_to confirm_delivery_item_path(item),
                  method: :patch,
                  class: "btn btn-xs btn-outline-info",
                  data: { turbo_stream: true, turbo_confirm: "¿Confirmar este producto?" } do %>
              <i class="bi bi-check-lg me-1"></i>Confirmar
            <% end %>
          <% end %>
          <% if item.confirmed? || item.pending? %>
            <%= button_to mark_delivered_delivery_item_path(item),
                  method: :patch,
                  class: "btn btn-xs btn-outline-success",
                  data: { turbo_stream: true, turbo_confirm: "¿Marcar como entregado?" } do %>
              <i class="bi bi-truck me-1"></i>Entregado
            <% end %>
          <% end %>
          <%# Botón reagendar:
              1. data-turbo-frame="modal"  → Turbo carga la respuesta en el <turbo-frame id="modal">
              2. data-bs-toggle / target   → Bootstrap abre el #globalModal
          %>
          <%= link_to reschedule_form_delivery_item_path(item),
              class: "btn btn-xs btn-outline-warning",
              data: { turbo_frame: "modal" } do %>
            <i class="bi bi-calendar-event me-1"></i>Reagendar
          <% end %>
          <%= button_to cancel_delivery_item_path(item),
                method: :patch,
                class: "btn btn-xs btn-outline-danger",
                data: { turbo_stream: true, turbo_confirm: "¿Cancelar este item?" } do %>
            <i class="bi bi-x-circle me-1"></i>Cancelar
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
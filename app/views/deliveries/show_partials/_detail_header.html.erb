<%# app/views/deliveries/show_partials/_detail_header.html.erb %>
<% can_edit = local_assigns.fetch(:can_edit, false) %>
<header id="delivery_detail_header_<%= delivery.id %>" class="bg-white border-bottom p-4">
  <div class="row align-items-center g-3">
    <div class="col-md">
      <div class="d-flex align-items-center gap-3 mb-2">
        <%= status_badge(delivery, with_icon: true, classes: "status-badge-soft rounded-pill px-3 py-1") %>
        <small class="text-muted">
          <i class="bi bi-hash text-primary"></i>
          <strong><%= delivery.order_number %></strong>
        </small>
      </div>
      <h4 class="fw-bold text-dark mb-1"><%= delivery.client_name %></h4>
      <div class="d-flex flex-wrap gap-3 text-muted small">
        <span>
          <i class="bi bi-calendar3 me-1"></i>
          <%= l(delivery.delivery_date, format: :long) if delivery.delivery_date %>
        </span>
        <% if delivery.delivery_time_preference.present? %>
          <span>
            <i class="bi bi-clock me-1 text-primary"></i>
            <%= delivery.delivery_time_preference %>
          </span>
        <% end %>
      </div>
    </div>
    <div class="col-md-auto">
      <% if can_edit %>
        <div id="delivery_actions_container">
          <%= render "deliveries/show_partials/actions", delivery: delivery %>
        </div>
      <% end %>
    </div>
  </div>
  <%# ═══ ALERTAS CONTEXTUALES ═══ %>
  <% if delivery.rescheduled? || delivery.address_error? || delivery.requires_sala_pickup? %>
    <div class="mt-4">
      <% if delivery.requires_sala_pickup? %>
        <div class="alert alert-danger border-0 shadow-sm d-flex justify-content-between align-items-center mb-2 px-3 py-2">
          <div class="small fw-medium">
            <i class="bi bi-shop-window me-2"></i>Requiere Recogida en Sala
          </div>
          <% if can_edit %>
            <%= link_to sala_pickup_form_delivery_path(delivery),
                  class: "btn btn-sm btn-danger text-uppercase fw-bold",
                  style: "font-size: 0.65rem;",
                  data: { turbo_frame: "modal" } do %>
              Generar Ahora
            <% end %>
          <% end %>
        </div>
      <% end %>
      <% if delivery.rescheduled? %>
        <div class="alert alert-info border-0 bg-info-subtle small py-2 mb-2">
          <i class="bi bi-info-circle me-2"></i>
          <strong>Reagendada:</strong> <%= delivery.reschedule_reason %>
        </div>
      <% end %>
      <% if delivery.address_error? %>
        <div class="alert alert-warning border-0 bg-warning-subtle small py-2 mb-0">
          <i class="bi bi-geo-alt-fill me-2"></i>Revisar dirección: Error de geolocalización.
        </div>
      <% end %>
    </div>
  <% end %>
</header>
<%# app/views/deliveries/show_partials/_detail_header.html.erb %>
<%# Locals esperados: delivery, can_edit (bool), can_approve (bool), %>
<%# can_reassign_seller (bool), can_new_service_case (bool), can_reopen (bool), is_admin (bool) %>
<% can_edit             = local_assigns.fetch(:can_edit, false) %>
<% can_approve          = local_assigns.fetch(:can_approve, false) %>
<% can_reassign_seller  = local_assigns.fetch(:can_reassign_seller, false) %>
<% can_new_service_case = local_assigns.fetch(:can_new_service_case, false) %>
<% can_reopen           = local_assigns.fetch(:can_reopen, false) %>
<% is_admin             = local_assigns.fetch(:is_admin, false) %>
<header id="delivery_detail_header_<%= delivery.id %>" class="bg-white border-bottom p-4">
  <div class="row align-items-center g-3">
    <div class="col-md">
      <div class="d-flex align-items-center gap-3 mb-2">
        <%= status_badge(delivery, with_icon: true, classes: "status-badge-soft rounded-pill px-3 py-1") %>
        <small class="text-muted">
          <i class="bi bi-hash text-primary"></i>
          <strong><%= delivery.order_number %></strong>
        </small>
      </div>
      <h4 class="fw-bold text-dark mb-1"><%= delivery.client_name %></h4>
      <div class="d-flex flex-wrap gap-3 text-muted small">
        <span>
          <i class="bi bi-calendar3 me-1"></i>
          <%= l(delivery.delivery_date, format: :long) if delivery.delivery_date %>
        </span>
        <% if delivery.delivery_time_preference.present? %>
          <span>
            <i class="bi bi-clock me-1 text-primary"></i>
            <%= delivery.delivery_time_preference %>
          </span>
        <% end %>
      </div>
    </div>
    <div class="col-md-auto">
      <% if can_edit || can_approve || can_reassign_seller || can_new_service_case || can_reopen || is_admin %>
        <div id="delivery_actions_container">
          <%= render "deliveries/show_partials/actions",
                delivery:             delivery,
                can_edit:             can_edit,
                can_approve:          can_approve,
                can_reassign_seller:  can_reassign_seller,
                can_new_service_case: can_new_service_case,
                can_reopen:           can_reopen,
                is_admin:             is_admin %>
        </div>
      <% end %>
    </div>
  </div>
  <%# ═══ ALERTAS CONTEXTUALES ═══ %>
  <% sc_alert = delivery.requires_service_case_action? || (delivery.service_case? && !delivery.bulk_locked?) %>
  <% rs_alert = delivery.requires_repair_service_action? || (delivery.repair_service? && !delivery.bulk_locked?) %>
  <% if delivery.rescheduled? || delivery.address_error? || delivery.requires_sala_pickup? || sc_alert || rs_alert %>
    <div class="mt-4">
      <% if delivery.requires_sala_pickup? %>
        <div class="alert alert-danger border-0 shadow-sm d-flex justify-content-between align-items-center mb-2 px-3 py-2">
          <div class="small fw-medium">
            <i class="bi bi-shop-window me-2"></i>Pendiente de retiro en Sala
          </div>
          <% if can_edit %>
            <%= link_to sala_pickup_form_delivery_path(delivery),
                  class: "btn btn-sm btn-danger text-uppercase fw-bold",
                  style: "font-size: 0.65rem;",
                  data: { turbo_frame: "modal" } do %>
              Generar Ahora
            <% end %>
          <% end %>
        </div>
      <% end %>
      <% if sc_alert %>
        <% sc_labels = { "pickup_with_return" => "Recolección + devolución", "only_pickup" => "Recolección", "return_delivery" => "Devolución", "onsite_repair" => "Reparación en sitio" } %>
        <div class="alert alert-warning border-0 shadow-sm d-flex justify-content-between align-items-center mb-2 px-3 py-2">
          <div class="small fw-medium">
            <i class="bi bi-headset me-2"></i>
            <% if delivery.service_case? %>
              Caso de servicio —
              <strong><%= sc_labels[delivery.delivery_type] || delivery.delivery_type.to_s.humanize %></strong>
            <% else %>
              Contiene productos de <strong>caso de servicio</strong>
            <% end %>
          </div>
          <% if can_edit %>
            <%= button_to service_case_form_delivery_path(delivery),
                  method: :get,
                  form: { data: { turbo_frame: "modal" } },
                  class: "btn btn-sm btn-warning text-uppercase fw-bold",
                  style: "font-size: 0.65rem;" do %>
              <i class="bi bi-headset me-1"></i>Gestionar caso
            <% end %>
          <% end %>
        </div>
      <% end %>
      <% if rs_alert %>
        <% rs_labels = { "repair_pickup" => "Recolección para reparación", "repair_return" => "Devolución de reparación" } %>
        <div class="alert alert-info border-0 shadow-sm d-flex justify-content-between align-items-center mb-2 px-3 py-2">
          <div class="small fw-medium">
            <i class="bi bi-wrench-adjustable me-2"></i>
            <% if delivery.repair_service? %>
              Serv. Reparación —
              <strong><%= rs_labels[delivery.delivery_type] || delivery.delivery_type.to_s.humanize %></strong>
            <% else %>
              Contiene productos de <strong>servicio de reparación</strong>
            <% end %>
          </div>
          <% if can_edit %>
            <%= button_to repair_service_form_delivery_path(delivery),
                  method: :get,
                  form: { data: { turbo_frame: "modal" } },
                  class: "btn btn-sm btn-info text-white text-uppercase fw-bold",
                  style: "font-size: 0.65rem;" do %>
              <i class="bi bi-wrench-adjustable me-1"></i>Gestionar reparación
            <% end %>
          <% end %>
        </div>
      <% end %>
      <% if delivery.rescheduled? %>
        <div class="alert alert-info border-0 bg-info-subtle small py-2 mb-2">
          <i class="bi bi-info-circle me-2"></i>
          <strong>Reagendada:</strong> <%= delivery.reschedule_reason %>
        </div>
      <% end %>
      <% if delivery.address_error? %>
        <div class="alert alert-warning border-0 bg-warning-subtle small py-2 mb-0">
          <i class="bi bi-geo-alt-fill me-2"></i>Revisar dirección: Error de geolocalización.
        </div>
      <% end %>
    </div>
  <% end %>
</header>
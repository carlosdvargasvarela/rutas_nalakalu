<%# app/views/deliveries/index_partials/_delivery_card_content.html.erb %>
<div id="<%= dom_id(delivery, :card_content) %>">
  <div class="card card-hover border-0 shadow-sm mb-2 <%= delivery.address_error? ? 'border-start border-start-danger border-3' : 'border-start border-start-primary border-3' %>"
       style="border-radius: 10px; cursor: pointer;">
    <div class="card-body p-3">
      <%# ── Fila 1: Número de pedido + estado ── %>
      <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="fw-bold text-primary small">
          <i class="bi bi-hash"></i><%= delivery.order&.number || "S/N" %>
        </span>
        <span class="badge <%= status_badge_class(delivery) %> rounded-pill" style="font-size: 0.65rem;">
          <%= delivery.display_status %>
        </span>
      </div>
      <%# ── Fila 2: Cliente ── %>
      <div class="fw-semibold text-dark mb-2 text-truncate" style="font-size: 0.95rem;">
        <i class="bi bi-person-fill text-secondary me-1" style="font-size: 0.8rem;"></i>
        <%= delivery.order&.client&.name || delivery.client_name %>
      </div>
      <%# ── Fila 3: Fecha + dirección ── %>
      <div class="d-flex flex-column gap-1 mb-2">
        <div class="small text-secondary d-flex align-items-center gap-1">
          <i class="bi bi-calendar3 text-primary" style="font-size: 0.75rem;"></i>
          <span><%= delivery.delivery_date ? l(delivery.delivery_date, format: :short) : "Sin fecha" %></span>
          <% if delivery.delivery_time_preference.present? %>
            <span class="text-muted">·</span>
            <span class="text-muted" style="font-size: 0.7rem;"><%= delivery.delivery_time_preference %></span>
          <% end %>
        </div>
        <div class="small text-secondary d-flex align-items-center gap-1">
          <i class="bi bi-geo-alt text-danger" style="font-size: 0.75rem;"></i>
          <span class="text-truncate" style="max-width: 200px;">
            <%= delivery.delivery_address&.address&.truncate(35) || "Sin dirección" %>
          </span>
        </div>
      </div>
      <%# ── Fila 4: Vendedor + badges ── %>
      <div class="d-flex justify-content-between align-items-center pt-2 border-top">
        <span class="small text-muted d-flex align-items-center gap-1">
          <i class="bi bi-person-badge"></i>
          <%= delivery.order&.seller&.name&.truncate(20) || "S/V" %>
        </span>
        <div class="d-flex gap-1">
          <% if delivery.delivery_items.pending.any? %>
            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill"
                  style="font-size: 0.6rem;">
              <i class="bi bi-clock me-1"></i><%= delivery.delivery_items.pending.count %> pend.
            </span>
          <% end %>
          <% if delivery.delivery_plan.present? %>
            <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle rounded-pill"
                  style="font-size: 0.6rem;">
              <i class="bi bi-truck"></i>
            </span>
          <% end %>
          <% if delivery.has_service_cases? %>
            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill"
                  style="font-size: 0.6rem;">
              <i class="bi bi-tools"></i>
            </span>
          <% end %>
        </div>
      </div>
      <%# ── Alerta dirección ── %>
      <% if delivery.address_error? %>
        <div class="mt-2 px-2 py-1 bg-danger-subtle text-danger rounded-2 small d-flex align-items-center gap-1"
             style="font-size: 0.72rem;">
          <i class="bi bi-exclamation-triangle-fill"></i> Dirección requiere revisión
        </div>
      <% end %>
    </div>
  </div>
</div>
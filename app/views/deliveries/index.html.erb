<%# app/views/deliveries/index.html.erb %>
<%= turbo_stream_from "deliveries" %>
<div class="workspace-container container-fluid py-3"
     data-controller="workspace"
     data-workspace-active-class="active-card">
  <div class="row g-3 workspace-row">
    <%# ── COLUMNA IZQUIERDA: Lista ── %>
    <div class="col-12 col-lg-5 col-xl-4 workspace-col d-flex flex-column">
      <div class="card shadow-sm border-0 h-100 d-flex flex-column overflow-hidden">
        <%# Header Principal %>
        <div class="card-header bg-white border-bottom py-3 flex-shrink-0">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold">
              <i class="bi bi-truck me-2 text-primary"></i>Entregas
            </h5>
            <div class="d-flex gap-1">
              <% if policy(Delivery).create? %>
                <%= link_to new_delivery_path, class: "btn btn-sm btn-primary" do %>
                  <i class="bi bi-plus-lg"></i>
                  <span class="d-none d-sm-inline">Nueva</span>
                <% end %>
              <% end %>
              <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                  <i class="bi bi-three-dots"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                  <% if policy(Delivery).create? && !current_user&.seller? %>
                    <li><%= link_to "Mandado interno", new_internal_delivery_deliveries_path, class: "dropdown-item" %></li>
                    <li><%= link_to "Caso de servicio", new_service_case_deliveries_path, class: "dropdown-item" %></li>
                    <li><hr class="dropdown-divider"></li>
                  <% end %>
                  <li><%= link_to "Exportar Excel", deliveries_path(format: :xlsx, q: params[:q]&.to_unsafe_h), class: "dropdown-item" %></li>
                </ul>
              </div>
            </div>
          </div>
          <%# Filtros Ransack %>
          <%= search_form_for @q, url: deliveries_path, html: { data: { turbo_action: "advance" } } do |f| %>
            <div class="d-flex flex-column gap-2">
              <div class="input-group input-group-sm">
                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-person"></i></span>
                <%= f.search_field :order_client_name_cont, class: "form-control bg-light border-start-0 border-end-0", placeholder: "Cliente..." %>
                <span class="input-group-text bg-light border-start-0 border-end-0 text-muted"><i class="bi bi-hash"></i></span>
                <%= f.search_field :order_number_cont, class: "form-control bg-light border-start-0", placeholder: "N°..." %>
              </div>
              <div class="input-group input-group-sm">
                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-person-badge"></i></span>
                <%= f.select :order_seller_id_eq,
                    options_from_collection_for_select(@sellers, :id, ->(s) { "#{s.name} · #{s.seller_code}" }, params.dig(:q, :order_seller_id_eq)),
                    { include_blank: "Todos los vendedores" },
                    { class: "form-select form-select-sm bg-light border-start-0" } %>
              </div>
              <%= f.select :status_eq,
                  Delivery.statuses.map { |k, _v| [t("activerecord.attributes.delivery.statuses.#{k}"), k] },
                  { include_blank: "Todos los estados" },
                  { class: "form-select form-select-sm bg-light" } %>
              <div class="d-flex gap-2 align-items-center">
                <div class="input-group input-group-sm flex-grow-1">
                  <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-calendar-range"></i></span>
                  <%= f.date_field :delivery_date_gteq, class: "form-control form-control-sm bg-light border-start-0", placeholder: "Desde" %>
                </div>
                <span class="text-muted small">→</span>
                <div class="input-group input-group-sm flex-grow-1">
                  <%= f.date_field :delivery_date_lteq, class: "form-control form-control-sm bg-light", placeholder: "Hasta" %>
                </div>
              </div>
              <div class="d-flex gap-2 mt-1">
                <%= f.submit "Filtrar Resultados", class: "btn btn-sm btn-primary flex-fill fw-bold" %>
                <%= link_to "Limpiar", deliveries_path, class: "btn btn-sm btn-outline-secondary flex-fill" %>
              </div>
            </div>
          <% end %>
          <%# Filtros rápidos %>
          <div class="d-flex gap-1 mt-3 flex-wrap">
            <%= link_to deliveries_path(no_plan: 1), class: "btn btn-xs btn-outline-secondary #{params[:no_plan].present? ? 'active' : ''}" do %>
              <i class="bi bi-calendar-x me-1"></i>Sin plan
            <% end %>
            <%= link_to deliveries_path(show_rescheduled: 1), class: "btn btn-xs btn-outline-warning #{params[:show_rescheduled] == '1' ? 'active' : ''}" do %>
              <i class="bi bi-arrow-repeat me-1"></i>Reagendadas
            <% end %>
            <%= link_to deliveries_path(only_service_cases: 1), class: "btn btn-xs btn-outline-info #{params[:only_service_cases].present? ? 'active' : ''}" do %>
              <i class="bi bi-tools me-1"></i>Servicio
            <% end %>
          </div>
        </div>
        <%# Lista de tarjetas %>
        <%= turbo_frame_tag "deliveries_list", class: "flex-grow-1 overflow-auto p-2", style: "background-color: #f4f6f9;" do %>
          <% if @deliveries.any? %>
            <div class="d-flex flex-column" id="deliveries_cards_container">
              <% @deliveries.each do |delivery| %>
                <%= render "deliveries/index_partials/delivery_card", delivery: delivery %>
              <% end %>
            </div>
            <div class="mt-3 d-flex justify-content-center">
              <%= paginate @deliveries %>
            </div>
          <% else %>
            <div class="text-center py-5 bg-white rounded-3 m-2 border">
              <i class="bi bi-inbox text-light-emphasis" style="font-size: 3rem;"></i>
              <p class="text-muted mt-3 mb-0">No se encontraron entregas</p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
    <%# ── COLUMNA DERECHA: Panel de detalle ── %>
    <div class="col-lg-7 col-xl-8 workspace-col d-none d-lg-flex flex-column">
      <div class="card shadow-sm border-0 h-100 overflow-hidden">
        <%= turbo_frame_tag "delivery_detail", class: "h-100 d-block" do %>
          <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted p-5 bg-white">
            <div class="text-center">
              <i class="bi bi-layout-sidebar-reverse text-light-emphasis" style="font-size: 4rem;"></i>
              <h5 class="fw-semibold mt-3">Selecciona una entrega</h5>
              <p class="small text-secondary mb-0">Haz clic en una tarjeta para ver y gestionar los detalles.</p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
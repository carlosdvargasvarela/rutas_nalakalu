<!-- app/views/delivery_plans/new_partials/_selected_sidebar.html.erb -->
<div class="card border-0 shadow-lg sticky-top" style="top: 24px; border-radius: 15px; overflow: hidden;">
  <div class="card-header bg-primary text-white py-3">
    <div class="d-flex align-items-center justify-content-between">
      <h5 class="mb-0 fw-bold"><i class="bi bi-list-check me-2"></i>Plan de Ruta</h5>
      <span class="badge bg-white text-primary fs-6 rounded-pill" id="selected-summary" data-delivery-plan-sidebar-target="summary">0</span>
    </div>
  </div>
  <div class="card-body p-0" style="max-height: 55vh; overflow-y: auto; background: #fdfdfd;">
    <ul id="selected-deliveries" 
        class="list-group list-group-flush"
        data-delivery-plan-sidebar-target="list">
      <li class="list-group-item py-5 text-center text-muted">
        <i class="bi bi-plus-circle d-block h2 mb-2 opacity-25"></i>
        <p class="mb-0 fw-medium">Haz clic en los pedidos<br>
          para agregarlos aquí</p>
      </li>
    </ul>
  </div>
  <div class="card-footer bg-white p-4 border-top">
    <%= simple_form_for delivery_plan, url: delivery_plans_path do |f| %>
      <%= f.hidden_field :week, value: Date.today.cweek %>
      <%= f.hidden_field :year, value: Date.today.cwyear %>
      <div data-delivery-plan-sidebar-target="hiddenInputs"></div>
      <div class="d-grid">
        <%= f.submit "Crear Plan de Entrega",
              class: "btn btn-success btn-lg fw-bold py-3 shadow",
              style: "border-radius: 12px; font-size: 1.1rem;",
              data: { delivery_plan_sidebar_target: "submit" },
              disabled: true %>
      </div>
    <% end %>
  </div>
</div>
<%
  valid_points = []
  skipped = []

  assignments.each do |a|
    next if a.delivery.hidden_from_route_map?

    addr = a.delivery.delivery_address
    reason = if addr.nil?
      "Sin dirección registrada"
    elsif addr.latitude.blank? || addr.longitude.blank?
      "Dirección sin coordenadas GPS"
    end

    if reason
      skipped << { a: a, addr: addr, reason: reason }
    else
      valid_points << {
        id: a.id,
        stop_order: a.stop_order,
        address: addr.address,
        lat: addr.latitude,
        lng: addr.longitude,
        order_number: a.delivery.order&.number,
        client: a.delivery.order&.client&.name || "Sin nombre",
        date: l(a.delivery.delivery_date)
      }
    end
  end
%>
<div
  data-controller="delivery-plan-map"
  data-delivery-plan-map-api-key-value="<%= ENV['GOOGLE_MAPS_API_KEY'] %>"
  data-delivery-plan-map-points-value="<%= valid_points.to_json %>">
  <div style="height:500px" class="border-0" data-delivery-plan-map-target="map"></div>
</div>
<% if skipped.any? %>
  <div class="alert alert-warning m-2 mb-0 small">
    <div class="d-flex align-items-center gap-2 mb-2">
      <i class="bi bi-exclamation-triangle-fill"></i>
      <strong><%= skipped.size %> parada<%= skipped.size > 1 ? "s" : "" %> no se muestran en el mapa:</strong>
    </div>
    <ul class="mb-0 ps-3">
      <% skipped.each do |s| %>
        <% a = s[:a]; addr = s[:addr] %>
        <li>
          <span class="fw-semibold">Parada #<%= a.stop_order %></span>
          &mdash; <%= a.delivery.order&.number || "s/n" %>
          &mdash; <%= a.delivery.order&.client&.name || "Sin nombre" %>
          <% if addr&.address.present? %>
            (<%= addr.address %>)
          <% end %>
          &mdash; <span class="text-danger"><%= s[:reason] %></span>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

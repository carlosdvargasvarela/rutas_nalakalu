<div id="admin-route-map"
     style="height: 600px; width: 100%;"
     data-controller="admin-driver-map"
     data-admin-driver-map-delivery-plan-id-value="<%= @delivery_plan.id %>"
     data-admin-driver-map-current-lat-value="<%= @delivery_plan.current_lat.to_f %>"
     data-admin-driver-map-current-lng-value="<%= @delivery_plan.current_lng.to_f %>"
     data-admin-driver-map-assignments-value="<%= assignments.reject { |a| a.delivery.hidden_from_route_map? }.map { |a|
       delivery = a.delivery
       addr = delivery.delivery_address
       {
         id: a.id,
         stop_order: a.stop_order,
         status: a.status,
         delivery: {
           id: delivery.id,
           latitude: addr&.latitude&.to_f,
           longitude: addr&.longitude&.to_f,
           customer: {
             name: delivery.order&.client&.name || "Sin nombre",
             address: addr&.address
           }
         }
       }
     }.to_json %>">
</div>
<div class="p-3 bg-light border-top">
  <div class="row text-center">
    <div class="col-md-4">
      <small class="text-muted d-block">Última actualización</small>
      <strong id="admin-last-update">
        <%= @delivery_plan.last_seen_at ? time_ago_in_words(@delivery_plan.last_seen_at) + " atrás" : "Sin datos" %>
      </strong>
    </div>
    <div class="col-md-4">
      <small class="text-muted d-block">Conductor</small>
      <strong><%= @delivery_plan.driver&.name || "Sin asignar" %></strong>
    </div>
    <div class="col-md-4">
      <small class="text-muted d-block">Camión</small>
      <strong><%= @delivery_plan.truck || "Sin asignar" %></strong>
    </div>
  </div>
</div>

<% driver = delivery_plan.driver %>
<% service_cases = delivery_plan.service_cases_count %>

<div class="row g-3 mb-4">
  <%# Semana %>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body py-2 px-3">
        <div class="small text-muted mb-1"><i class="bi bi-calendar-week me-1"></i>Semana</div>
        <span class="badge bg-primary"><%= week_range_label(delivery_plan.year, delivery_plan.week) %></span>
      </div>
    </div>
  </div>

  <%# Estado %>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body py-2 px-3">
        <div class="small text-muted mb-1"><i class="bi bi-flag me-1"></i>Estado</div>
        <span class="badge bg-<%= delivery_plan_status_color(delivery_plan.status) %>">
          <i class="<%= delivery_plan_status_icon(delivery_plan.status) %> me-1"></i>
          <%= delivery_plan.display_status %>
        </span>
      </div>
    </div>
  </div>

  <%# Conductor %>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body py-2 px-3">
        <div class="small text-muted mb-1"><i class="bi bi-person me-1"></i>Conductor</div>
        <div class="fw-semibold small">
          <%= driver&.name || content_tag(:span, "No asignado", class: "text-muted fst-italic fw-normal") %>
        </div>
      </div>
    </div>
  </div>

  <%# Camión %>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body py-2 px-3">
        <div class="small text-muted mb-1"><i class="bi bi-truck-front me-1"></i>Camión</div>
        <% if delivery_plan.truck.present? %>
          <span class="badge bg-dark">
            <i class="bi bi-truck me-1"></i><%= delivery_plan.truck_label || delivery_plan.truck %>
          </span>
        <% else %>
          <span class="text-muted fst-italic small">No asignado</span>
        <% end %>
      </div>
    </div>
  </div>

  <%# Paradas %>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body py-2 px-3">
        <div class="small text-muted mb-1"><i class="bi bi-box-seam me-1"></i>Paradas</div>
        <div class="d-flex align-items-center gap-2">
          <span class="fw-bold fs-5"><%= delivery_plan.delivery_plan_assignments.size %></span>
          <% if service_cases > 0 %>
            <span class="badge bg-warning text-dark"
                  data-bs-toggle="tooltip"
                  title="<%= service_cases %> caso<%= service_cases > 1 ? 's' : '' %> de servicio">
              <i class="bi bi-exclamation-triangle me-1"></i><%= service_cases %>
            </span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# Tripulación %>
  <div class="col-12 col-md-8 col-xl-2">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body py-2 px-3">
        <div class="small text-muted mb-1"><i class="bi bi-people me-1"></i>Tripulación</div>
        <% if driver.present? && driver.crew_members.any? %>
          <div class="d-flex flex-wrap gap-1">
            <% driver.crew_members.each do |cm| %>
              <span class="badge bg-light text-dark border">
                <i class="bi bi-person me-1"></i><%= cm.name %>
              </span>
            <% end %>
          </div>
        <% else %>
          <span class="text-muted fst-italic small">Sin tripulación</span>
        <% end %>
      </div>
    </div>
  </div>
</div>

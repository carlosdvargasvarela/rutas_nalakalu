<!-- app/views/delivery_plans/new.html.erb -->
<div class="container-fluid py-4 bg-light min-vh-100">
  <div class="row g-4" data-controller="delivery-plan-sidebar">
    <!-- Panel izquierdo: Filtros + Tabla -->
    <div class="col-lg-8 col-xl-9">
      <div class="d-flex align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800 fw-bold">Crear Nuevo Plan de Entrega</h1>
        <span class="badge bg-primary ms-3 rounded-pill">Paso 1: Selección</span>
      </div>
      <%= render "delivery_plans/new_partials/filters", q: @q, from: @from, to: @to %>
      <%= render "delivery_plans/new_partials/deliveries_table", deliveries: @deliveries, selected_ids: @selected_delivery_ids %>
    </div>
    <!-- Panel derecho: Sidebar de Selección -->
    <div class="col-lg-4 col-xl-3">
      <%= render "delivery_plans/new_partials/selected_sidebar", delivery_plan: @delivery_plan %>
    </div>
  </div>
</div>
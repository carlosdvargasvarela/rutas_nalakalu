<div class="container-fluid py-4">
  <%= render "delivery_plans/show_partials/header",
        delivery_plan: @delivery_plan,
        from_date: @from_date %>
  <%= render "delivery_plans/show_partials/alerts",
        delivery_plan: @delivery_plan %>
  <%# ── Fila superior: Info general + Tripulación ── %>
  <div class="row g-4 mb-4">
    <div class="col-lg-5">
      <%= render "delivery_plans/show_partials/general_info",
            delivery_plan: @delivery_plan %>
    </div>
    <div class="col-lg-7">
      <%= render "delivery_plans/show_partials/crew",
            delivery_plan: @delivery_plan %>
    </div>
  </div>
  <%# ── Mapa de seguimiento ── %>
  <%= render "delivery_plans/show_partials/driver",
        assignments: @assignments %>
  <%# ── Tabla de entregas (desktop) ── %>
  <%= render "delivery_plans/show_partials/deliveries_table",
        delivery_plan: @delivery_plan %>
  <%# ── Cards de entregas (móvil) ── %>
  <%= render "delivery_plans/show_partials/deliveries_cards",
        delivery_plan: @delivery_plan %>
  <%# ── Botón volver ── %>
  <div class="mt-4">
    <%= render "delivery_plans/show_partials/back_button" %>
  </div>
</div>
<%# ── Modales de notas (fuera del layout) ── %>
<%= render "delivery_plans/show_partials/notes_modal" %>
<%# app/views/delivery_plans/index_partials/_empty_state.html.erb %>
<div class="text-center py-5 text-muted">
  <div class="empty-state-icon mx-auto mb-3">
    <i class="bi bi-calendar-x fs-1 text-muted opacity-50"></i>
  </div>
  <h5 class="text-muted mb-2">No hay planes de entrega</h5>
  <p class="text-muted mb-4 small">
    No se encontraron planes que coincidan con los filtros aplicados.
  </p>
  <%= link_to new_delivery_plan_path, class: "btn btn-primary btn-sm" do %>
    <i class="bi bi-plus-circle me-2"></i>Crear primer plan
  <% end %>
</div>
<%# app/views/deliveries/upsert_partials/_address_fields.html.erb %>
<div class="card shadow-sm border-primary mb-4"
     data-controller="address-autocomplete address-validator"
     data-address-autocomplete-api-key-value="<%= ENV.fetch('GOOGLE_MAPS_API_KEY', '') %>">
  <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
    <h5 class="mb-0"><i class="bi bi-geo-alt-fill me-2"></i>Ubicación Exacta de Entrega</h5>
    <span class="badge bg-white text-primary" data-address-autocomplete-target="statusBadge">Requerido</span>
  </div>
  <div class="card-body">
    <!-- BLOQUE 1: SELECCIÓN O BÚSQUEDA -->
    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <label class="form-label fw-bold text-primary">
          <i class="bi bi-bookmark-fill me-1"></i> 1. Seleccionar Dirección Guardada
        </label>
        <%= f.select :delivery_address_id,
              options_from_collection_for_select(
                addresses || [],
                :id,
                :address,
                f.object.delivery_address_id || f.object.delivery_address&.id
              ),
              { prompt: "--- Seleccionar dirección existente ---" },
              class: "form-select form-select-lg border-primary",
              data: {
                controller: "tom-select",
                "address-autocomplete-target": "addressSelect",
                action: "change->address-autocomplete#loadExistingAddress"
              } %>
        <div class="form-text">
          <i class="bi bi-info-circle me-1"></i>
          Direcciones previamente guardadas para este cliente
        </div>
      </div>
      <div class="col-md-6">
        <label class="form-label fw-bold text-success">
          <i class="bi bi-search me-1"></i> 2. O Buscar/Crear Nueva Ubicación
        </label>
        <div class="input-group input-group-lg">
          <span class="input-group-text bg-success text-white">
            <i class="bi bi-magic"></i>
          </span>
          <%= text_field_tag "delivery_address[search_input]",
                nil,
                placeholder: "Plus Code, Coordenadas (9.93,-84.08) o buscar lugar...",
                class: "form-control border-success",
                data: {
                  "address-autocomplete-target": "input",
                  action: "input->address-autocomplete#handleSmartInput blur->address-autocomplete#handleSmartInput"
                } %>
        </div>
        <div class="form-text text-success">
          <i class="bi bi-lightbulb me-1"></i>
          <strong>Tip:</strong> Pegue directamente <code>9.93,-84.08</code> o <code>W2H5+2Q</code>
        </div>
      </div>
    </div>
    <!-- BLOQUE 2: MAPA INTERACTIVO -->
    <div class="position-relative mb-3">
      <div data-address-autocomplete-target="map"
           class="rounded shadow border"
           style="height: 400px; width: 100%; background: #e9ecef;">
      </div>
      <div class="position-absolute bottom-0 start-0 m-3 p-3 bg-white rounded shadow border d-flex flex-column gap-2"
           style="z-index: 1000; min-width: 280px;">
        <div class="d-flex align-items-center gap-2">
          <span class="badge bg-primary">Lat:</span>
          <strong data-address-autocomplete-target="latDisplay" class="text-primary">--</strong>
          <span class="badge bg-primary ms-2">Lng:</span>
          <strong data-address-autocomplete-target="lngDisplay" class="text-primary">--</strong>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="badge bg-success">Plus Code:</span>
          <strong data-address-autocomplete-target="plusDisplay" class="text-success font-monospace">--</strong>
        </div>
        <small class="text-muted">
          <i class="bi bi-hand-index me-1"></i>
          Haz clic en el mapa o arrastra el marcador para ajustar
        </small>
      </div>
    </div>
    <!-- DETALLES GEOGRÁFICOS -->
    <div data-address-autocomplete-target="geoDetails"
         class="alert alert-light border mb-4 py-2"
         style="display: none;">
      <span class="text-muted small">
        <i class="bi bi-map me-1"></i>
        Selecciona una ubicación para ver los detalles geográficos
      </span>
    </div>
    <!-- BLOQUE 3: CAMPOS OCULTOS -->
    <%= hidden_field_tag "delivery_address[latitude]",
          params.dig(:delivery_address, :latitude) || f.object.delivery_address&.latitude,
          data: { "address-autocomplete-target": "lat" } %>
    <%= hidden_field_tag "delivery_address[longitude]",
          params.dig(:delivery_address, :longitude) || f.object.delivery_address&.longitude,
          data: { "address-autocomplete-target": "lng" } %>
    <%= hidden_field_tag "delivery_address[plus_code]",
          params.dig(:delivery_address, :plus_code) || f.object.delivery_address&.plus_code,
          data: { "address-autocomplete-target": "plus" } %>
    <%= hidden_field_tag "delivery_address[address]",
          params.dig(:delivery_address, :address) || f.object.delivery_address&.address,
          data: { "address-autocomplete-target": "addressName" } %>
    <%= hidden_field_tag "delivery_address[client_id]",
          (@client&.id || delivery.order&.client&.id),
          data: { "delivery-form-target": "newAddressClientId" } %>
    <!-- BLOQUE 4: DESCRIPCIÓN PARA EL CHOFER -->
    <div class="bg-light p-4 rounded border-start border-5 border-danger">
      <label class="form-label fw-bold text-danger fs-5 mb-3">
        <i class="bi bi-card-text me-2"></i>
        3. Referencia Exacta para el Chofer *
      </label>
      <%= text_area_tag "delivery_address[description]",
            params.dig(:delivery_address, :description) || f.object.delivery_address&.description,
            placeholder: "Ejemplo detallado:\n• Casa blanca de dos pisos con portón negro\n• 200 metros norte de la Iglesia Católica\n• Frente a la pulpería 'La Amistad'\n• Al lado del taller mecánico",
            rows: 4,
            class: "form-control form-control-lg border-danger",
            required: true,
            data: {
              "address-autocomplete-target": "description",
              "address-validator-target": "addressInput"
            } %>
      <div class="alert alert-danger d-flex align-items-start mt-3 mb-0" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
        <div>
          <strong>¡MUY IMPORTANTE!</strong>
          <p class="mb-2">
            Sin esta referencia detallada, el chofer NO podrá encontrar el lugar aunque el GPS sea exacto.
          </p>
          <ul class="mb-0 small">
            <li>Describe características visibles de la propiedad</li>
            <li>Menciona puntos de referencia cercanos conocidos</li>
            <li>Indica colores, números de casa, negocios vecinos</li>
            <li>Evita usar enlaces de Waze o Google Maps aquí</li>
          </ul>
        </div>
      </div>
    </div>
    <!-- BLOQUE 5: RESUMEN DE UBICACIÓN (sin código GMaps) ✅ -->
    <div class="mt-4 p-3 bg-white border rounded d-flex align-items-start gap-3">
      <i class="bi bi-geo-alt-fill text-primary fs-4 mt-1"></i>
      <div class="flex-grow-1">
        <div class="fw-bold text-primary small mb-1">Dirección detectada automáticamente</div>
        <div data-address-autocomplete-target="addressDisplay"
             class="text-dark"
             style="min-height: 1.4em;">
          <span class="text-muted fst-italic">Se completará al seleccionar una ubicación en el mapa</span>
        </div>
      </div>
    </div>
  </div>
  <!-- PIE DE TARJETA: SEMÁFORO -->
  <div class="card-footer bg-white border-top">
    <div class="d-flex align-items-center justify-content-between">
      <div class="d-flex align-items-center gap-2">
        <span class="badge bg-secondary" data-address-autocomplete-target="coordsStatus">
          <i class="bi bi-geo me-1"></i> Coordenadas: Pendiente
        </span>
        <span class="badge bg-secondary" data-address-autocomplete-target="descStatus">
          <i class="bi bi-card-text me-1"></i> Descripción: Pendiente
        </span>
      </div>
      <small class="text-muted">
        <i class="bi bi-shield-check me-1"></i>
        Validación en tiempo real
      </small>
    </div>
  </div>
</div>